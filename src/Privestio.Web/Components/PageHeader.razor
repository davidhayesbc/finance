<div class="page-header @(Compact ? "page-header--compact" : string.Empty)">
    <div class="page-header__main">
        <div class="page-header__copy">
        @if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            <span class="eyebrow">@Eyebrow</span>
        }

        <h1>@Title</h1>

        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <p>@Description</p>
        }

        @if (!string.IsNullOrWhiteSpace(UtilityDescription))
        {
            <p class="page-header__utility-description">@UtilityDescription</p>
        }
        </div>
    </div>

    @if (Context is not null || Actions is not null)
    {
        <div class="page-header__utility">
            @if (Context is not null)
            {
                <div class="page-header__context">
                    @Context
                </div>
            }

            @if (Actions is not null)
            {
                <div class="page-header__actions">
                    @Actions
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string? Eyebrow { get; set; }

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public string? UtilityDescription { get; set; }

    [Parameter]
    public bool Compact { get; set; }

    [Parameter]
    public RenderFragment? Context { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }
}
