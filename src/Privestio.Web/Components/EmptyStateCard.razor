<FluentCard Class="@CardClass">
    <FluentMessageBar Intent="@Intent" aria-live="@AriaLive">
        <div class="empty-state-card__message">
            <strong>@Message</strong>
            @if (!string.IsNullOrWhiteSpace(MissingContext))
            {
                <span>@MissingContext</span>
            }

            @if (!string.IsNullOrWhiteSpace(ActionHint))
            {
                <span>@ActionHint</span>
            }

            @if (!string.IsNullOrWhiteSpace(LocationHint))
            {
                <span>@LocationHint</span>
            }
        </div>
    </FluentMessageBar>

    @if (Actions is not null)
    {
        <div class="action-cluster empty-state-shell__actions">
            @Actions
        </div>
    }
</FluentCard>

@code {
    private string CardClass => $"surface-card empty-state-shell {Class}".Trim();

    [Parameter, EditorRequired]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public MessageIntent Intent { get; set; } = MessageIntent.Info;

    [Parameter]
    public string AriaLive { get; set; } = "polite";

    [Parameter]
    public string? MissingContext { get; set; }

    [Parameter]
    public string? ActionHint { get; set; }

    [Parameter]
    public string? LocationHint { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }
}
