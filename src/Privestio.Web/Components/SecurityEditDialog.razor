@implements IDialogContentComponent<SecurityCatalogItemResponse>
@inject ISecurityWebService SecurityService

<FluentStack Orientation="Orientation.Vertical" Style="gap: 1.25rem;">

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <FluentMessageBar Intent="@(_statusIsError? MessageIntent.Error: MessageIntent.Success)">
            @_statusMessage
        </FluentMessageBar>
    }

    <fieldset style="border: 1px solid var(--neutral-stroke-rest); border-radius: 4px; padding: 1rem;">
        <legend style="font-weight: 600; padding: 0 0.5rem;">Security details</legend>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <FluentTextField @bind-Value="_displaySymbol" Label="Display symbol" />
            <FluentTextField @bind-Value="_name" Label="Security name" />
            <FluentTextField @bind-Value="_exchange" Label="Exchange" />
            <FluentTextField @bind-Value="_currency" Label="Currency" />
        </div>
        <div style="margin-top: 0.75rem;">
            <FluentCheckbox @bind-Value="_isCashEquivalent" Label="Cash equivalent" />
        </div>
        <div style="margin-top: 1rem; display: flex; gap: 0.5rem;">
            <FluentButton Appearance="Appearance.Accent" Disabled="@_isSaving" OnClick="SaveSecurityAsync">
                Save security
            </FluentButton>
            <FluentButton Appearance="Appearance.Outline" Disabled="@_isSaving" OnClick="FetchPriceAsync">
                @if (_isFetchingPrice)
                {
                    <span>Fetching…</span>
                }
                else
                {
                    <span>Fetch price</span>
                }
            </FluentButton>
            @if (_security.LatestPrice is { } price)
            {
                <span style="align-self: center; color: var(--neutral-foreground-hint); font-size: 0.875rem;">
                    Latest: @price.ToString("N4") @_security.LatestPriceCurrency
                    (@(_security.LatestPriceAsOfDate?.ToString("yyyy-MM-dd") ?? "—"))
                </span>
            }
        </div>
    </fieldset>

    <fieldset style="border: 1px solid var(--neutral-stroke-rest); border-radius: 4px; padding: 1rem;">
        <legend style="font-weight: 600; padding: 0 0.5rem;">Aliases</legend>

        @if (_security.Aliases.Any())
        {
            <FluentDataGrid Items="@(_security.Aliases.OrderBy(a => a.Source).ThenBy(a => a.Symbol).AsQueryable())"
                            TGridItem="SecurityAliasResponse" Class="data-grid--elevated" Style="margin-bottom: 1rem;"
                            aria-label="@($"Aliases for {_security.DisplaySymbol}")">
                <TemplateColumn Title="Institution/Site">
                    @{
                        var sourceRow = GetAliasEditRow(context);
                    }
                    <FluentTextField @bind-Value="sourceRow.Source" style="width: 100%;" />
                </TemplateColumn>
                <TemplateColumn Title="Symbol">
                    @{
                        var symbolRow = GetAliasEditRow(context);
                    }
                    <FluentTextField @bind-Value="symbolRow.Symbol" style="width: 100%;" />
                </TemplateColumn>
                <TemplateColumn Title="Exchange">
                    @{
                        var exchRow = GetAliasEditRow(context);
                    }
                    <FluentTextField @bind-Value="exchRow.Exchange" style="width: 100%;" />
                </TemplateColumn>
                <TemplateColumn Title="Primary">
                    @{
                        var priRow = GetAliasEditRow(context);
                    }
                    <FluentCheckbox @bind-Value="priRow.IsPrimary" />
                </TemplateColumn>
                <TemplateColumn Title="Actions">
                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 4px;">
                        <FluentButton Appearance="Appearance.Stealth" Disabled="@_isSaving"
                                      OnClick="@(() => SaveAliasAsync(context.Id))">
                            Save
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" Disabled="@_isSaving"
                                      OnClick="@(() => DeleteAliasAsync(context.Id))">
                            Remove
                        </FluentButton>
                    </FluentStack>
                </TemplateColumn>
            </FluentDataGrid>
        }

        <h5 style="margin: 0 0 0.5rem 0; font-weight: 600;">Add alias</h5>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
            <FluentTextField @bind-Value="_draftSource" Label="Institution/Site" Placeholder="e.g. YahooFinance" />
            <FluentTextField @bind-Value="_draftSymbol" Label="Symbol" Placeholder="e.g. CASH.TO" />
            <FluentTextField @bind-Value="_draftExchange" Label="Exchange" Placeholder="e.g. XTSE" />
            <FluentCheckbox @bind-Value="_draftIsPrimary" Label="Primary" Style="align-self: end;" />
        </div>
        <div style="margin-top: 0.75rem;">
            <FluentButton Appearance="Appearance.Outline" Disabled="@_isSaving" OnClick="AddAliasAsync">
                Add alias
            </FluentButton>
        </div>
    </fieldset>

    <fieldset style="border: 1px solid var(--neutral-stroke-rest); border-radius: 4px; padding: 1rem;">
        <legend style="font-weight: 600; padding: 0 0.5rem;">Pricing provider order</legend>
        <p style="margin: 0 0 0.75rem 0; color: var(--neutral-foreground-hint); font-size: 0.875rem;">
            Providers are tried in order. Leave empty to use the global default (YahooFinance, MsnFinance).
        </p>

        @if (_pricingProviders.Count > 0)
        {
            <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 0.75rem;">
                @for (var i = 0; i < _pricingProviders.Count; i++)
                {
                    var idx = i;
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                        <span style="min-width: 1.5rem; text-align: center; font-weight: 600;">@(idx + 1).</span>
                        <FluentTextField Value="@_pricingProviders[idx]"                                         ValueChanged="@(v => _pricingProviders[idx] = v)"
                                         style="flex: 1;" />
                        <FluentButton Appearance="Appearance.Stealth" Disabled="@(idx == 0)"
                                      OnClick="@(() => MovePricingProvider(idx, -1))">↑</FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" Disabled="@(idx == _pricingProviders.Count - 1)"
                                      OnClick="@(() => MovePricingProvider(idx, 1))">↓</FluentButton>
                        <FluentButton Appearance="Appearance.Stealth"                                      OnClick="@(() => _pricingProviders.RemoveAt(idx))">×
                        </FluentButton>
                    </div>
                }
            </div>
        }

        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem;">
            <FluentTextField @bind-Value="_draftPricingProvider" Placeholder="e.g. YahooFinance" />
            <FluentButton Appearance="Appearance.Outline" Disabled="@(string.IsNullOrWhiteSpace(_draftPricingProvider))"
                          OnClick="AddPricingProvider">Add</FluentButton>
        </FluentStack>
        <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem;">
            <FluentButton Appearance="Appearance.Accent" Disabled="@_isSaving"                          OnClick="SavePricingOrderAsync">Save
                pricing order</FluentButton>
                <FluentButton Appearance="Appearance.Outline" Disabled="@_isSaving"                          OnClick="ClearPricingOrderAsync">Use
                    global default</FluentButton>
                </div>
            </fieldset>
        </FluentStack>

@code {
    [Parameter]
    public SecurityCatalogItemResponse Content { get; set; } = default!;

    [CascadingParameter]
    public FluentDialog Dialog { get; set; } = default!;

    private SecurityCatalogItemResponse _security = default!;
    private readonly Dictionary<Guid, AliasEditRow> _aliasEditRows = [];

    private string _displaySymbol = string.Empty;
    private string _name = string.Empty;
    private string _currency = "CAD";
    private string? _exchange;
    private bool _isCashEquivalent;

    private string _draftSymbol = string.Empty;
    private string _draftSource = string.Empty;
    private string? _draftExchange;
    private bool _draftIsPrimary;

    private bool _isSaving;
    private bool _isFetchingPrice;
    private string? _statusMessage;
    private bool _statusIsError;

    private List<string> _pricingProviders = [];
    private string _draftPricingProvider = string.Empty;

    protected override void OnParametersSet()
    {
        _security = Content;
        _displaySymbol = _security.DisplaySymbol;
        _name = _security.Name;
        _currency = _security.Currency;
        _exchange = _security.Exchange;
        _isCashEquivalent = _security.IsCashEquivalent;
        _pricingProviders = _security.PricingProviderOrder?.ToList() ?? [];
        SyncAliasEditRows();
    }

    private AliasEditRow GetAliasEditRow(SecurityAliasResponse alias)
    {
        if (_aliasEditRows.TryGetValue(alias.Id, out var row))
            return row;

        row = new AliasEditRow
        {
            Symbol = alias.Symbol,
            Source = alias.Source,
            Exchange = alias.Exchange,
            IsPrimary = alias.IsPrimary,
        };
        _aliasEditRows[alias.Id] = row;
        return row;
    }

    private async Task SaveSecurityAsync()
    {
        if (string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_displaySymbol) ||
string.IsNullOrWhiteSpace(_currency))
        {
            SetStatus("Name, display symbol, and currency are required.", true);
            return;
        }

        _isSaving = true;
        try
        {
            var updated = await SecurityService.UpdateSecurityAsync(
                _security.Id,
                new UpdateSecurityDetailsRequest
                {
                    Name = _name.Trim(),
                    DisplaySymbol = _displaySymbol.Trim(),
                    Currency = _currency.Trim(),
                    Exchange = EmptyToNull(_exchange),
                    IsCashEquivalent = _isCashEquivalent,
                }
            );

            if (updated is null)
            {
                SetStatus("Security update failed.", true);
                return;
            }

            _security = updated;
            SetStatus($"Updated security {updated.DisplaySymbol}.", false);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task AddAliasAsync()
    {
        if (string.IsNullOrWhiteSpace(_draftSymbol))
        {
            SetStatus("Alias symbol is required.", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(_draftSource))
        {
            SetStatus("Institution/Site is required.", true);
            return;
        }

        _isSaving = true;
        try
        {
            var created = await SecurityService.AddSecurityAliasAsync(
                _security.Id,
                new AddSecurityAliasRequest
                {
                    Symbol = _draftSymbol.Trim(),
                    Source = _draftSource.Trim(),
                    Exchange = EmptyToNull(_draftExchange),
                    IsPrimary = _draftIsPrimary,
                }
            );

            if (created is null)
            {
                SetStatus("Alias could not be saved.", true);
                return;
            }

            _draftSymbol = string.Empty;
            _draftSource = string.Empty;
            _draftExchange = null;
            _draftIsPrimary = false;

            await RefreshAsync();
            SetStatus("Alias saved.", false);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task FetchPriceAsync()
    {
        _isFetchingPrice = true;
        _isSaving = true;
        try
        {
            var updated = await SecurityService.FetchPriceAsync(_security.Id);
            if (updated is null)
            {
                SetStatus("Price fetch failed. Check provider configuration.", true);
                return;
            }

            _security = updated;
            SyncAliasEditRows();

            if (updated.LatestPrice is { } price)
            {
                SetStatus(
                    $"Fetched {price:N4} {updated.LatestPriceCurrency} ({updated.LatestPriceAsOfDate?.ToString("yyyy-MM-dd") ?? "—"}) from {updated.LatestPriceSource ?? "unknown"}.",
                    false
                );
            }
            else
            {
                SetStatus("No price returned from providers.", true);
            }
        }
        finally
        {
            _isFetchingPrice = false;
            _isSaving = false;
        }
    }

    private async Task SaveAliasAsync(Guid aliasId)
    {
        var row = _aliasEditRows.GetValueOrDefault(aliasId);
        if (row is null || string.IsNullOrWhiteSpace(row.Symbol))
        {
            SetStatus("Alias symbol is required.", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(row.Source))
        {
            SetStatus("Institution/Site is required.", true);
            return;
        }

        _isSaving = true;
        try
        {
            var updated = await SecurityService.UpdateSecurityAliasAsync(
                _security.Id,
                aliasId,
                new AddSecurityAliasRequest
                {
                    Symbol = row.Symbol.Trim(),
                    Source = row.Source.Trim(),
                    Exchange = EmptyToNull(row.Exchange),
                    IsPrimary = row.IsPrimary,
                }
            );

            if (updated is null)
            {
                SetStatus("Alias could not be updated.", true);
                return;
            }

            await RefreshAsync();
            SetStatus("Alias updated.", false);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteAliasAsync(Guid aliasId)
    {
        _isSaving = true;
        try
        {
            var deleted = await SecurityService.DeleteSecurityAliasAsync(_security.Id, aliasId);
            if (!deleted)
            {
                SetStatus("Alias could not be removed.", true);
                return;
            }

            await RefreshAsync();
            SetStatus("Alias removed.", false);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task RefreshAsync()
    {
        var all = await SecurityService.GetSecuritiesAsync();
        var updated = all.FirstOrDefault(s => s.Id == _security.Id);
        if (updated is not null)
        {
            _security = updated;
            SyncAliasEditRows();
        }
    }

    private void SyncAliasEditRows()
    {
        var currentIds = _security.Aliases.Select(a => a.Id).ToHashSet();
        var stale = _aliasEditRows.Keys.Where(k => !currentIds.Contains(k)).ToList();
        foreach (var id in stale) _aliasEditRows.Remove(id);

        foreach (var alias in _security.Aliases)
        {
            _aliasEditRows[alias.Id] = new AliasEditRow
            {
                Symbol = alias.Symbol,
                Source = alias.Source,
                Exchange = alias.Exchange,
                IsPrimary = alias.IsPrimary,
            };
        }
    }

    private void SetStatus(string message, bool isError)
    {
        _statusMessage = message;
        _statusIsError = isError;
    }

    private void AddPricingProvider()
    {
        if (!string.IsNullOrWhiteSpace(_draftPricingProvider))
        {
            _pricingProviders.Add(_draftPricingProvider.Trim());
            _draftPricingProvider = string.Empty;
        }
    }

    private void MovePricingProvider(int index, int direction)
    {
        var newIndex = index + direction;
        if (newIndex < 0 || newIndex >= _pricingProviders.Count) return;
        (_pricingProviders[index], _pricingProviders[newIndex]) = (_pricingProviders[newIndex], _pricingProviders[index]);
    }

    private async Task SavePricingOrderAsync()
    {
        _isSaving = true;
        try
        {
            var order = _pricingProviders.Count > 0 ? _pricingProviders : null;
            var updated = await SecurityService.SetPricingProviderOrderAsync(_security.Id, order);
            if (updated is null)
            {
                SetStatus("Failed to save pricing order.", true);
                return;
            }

            _security = updated;
            _pricingProviders = updated.PricingProviderOrder?.ToList() ?? [];
            SetStatus("Pricing provider order saved.", false);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ClearPricingOrderAsync()
    {
        _isSaving = true;
        try
        {
            var updated = await SecurityService.SetPricingProviderOrderAsync(_security.Id, null);
            if (updated is null)
            {
                SetStatus("Failed to clear pricing order.", true);
                return;
            }

            _security = updated;
            _pricingProviders = [];
            SetStatus("Using global default pricing order.", false);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private static string? EmptyToNull(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class AliasEditRow
    {
        public string Symbol { get; set; } = string.Empty;
        public string Source { get; set; } = string.Empty;
        public string? Exchange { get; set; }
        public bool IsPrimary { get; set; }
    }
}
