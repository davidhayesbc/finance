@inject ITransactionService TransactionService
@inject NavigationManager Navigation

<FluentCard Class="surface-card transaction-panel" aria-labelledby="recent-transactions-title" data-testid="account-transactions-panel">
    <div class="section-heading-row">
        <div>
            <h2 id="recent-transactions-title" class="section-heading">Transactions</h2>
            <p class="section-copy">All account transactions with search, filtering, and sortable columns so drilldown stays complete.</p>
            </div>
            <div class="summary-strip summary-strip--compact">
                <div>
                    <span class="summary-strip__label">Visible items</span>
                    <strong>@VisibleTransactions.Count</strong>
                </div>
                <div>
                    <span class="summary-strip__label">Range</span>
                    <strong>@GetRangeSummary()</strong>
                </div>
                <div>
                    <span class="summary-strip__label">Loaded</span>
                    <strong>@_transactions.Count</strong>
                </div>
            </div>
        </div>

        <form class="transaction-filters" @onsubmit="HandleFilterSubmitAsync" @onsubmit:preventDefault="true">
            <div class="transaction-filters__search">
                <label class="filter-label" for="transaction-search">Search</label>
                <input id="transaction-search" class="filter-input" type="search"
                       placeholder="Description, payee, category, or notes" @bind="_searchTerm" @bind:event="oninput" />
            </div>

            <div class="transaction-filters__dates">
                <div>
                    <label class="filter-label" for="from-date">From</label>
                    <input id="from-date" class="filter-input" type="date" value="@_fromDateInput"
                           @onchange="HandleFromDateChanged" />
                </div>
                <div>
                    <label class="filter-label" for="to-date">To</label>
                    <input id="to-date" class="filter-input" type="date" value="@_toDateInput"
                           @onchange="HandleToDateChanged" />
                </div>
            </div>

            <div class="transaction-filters__dates">
                <div>
                    <label class="filter-label" for="type-filter">Type</label>
                    <select id="type-filter" class="filter-input" value="@_selectedTypeFilter" @onchange="HandleTypeFilterChanged" data-testid="account-transactions-type-filter">
                        @foreach (var option in _typeFilterOptions)
                        {
                            <option value="@option.Key">@option.Label</option>
                        }
                    </select>
                </div>
            </div>

            <div class="transaction-filters__actions">
                <button type="submit" class="app-button app-button--primary">Apply</button>
                <button type="button" class="app-button app-button--secondary"                    @onclick="ResetFiltersAsync">Reset</button>
            </div>
        </form>

        <div class="filter-chip-row" role="group" aria-label="Date range presets">
            @foreach (var preset in _datePresets)
            {
                <button type="button"
                        class="filter-chip @(preset.Key == _selectedDatePreset ? "filter-chip--active" : string.Empty)"
                        @onclick='() => ApplyDatePresetAsync(preset.Key)'>
                    @preset.Label
                </button>
            }
        </div>

        @if (_isLoading)
        {
            <LoadingSpinner AriaLabel="Loading transactions" />
        }
        else if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <FluentMessageBar Intent="@MessageIntent.Warning">@_errorMessage</FluentMessageBar>
        }
        else if (_transactions.Count == 0)
        {
            <div class="empty-inline">
                <strong>No transactions match these filters.</strong>
                <span>Try a wider date range or clear the search term.</span>
            </div>
        }
        else if (VisibleTransactions.Count == 0)
        {
            <div class="empty-inline">
                <strong>No transactions match this type filter.</strong>
                <span>Choose a different transaction type or reset filters.</span>
            </div>
        }
        else
        {
            <div class="txn-table-wrapper" role="region" aria-label="Account transactions" data-testid="account-transactions-grid">
                <table class="txn-table" aria-label="Account transactions">
                    <thead>
                        <tr>
                            <th scope="col" class="txn-col--date">
                                <button type="button" class="txn-sort-button" @onclick='() => ToggleSort("date")' aria-label="Sort by date">
                                    Date @GetSortIndicator("date")
                                </button>
                            </th>
                            <th scope="col" class="txn-col--desc">
                                <button type="button" class="txn-sort-button" @onclick='() => ToggleSort("description")' aria-label="Sort by description">
                                    Description @GetSortIndicator("description")
                                </button>
                            </th>
                            <th scope="col" class="txn-col--cat">
                                <button type="button" class="txn-sort-button" @onclick='() => ToggleSort("category")' aria-label="Sort by category">
                                    Category @GetSortIndicator("category")
                                </button>
                            </th>
                            <th scope="col" class="txn-col--amount txn-cell--right">
                                <button type="button" class="txn-sort-button txn-sort-button--right" @onclick='() => ToggleSort("amount")' aria-label="Sort by amount">
                                    Amount @GetSortIndicator("amount")
                                </button>
                            </th>
                            <th scope="col" class="txn-col--balance txn-cell--right">
                                <button type="button" class="txn-sort-button txn-sort-button--right" @onclick='() => ToggleSort("balance")' aria-label="Sort by running balance">
                                    Balance @GetSortIndicator("balance")
                                </button>
                            </th>
                            <th scope="col" class="txn-col--action"><span class="sr-only">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var transaction in VisibleTransactions)
                        {
                            <tr class="txn-row" @key="transaction.Id">
                                <td class="txn-cell--date">@transaction.Date.ToString("MMM d, yyyy")</td>
                                <td class="txn-cell--desc">
                                    <span class="txn-desc-primary">@transaction.Description</span>
                                    @if (!string.IsNullOrWhiteSpace(transaction.PayeeName))
                                    {
                                        <span class="txn-desc-sub">@transaction.PayeeName</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(transaction.FromAccountName) || !string.IsNullOrWhiteSpace(transaction.ToAccountName))
                                    {
                                        <span class="txn-desc-sub">@BuildTransferRouteLabel(transaction)</span>
                                    }
                                    @if (transaction.IsReconciled)
                                    {
                                        <span class="txn-badge txn-badge--reconciled" title="Reconciled">R</span>
                                    }
                                    @if (transaction.IsSplit)
                                    {
                                        <span class="txn-badge" title="Split transaction">S</span>
                                    }
                                </td>
                                <td class="txn-cell--cat">
                                    @if (!string.IsNullOrWhiteSpace(transaction.CategoryName))
                                    {
                                        <span class="txn-category">@transaction.CategoryName</span>
                                    }
                                    else
                                    {
                                        <span class="txn-no-value">—</span>
                                    }
                                </td>
                                <td class="txn-cell--amount txn-cell--right @TransactionFormatHelper.GetAmountClass(transaction)">
                                    @TransactionFormatHelper.FormatAmount(transaction)
                                </td>
                                <td class="txn-cell--balance txn-cell--right">
                                    @transaction.RunningBalance.ToString("C") @transaction.Currency
                                </td>
                                <td class="txn-cell--action">
                                    <button type="button" class="app-button app-button--secondary app-button--xs"
                                            @onclick='() => Navigation.NavigateTo($"/transactions/{transaction.Id}")'>
                                        View
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </FluentCard>

@code {
    [Parameter, EditorRequired] public Guid AccountId { get; set; }

    private readonly List<TransactionResponse> _transactions = new();
    private readonly IReadOnlyList<DatePreset> _datePresets =
    [
        new("30d", "30D"),
        new("90d", "90D"),
        new("ytd", "YTD"),
        new("1y", "1Y"),
        new("all", "All")
    ];
    private readonly IReadOnlyList<TransactionTypeFilterOption> _typeFilterOptions =
    [
        new("all", "All types"),
        new("Credit", "Credit"),
        new("Debit", "Debit"),
        new("Transfer", "Transfer"),
        new("Other", "Other")
    ];

    private bool _isLoading = true;
    private string? _errorMessage;
    private string _searchTerm = string.Empty;
    private string _appliedSearchTerm = string.Empty;
    private string _selectedDatePreset = "90d";
    private string _selectedTypeFilter = "all";
    private string _sortColumn = "date";
    private bool _sortDescending = true;
    private string _fromDateInput = string.Empty;
    private string _toDateInput = string.Empty;

    private IReadOnlyList<TransactionResponse> VisibleTransactions => GetSortedTransactions()
        .Where(MatchesTypeFilter)
        .ToList();

    protected override async Task OnParametersSetAsync()
    {
        SetDatePreset("90d");
        await LoadTransactionsAsync(resetPaging: true);
    }

    private async Task HandleFilterSubmitAsync()
    {
        if (!TryParseDateInputs(out var fromDate, out var toDate))
        {
            _errorMessage = "Enter a valid date range before applying filters.";
            return;
        }

        _errorMessage = null;
        _appliedSearchTerm = _searchTerm.Trim();
        _selectedDatePreset = string.Empty;
        _fromDateInput = FormatDateInput(fromDate);
        _toDateInput = FormatDateInput(toDate);
        await LoadTransactionsAsync(resetPaging: true);
    }

    private async Task ApplyDatePresetAsync(string presetKey)
    {
        SetDatePreset(presetKey);
        await LoadTransactionsAsync(resetPaging: true);
    }

    private async Task ResetFiltersAsync()
    {
        _searchTerm = string.Empty;
        _appliedSearchTerm = string.Empty;
        _selectedTypeFilter = "all";
        SetDatePreset("90d");
        await LoadTransactionsAsync(resetPaging: true);
    }

    private void HandleFromDateChanged(ChangeEventArgs args)
    {
        _fromDateInput = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleToDateChanged(ChangeEventArgs args)
    {
        _toDateInput = args.Value?.ToString() ?? string.Empty;
    }

    private void HandleTypeFilterChanged(ChangeEventArgs args)
    {
        _selectedTypeFilter = args.Value?.ToString() ?? "all";
    }

    private void ToggleSort(string sortColumn)
    {
        if (string.Equals(_sortColumn, sortColumn, StringComparison.OrdinalIgnoreCase))
        {
            _sortDescending = !_sortDescending;
            return;
        }

        _sortColumn = sortColumn;
        _sortDescending = sortColumn switch
        {
            "date" => true,
            "amount" => true,
            "balance" => true,
            _ => false,
        };
    }

    private string GetSortIndicator(string sortColumn)
    {
        if (!string.Equals(_sortColumn, sortColumn, StringComparison.OrdinalIgnoreCase))
            return string.Empty;

        return _sortDescending ? "▼" : "▲";
    }

    private async Task LoadTransactionsAsync(bool resetPaging)
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var fromDate = ParseDateInput(_fromDateInput);
            var toDate = ParseDateInput(_toDateInput);
            _transactions.Clear();
            _transactions.AddRange(await LoadAllTransactionsAsync(fromDate, toDate));
        }
        catch
        {
            _transactions.Clear();
            _errorMessage = "Transactions could not be loaded right now.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task<IReadOnlyList<TransactionResponse>> LoadAllTransactionsAsync(DateTime? fromDate, DateTime? toDate)
    {
        const int pageSize = 100;
        const int maxPages = 200;

        var allTransactions = new List<TransactionResponse>();
        string? cursor = null;
        var pageCount = 0;

        do
        {
            var result = await TransactionService.GetTransactionsAsync(
                AccountId,
                pageSize: pageSize,
                cursor: cursor,
                fromDate: fromDate,
                toDate: toDate,
                searchTerm: _appliedSearchTerm
            );

            allTransactions.AddRange(result.Items);
            cursor = result.HasNextPage ? result.NextCursor : null;
            pageCount++;
        } while (!string.IsNullOrWhiteSpace(cursor) && pageCount < maxPages);

        return allTransactions;
    }

    private IEnumerable<TransactionResponse> GetSortedTransactions()
    {
        return (_sortColumn, _sortDescending) switch
        {
            ("description", true) => _transactions.OrderByDescending(t => t.Description, StringComparer.OrdinalIgnoreCase).ThenByDescending(t => t.Date),
            ("description", false) => _transactions.OrderBy(t => t.Description, StringComparer.OrdinalIgnoreCase).ThenByDescending(t => t.Date),
            ("category", true) => _transactions.OrderByDescending(t => t.CategoryName ?? string.Empty, StringComparer.OrdinalIgnoreCase).ThenByDescending(t => t.Date),
            ("category", false) => _transactions.OrderBy(t => t.CategoryName ?? string.Empty, StringComparer.OrdinalIgnoreCase).ThenByDescending(t => t.Date),
            ("amount", true) => _transactions.OrderByDescending(t => t.Amount).ThenByDescending(t => t.Date),
            ("amount", false) => _transactions.OrderBy(t => t.Amount).ThenByDescending(t => t.Date),
            ("balance", true) => _transactions.OrderByDescending(t => t.RunningBalance).ThenByDescending(t => t.Date),
            ("balance", false) => _transactions.OrderBy(t => t.RunningBalance).ThenByDescending(t => t.Date),
            ("date", false) => _transactions.OrderBy(t => t.Date),
            _ => _transactions.OrderByDescending(t => t.Date),
        };
    }

    private bool MatchesTypeFilter(TransactionResponse transaction)
    {
        if (string.Equals(_selectedTypeFilter, "all", StringComparison.OrdinalIgnoreCase))
            return true;

        return string.Equals(transaction.TransactionType, _selectedTypeFilter, StringComparison.OrdinalIgnoreCase);
    }

    private void SetDatePreset(string presetKey)
    {
        _selectedDatePreset = presetKey;
        var today = DateTime.Today;

        var range = presetKey switch
        {
            "30d" => ((DateTime?)today.AddDays(-30), (DateTime?)today),
            "90d" => ((DateTime?)today.AddDays(-90), (DateTime?)today),
            "ytd" => ((DateTime?)new DateTime(today.Year, 1, 1), (DateTime?)today),
            "1y" => ((DateTime?)today.AddYears(-1), (DateTime?)today),
            _ => ((DateTime?)null, (DateTime?)null),
        };

        var (fromDate, toDate) = range;
        _fromDateInput = FormatDateInput(fromDate);
        _toDateInput = FormatDateInput(toDate);
    }

    private bool TryParseDateInputs(out DateTime? fromDate, out DateTime? toDate)
    {
        fromDate = ParseDateInput(_fromDateInput);
        toDate = ParseDateInput(_toDateInput);

        if ((_fromDateInput.Length > 0 && !fromDate.HasValue) || (_toDateInput.Length > 0 && !toDate.HasValue))
            return false;

        if (fromDate.HasValue && toDate.HasValue && fromDate > toDate)
            return false;

        return true;
    }

    private static DateTime? ParseDateInput(string value) =>
        DateTime.TryParse(value, out var parsed) ? parsed : null;

    private static string FormatDateInput(DateTime? value) =>
        value.HasValue ? value.Value.ToString("yyyy-MM-dd") : string.Empty;

    private string GetRangeSummary()
    {
        var fromDate = ParseDateInput(_fromDateInput);
        var toDate = ParseDateInput(_toDateInput);

        return (fromDate, toDate) switch
        {
            (null, null) => "All time",
            (not null, null) => $"Since {fromDate.Value:MMM d}",
            (null, not null) => $"Until {toDate.Value:MMM d}",
            _ => $"{fromDate.Value:MMM d} to {toDate.Value:MMM d}",
        };
    }

    private static string BuildTransferRouteLabel(TransactionResponse transaction)
    {
        var from = string.IsNullOrWhiteSpace(transaction.FromAccountName)
            ? "Unknown"
            : transaction.FromAccountName;
        var to = string.IsNullOrWhiteSpace(transaction.ToAccountName)
            ? "Unknown"
            : transaction.ToAccountName;

        return $"Transfer: {from} -> {to}";
    }

    private sealed record DatePreset(string Key, string Label);

    private sealed record TransactionTypeFilterOption(string Key, string Label);
}
