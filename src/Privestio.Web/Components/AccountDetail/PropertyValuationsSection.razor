@inject IValuationService ValuationService
@using Privestio.Contracts.Requests

<FluentCard Class="surface-card transaction-panel" aria-labelledby="valuations-title">
    <div class="section-heading-row">
        <div>
            <h2 id="valuations-title" class="section-heading">Previous valuations</h2>
            <p class="section-copy">Historical valuations for this property, ordered by most recent first.</p>
        </div>
        <div style="display:flex;gap:0.75rem;align-items:center;">
            <div class="summary-strip summary-strip--compact">
                <div>
                    <span class="summary-strip__label">Total valuations</span>
                    <strong>@_valuations.Count</strong>
                </div>
            </div>
            <FluentButton Appearance="Appearance.Outline" @onclick="ToggleForm" aria-label="Record property valuation">
                Record Valuation
            </FluentButton>
        </div>
    </div>

    @if (_showForm)
    {
        <FluentCard Class="surface-card" style="margin-bottom:1rem;">
            <div class="section-heading-row">
                <div>
                    <h3 class="section-heading" style="margin-bottom:0.25rem;">Record valuation</h3>
                    <p class="section-copy">Capture the current estimated property value without affecting expense cash-flow
                        tracking.</p>
                    </div>
                </div>

                <FluentStack Orientation="Orientation.Vertical" Width="100%" style="gap:0.75rem;">
                    <FluentNumberField @bind-Value="_valuationAmount" Label="Estimated value" Step="0.01m" Required="true" />
                    <FluentDatePicker @bind-Value="_valuationEffectiveDate" Label="Effective date" />
                    <FluentTextField @bind-Value="_valuationSource" Label="Source"
                                     Placeholder="Appraisal, market estimate, assessment..." />
                    <FluentTextArea @bind-Value="_valuationNotes" Label="Notes (optional)" Resize="TextAreaResize.Vertical"
                                    Rows="3" />
                    <FluentStack Orientation="Orientation.Horizontal" style="gap:0.5rem;">
                        <FluentButton Appearance="Appearance.Accent" OnClick="SaveValuationAsync" Loading="_isSaving">
                            Save Valuation
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Outline" OnClick="ToggleForm">Cancel</FluentButton>
                    </FluentStack>
                </FluentStack>
            </FluentCard>
        }

        @if (!string.IsNullOrWhiteSpace(_saveMessage))
        {
            <FluentMessageBar Intent="@_saveIntent" style="margin-bottom:1rem;">@_saveMessage</FluentMessageBar>
        }

        @if (_isLoading)
        {
            <LoadingSpinner AriaLabel="Loading valuations" />
        }
        else if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <FluentMessageBar Intent="@MessageIntent.Warning">@_errorMessage</FluentMessageBar>
        }
        else if (_valuations.Count == 0)
        {
            <div class="empty-inline">
                <strong>No valuations recorded yet.</strong>
                <span>Add a valuation to track this property's value over time.</span>
            </div>
        }
        else
        {
            <div class="txn-table-wrapper" role="region" aria-label="Previous valuations">
                <table class="txn-table" aria-label="Previous valuations">
                    <thead>
                        <tr>
                            <th scope="col" class="txn-col--date">Date</th>
                            <th scope="col" class="txn-col--amount txn-cell--right">Value</th>
                            <th scope="col" class="txn-col--cat">Source</th>
                            <th scope="col" class="txn-col--desc">Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var valuation in _valuations)
                        {
                            <tr class="txn-row" @key="valuation.Id">
                                <td class="txn-cell--date">@valuation.EffectiveDate.ToString("MMM d, yyyy")</td>
                                <td class="txn-cell--amount txn-cell--right">
                                    @valuation.Amount.ToString("C") @valuation.Currency
                                </td>
                                <td class="txn-cell--cat">
                                    @if (!string.IsNullOrWhiteSpace(valuation.Source))
                                    {
                                        <span class="txn-category">@valuation.Source</span>
                                    }
                                    else
                                    {
                                        <span class="txn-no-value">—</span>
                                    }
                                </td>
                                <td class="txn-cell--desc">
                                    @if (!string.IsNullOrWhiteSpace(valuation.Notes))
                                    {
                                        <span>@valuation.Notes</span>
                                    }
                                    else
                                    {
                                        <span class="txn-no-value">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </FluentCard>

@code {
    [Parameter, EditorRequired] public Guid AccountId { get; set; }
    [Parameter] public string Currency { get; set; } = "CAD";
    [Parameter] public decimal DefaultAmount { get; set; }
    [Parameter] public EventCallback OnValuationSaved { get; set; }

    private readonly List<ValuationResponse> _valuations = new();
    private bool _isLoading = true;
    private string? _errorMessage;
    private bool _showForm;
    private bool _isSaving;
    private string? _saveMessage;
    private MessageIntent _saveIntent = MessageIntent.Success;
    private decimal _valuationAmount;
    private DateTime? _valuationEffectiveDate = DateTime.Today;
    private string _valuationSource = "Manual";
    private string _valuationNotes = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        await LoadValuationsAsync();
    }

    private async Task LoadValuationsAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var result = await ValuationService.GetValuationsAsync(AccountId);
            _valuations.Clear();
            _valuations.AddRange(result);
        }
        catch
        {
            _valuations.Clear();
            _errorMessage = "Valuations could not be loaded right now.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleForm()
    {
        _showForm = !_showForm;
        _saveMessage = null;

        if (_showForm)
        {
            _valuationAmount = DefaultAmount;
            _valuationEffectiveDate = DateTime.Today;
            _valuationSource = "Manual";
            _valuationNotes = string.Empty;
        }
    }

    private async Task SaveValuationAsync()
    {
        if (_valuationAmount <= 0 || string.IsNullOrWhiteSpace(_valuationSource))
        {
            _saveIntent = MessageIntent.Warning;
            _saveMessage = "Enter a valid amount and source.";
            return;
        }

        _isSaving = true;
        try
        {
            var request = new CreateValuationRequest
            {
                Amount = _valuationAmount,
                Currency = Currency,
                EffectiveDate = DateOnly.FromDateTime(_valuationEffectiveDate ?? DateTime.Today),
                Source = _valuationSource.Trim(),
                Notes = string.IsNullOrWhiteSpace(_valuationNotes) ? null : _valuationNotes.Trim(),
            };

            var created = await ValuationService.CreateValuationAsync(AccountId, request);
            if (created is null)
            {
                _saveIntent = MessageIntent.Error;
                _saveMessage = "Failed to save valuation.";
                return;
            }

            _saveIntent = MessageIntent.Success;
            _saveMessage = "Valuation saved.";
            _showForm = false;
            await LoadValuationsAsync();
            await OnValuationSaved.InvokeAsync();
        }
        finally
        {
            _isSaving = false;
        }
    }
}