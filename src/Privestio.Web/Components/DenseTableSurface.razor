<div class="@ComputedClass" aria-busy="@IsLoadingOrUpdating" @attributes="AdditionalAttributes">
    @if (IsLoading)
    {
        <LoadingSurface Variant="table" Rows="@LoadingRows" Columns="@LoadingColumns" />
    }
    else if (IsEmpty)
    {
        <div class="empty-inline dense-table-surface__empty">
            <strong>@EmptyTitle</strong>
            <span>@EmptyMessage</span>
        </div>
    }
    else
    {
        @ChildContent
    }

    @if (IsUpdating && !IsLoading)
    {
        <div class="surface-refresh-overlay" aria-hidden="true">
            <span>@UpdatingMessage</span>
        </div>
    }
</div>

@code {
    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public bool IsEmpty { get; set; }

    [Parameter]
    public int LoadingRows { get; set; } = 5;

    [Parameter]
    public int LoadingColumns { get; set; } = 6;

    [Parameter]
    public bool IsUpdating { get; set; }

    [Parameter]
    public string UpdatingMessage { get; set; } = "Updating surface...";

    [Parameter]
    public string EmptyTitle { get; set; } = "No rows available.";

    [Parameter]
    public string EmptyMessage { get; set; } = "Add data to populate this table.";

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsLoadingOrUpdating => IsLoading || IsUpdating;

    private string ComputedClass
    {
        get
        {
            var baseClass = string.IsNullOrWhiteSpace(Class)
                ? "dense-table-surface"
                : $"dense-table-surface {Class}";

            return IsUpdating && !IsLoading
                ? $"{baseClass} dense-table-surface--updating"
                : baseClass;
        }
    }
}
