@page "/reconciliation"
@inject IReconciliationService ReconciliationService
@inject IAccountService AccountService

<PageTitle>Reconciliation — Privestio</PageTitle>

<section class="page-shell">
    <PageHeader Eyebrow="Account Management" Title="Reconciliation"
                Description="Reconcile account balances against bank statements." />

    <FluentCard Class="surface-card" style="margin-bottom: 1.5rem;">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                     Style="gap: 1rem;">
            <FluentSelect TOption="string" @bind-Value="_selectedAccountIdStr" Label="Account"
                          Style="min-width: 250px;">
                <FluentOption TOption="string" Value="">Select an account...</FluentOption>
                @foreach (var account in _accounts)
                {
                    <FluentOption TOption="string" Value="@account.Id.ToString()">@account.Name</FluentOption>
                }
            </FluentSelect>
            <FluentButton Appearance="Appearance.Outline" OnClick="LoadPeriodsAsync" Style="align-self: flex-end;">
                Load
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="ShowCreateForm" Style="align-self: flex-end;"
                          Disabled="@(string.IsNullOrEmpty(_selectedAccountIdStr))">
                New Period
            </FluentButton>
        </FluentStack>
    </FluentCard>

    @if (_showForm)
    {
        <FluentCard Class="surface-card form-card" style="margin-bottom: 1.5rem;">
            <h3>New Reconciliation Period</h3>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <FluentMessageBar Intent="@MessageIntent.Error">
                    @_errorMessage
                </FluentMessageBar>
            }

            <EditForm Model="_form" OnValidSubmit="SavePeriodAsync" aria-label="Reconciliation form">
                <DataAnnotationsValidator />
                <FluentValidationSummary />

                <FluentStack Orientation="Orientation.Vertical" Width="100%" Class="form-stack">
                    <FluentDatePicker @bind-Value="_statementDate" Label="Statement date" Required="true" />

                    <FluentNumberField @bind-Value="_form.StatementBalanceAmount" Label="Statement balance" Step="0.01m"
                                       Required="true" />
                    <FluentValidationMessage For="@(() => _form.StatementBalanceAmount)" />

                    <CurrencySelect @bind-Value="_form.Currency" Label="Currency" />

                    <FluentTextArea @bind-Value="_form.Notes" Label="Notes" Rows="2" />

                    <FluentStack Orientation="Orientation.Horizontal" Class="form-actions">
                        <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Loading="_isSaving">
                            Create Period
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="CancelForm">Cancel</FluentButton>
                    </FluentStack>
                </FluentStack>
            </EditForm>
        </FluentCard>
    }

    @if (_isLoading)
    {
        <LoadingSpinner AriaLabel="Loading reconciliation" />
    }
    else if (string.IsNullOrEmpty(_selectedAccountIdStr))
    {
        <EmptyStateCard Message="Select an account to view reconciliation periods." />
    }
    else if (_periods.Count == 0)
    {
        <EmptyStateCard Message="No reconciliation periods for this account. Create one to start reconciling.">
            <Actions>
                <FluentButton Appearance="Appearance.Accent" OnClick="ShowCreateForm">New Period</FluentButton>
            </Actions>
        </EmptyStateCard>
    }
    else
    {
        <FluentCard Class="surface-card data-card">
            <h3 style="margin: 0 0 1rem 0;">Reconciliation Periods</h3>

            <FluentDataGrid Items="_periods.AsQueryable()" TGridItem="ReconciliationPeriodResponse"
                            Class="data-grid--elevated"
                            ResizableColumns="true"
                            ResizeType="DataGridResizeType.Discrete"
                            HeaderCellAsButtonWithMenu="true"
                            ResizeColumnOnAllRows="false"
                            ShowHover="true"
                            DisplayMode="DataGridDisplayMode.Table"
                            RowSize="DataGridRowSize.Medium">
                <TemplateColumn Title="Statement Date" Sortable="true"
                                SortBy="@(GridSort<ReconciliationPeriodResponse>.ByDescending(p => p.StatementDate))">
                    @context.StatementDate.ToString("MMM dd, yyyy")
                </TemplateColumn>
                <TemplateColumn Title="Statement Balance">
                    @context.StatementBalanceAmount.ToString("C") @context.Currency
                </TemplateColumn>
                <TemplateColumn Title="Status">
                    <FluentBadge Appearance="@(context.Status == "Locked" ? Appearance.Accent : Appearance.Neutral)"
                                 BackgroundColor="@(context.Status == "Locked" ? "#107c10" : null)"
                                 Color="@(context.Status == "Locked" ? "white" : null)">
                        @context.Status
                    </FluentBadge>
                </TemplateColumn>
                <TemplateColumn Title="Locked At">
                    @(context.LockedAt?.ToString("MMM dd, yyyy HH:mm") ?? "—")
                </TemplateColumn>
                <PropertyColumn Property="@(p => p.Notes)" Title="Notes" />
                <TemplateColumn Title="">
                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 4px;">
                        @if (context.Status != "Locked")
                        {
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => LockPeriodAsync(context.Id))">
                                Lock
                            </FluentButton>
                        }
                        else
                        {
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => UnlockPeriodAsync(context.Id))">
                                Unlock
                            </FluentButton>
                        }
                    </FluentStack>
                </TemplateColumn>
            </FluentDataGrid>
        </FluentCard>
    }
</section>

@code {
    private List<AccountResponse> _accounts = [];
    private List<ReconciliationPeriodResponse> _periods = [];
    private bool _isLoading;
    private bool _isSaving;
    private bool _showForm;
    private string? _errorMessage;
    private string _selectedAccountIdStr = string.Empty;
    private DateTime? _statementDate = DateTime.Today;

    private CreateReconciliationPeriodFormModel _form = new();

    protected override async Task OnInitializedAsync()
    {
        _accounts = (await AccountService.GetAccountsAsync()).ToList();
    }

    private async Task LoadPeriodsAsync()
    {
        if (string.IsNullOrEmpty(_selectedAccountIdStr) || !Guid.TryParse(_selectedAccountIdStr, out var accountId))
            return;

        _isLoading = true;
        _periods = (await ReconciliationService.GetByAccountIdAsync(accountId)).ToList();
        _isLoading = false;
    }

    private void ShowCreateForm()
    {
        _form = new CreateReconciliationPeriodFormModel
        {
            AccountId = _selectedAccountIdStr,
            Currency = "CAD"
        };
        _statementDate = DateTime.Today;
        _errorMessage = null;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _errorMessage = null;
    }

    private async Task SavePeriodAsync()
    {
        _isSaving = true;
        _errorMessage = null;

        var result = await ReconciliationService.CreateAsync(
            new CreateReconciliationPeriodRequest(
                Guid.Parse(_form.AccountId),
                DateOnly.FromDateTime(_statementDate ?? DateTime.Today),
                _form.StatementBalanceAmount,
                _form.Currency,
                _form.Notes
            )
        );

        if (result is null)
        {
            _errorMessage = "Failed to create reconciliation period.";
            _isSaving = false;
            return;
        }

        _isSaving = false;
        _showForm = false;
        await LoadPeriodsAsync();
    }

    private async Task LockPeriodAsync(Guid id)
    {
        await ReconciliationService.LockAsync(id);
        await LoadPeriodsAsync();
    }

    private async Task UnlockPeriodAsync(Guid id)
    {
        await ReconciliationService.UnlockAsync(id, new UnlockReconciliationPeriodRequest("Manual unlock from UI"));
        await LoadPeriodsAsync();
    }
}