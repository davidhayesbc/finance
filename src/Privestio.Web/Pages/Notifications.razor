@page "/notifications"
@inject INotificationWebService NotificationService
@inject NavigationManager Navigation

<PageTitle>Notifications — Privestio</PageTitle>

<section class="page-shell">
    <PageHeader Eyebrow="Notifications" Title="Alert center" Description="View financial alerts and notifications.">
        <Actions>
            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem;">
                <FluentButton Appearance="Appearance.Outline" OnClick="CheckAlertsAsync" Loading="_isChecking">
                    Check Alerts
                </FluentButton>
                @if (_notifications.Any(n => !n.IsRead))
                {
                    <FluentButton Appearance="Appearance.Outline" OnClick="MarkAllReadAsync">
                        Mark All Read
                    </FluentButton>
                }
            </FluentStack>
        </Actions>
    </PageHeader>

    <FluentCard Class="surface-card" style="margin-bottom: 1.5rem;">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                     Style="gap: 1rem;">
            <FluentCheckbox @bind-Value="_includeRead" Label="Show read notifications" />
            <FluentButton Appearance="Appearance.Stealth" OnClick="LoadDataAsync">Refresh</FluentButton>
        </FluentStack>
    </FluentCard>

    @if (_isLoading)
    {
        <LoadingSpinner AriaLabel="Loading notifications" />
    }
    else if (_notifications.Count == 0)
    {
        <EmptyStateCard
            Message="No notifications. Run 'Check Alerts' to scan for budget overages, low balances, and sinking fund issues.">
            <Actions>
                <FluentButton Appearance="Appearance.Accent" OnClick="CheckAlertsAsync" Loading="_isChecking">Check Alerts
                </FluentButton>
            </Actions>
        </EmptyStateCard>
    }
    else
    {
        <div class="summary-strip" style="margin-bottom: 1rem;">
            <div>
                <span class="summary-strip__label">Unread</span>
                <strong>@_notifications.Count(n => !n.IsRead)</strong>
            </div>
            <div>
                <span class="summary-strip__label">Total</span>
                <strong>@_notifications.Count</strong>
            </div>
        </div>

        @foreach (var notification in _notifications)
        {
            <FluentCard Class="surface-card"
                        Style="@($"margin-bottom: 0.75rem; opacity: {(notification.IsRead ? "0.7" : "1")}")">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Top" Style="gap: 1rem;">
                    <div style="flex: 1;">
                        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                                     Style="gap: 0.5rem; margin-bottom: 0.25rem;">
                            <FluentBadge Appearance="@GetSeverityAppearance(notification.Severity)"
                                         BackgroundColor="@GetSeverityColor(notification.Severity)"
                                         Color="@(notification.Severity == "Info" ? null : "white")">
                                @notification.Severity
                            </FluentBadge>
                            <FluentBadge Appearance="Appearance.Neutral">@notification.Type</FluentBadge>
                            @if (!notification.IsRead)
                            {
                                <FluentBadge Appearance="Appearance.Accent">New</FluentBadge>
                            }
                        </FluentStack>
                        <strong>@notification.Title</strong>
                        <p style="margin: 0.25rem 0 0 0; font-size: 0.9rem; color: var(--neutral-foreground-hint);">
                            @notification.Message</p>
                            <span style="font-size: 0.8rem; color: var(--neutral-foreground-hint);">@notification.CreatedAtUtc.ToLocalTime().ToString("g")</span>
                        </div>
                        @if (!notification.IsRead)
                        {
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => MarkReadAsync(notification.Id))">
                                Mark Read
                            </FluentButton>
                        }
                    </FluentStack>
                </FluentCard>
            }
        }
    </section>

@code {
    private List<NotificationResponse> _notifications = [];
    private bool _isLoading = true;
    private bool _isChecking;
    private bool _includeRead;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _notifications = (await NotificationService.GetNotificationsAsync(_includeRead)).ToList();
        _isLoading = false;
    }

    private async Task MarkReadAsync(Guid id)
    {
        await NotificationService.MarkAsReadAsync(id);
        await LoadDataAsync();
    }

    private async Task MarkAllReadAsync()
    {
        await NotificationService.MarkAllAsReadAsync();
        await LoadDataAsync();
    }

    private async Task CheckAlertsAsync()
    {
        _isChecking = true;
        var now = DateTime.Today;
        await NotificationService.CheckAlertsAsync(minimumBalance: 500, year: now.Year, month: now.Month);
        _isChecking = false;
        await LoadDataAsync();
    }

    private static Appearance GetSeverityAppearance(string severity) =>
        severity switch
        {
            "Warning" or "Critical" => Appearance.Accent,
            _ => Appearance.Neutral
        };

    private static string? GetSeverityColor(string severity) =>
        severity switch
        {
            "Critical" => "#c50f1f",
            "Warning" => "#d47d00",
            _ => null
        };
}