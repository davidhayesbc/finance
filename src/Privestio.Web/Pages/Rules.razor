@page "/rules"
@inject IRuleService RuleService
@inject NavigationManager Navigation

<PageTitle>Categorization Rules — Privestio</PageTitle>

<section class="page-shell panel-stack">
    <FluentBreadcrumb aria-label="Breadcrumb navigation">
        <FluentBreadcrumbItem Href="/accounts">Accounts</FluentBreadcrumbItem>
        <FluentBreadcrumbItem>Rules</FluentBreadcrumbItem>
    </FluentBreadcrumb>

    <PageHeader Eyebrow="Rules" Title="Categorization rules"
                Description="Keep rule priority, JSON conditions, and enablement in an interface that feels like an operations panel instead of raw scaffolding."
                Compact="true">
        <Actions>
            <FluentButton Appearance="Appearance.Accent" OnClick="ShowCreateForm" aria-label="Create new rule">
                New Rule
            </FluentButton>
        </Actions>
    </PageHeader>

    <MessageStack ErrorMessage="@_errorMessage" SuccessMessage="@_successMessage" />

    @if (_isLoading)
    {
        <LoadingSpinner AriaLabel="Loading rules" />
    }
    else if (!_showForm && _rules.Count == 0)
    {
        <EmptyStateCard
        Message="No categorization rules yet. Create your first rule to auto-categorize imported transactions." />
    }

    @if (_showForm)
    {
        <FluentCard Class="surface-card form-card" aria-label="@(_editingRuleId.HasValue ? "Edit rule" : "Create rule")">
            <h2 class="section-heading">@(_editingRuleId.HasValue ? "Edit rule" : "New rule")</h2>

            <FluentStack Orientation="Orientation.Vertical" Width="100%" Class="form-stack">
                <FluentTextField @bind-Value="_formName" Label="Rule Name" Placeholder="e.g., Loblaws to Groceries"
                                 Required="true" maxlength="200" />

                <FluentNumberField @bind-Value="_formPriority" Label="Priority (lower = higher priority)" Min="1" Max="9999"
                                   Step="1" />

                <FluentTextArea @bind-Value="_formConditions" Label="Conditions (JSON)"
                                Placeholder='e.g., {"field":"Description","operator":"Contains","value":"Loblaws"}' Rows="4"
                                Class="code-field" />

                <FluentTextArea @bind-Value="_formActions" Label="Actions (JSON)"
                                Placeholder='e.g., {"categoryId":"...","payeeId":"..."}' Rows="4" Class="code-field" />

                <FluentCheckbox @bind-Value="_formIsEnabled" Label="Enabled" />

                <FluentStack Orientation="Orientation.Horizontal" Class="form-actions">
                    <FluentButton Appearance="Appearance.Accent"
                                  Disabled="@(string.IsNullOrWhiteSpace(_formName) || _isSaving)" Loading="_isSaving"
                                  OnClick="SaveRuleAsync">
                        @(_editingRuleId.HasValue ? "Update Rule" : "Create Rule")
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="CancelForm">
                        Cancel
                    </FluentButton>
                </FluentStack>
            </FluentStack>
        </FluentCard>
    }

    @if (!_isLoading && _rules.Count > 0)
    {
        <FluentCard Class="surface-card data-card">
            <FluentDataGrid Items="_rules.OrderBy(r => r.Priority).ThenBy(r => r.Name).AsQueryable()"
                            aria-label="Categorization rules" TGridItem="CategorizationRuleResponse"
                            Class="data-grid--elevated data-grid--rules" ResizableColumns="true"
                            ResizeType="DataGridResizeType.Discrete" HeaderCellAsButtonWithMenu="true" ResizeColumnOnAllRows="false"
                            ShowHover="true" DisplayMode="DataGridDisplayMode.Table" RowSize="DataGridRowSize.Medium">
                <PropertyColumn Property="@(r => r.Priority)" Title="Priority" Sortable="true" Width="104px" />
                <TemplateColumn Title="Name" SortBy="@(GridSort<CategorizationRuleResponse>.ByAscending(r => r.Name))"
                                Width="280px">
                    <span class="cell-truncate"
                          title="@(string.IsNullOrWhiteSpace(context.Name) ? "Unnamed rule" : context.Name)">@context.Name</span>
                </TemplateColumn>
                <TemplateColumn Title="Status" Width="110px">
                    <FluentBadge Appearance="@(context.IsEnabled? Appearance.Accent: Appearance.Neutral)">
                        @(context.IsEnabled ? "Enabled" : "Disabled")
                    </FluentBadge>
                </TemplateColumn>
                <PropertyColumn Property="@(r => r.UpdatedAt)" Title="Updated" Format="g" Sortable="true" Width="180px" />
                <TemplateColumn Title="" Width="160px">
                    <FluentStack Orientation="Orientation.Horizontal" Class="grid-actions grid-actions--compact">
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => EditRule(context))"
                                      aria-label="@($"Edit rule {context.Name}")">
                            Edit
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => DeleteRuleAsync(context.Id))"
                                      aria-label="@($"Delete rule {context.Name}")">
                            Delete
                        </FluentButton>
                    </FluentStack>
                </TemplateColumn>
            </FluentDataGrid>
        </FluentCard>
    }
</section>

@code {
    private List<CategorizationRuleResponse> _rules = [];
    private bool _isLoading = true;
    private bool _showForm;
    private bool _isSaving;
    private string? _errorMessage;
    private string? _successMessage;

    // Form state
    private Guid? _editingRuleId;
    private string _formName = string.Empty;
    private int _formPriority = 100;
    private string _formConditions = string.Empty;
    private string _formActions = string.Empty;
    private bool _formIsEnabled = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadRulesAsync();
        _isLoading = false;
    }

    private async Task LoadRulesAsync()
    {
        _rules = (await RuleService.GetRulesAsync()).ToList();
    }

    private void ShowCreateForm()
    {
        _editingRuleId = null;
        _formName = string.Empty;
        _formPriority = (_rules.Count > 0 ? _rules.Max(r => r.Priority) : 0) + 10;
        _formConditions = string.Empty;
        _formActions = string.Empty;
        _formIsEnabled = true;
        _showForm = true;
        _errorMessage = null;
        _successMessage = null;
    }

    private void EditRule(CategorizationRuleResponse rule)
    {
        _editingRuleId = rule.Id;
        _formName = rule.Name;
        _formPriority = rule.Priority;
        _formConditions = rule.Conditions;
        _formActions = rule.Actions;
        _formIsEnabled = rule.IsEnabled;
        _showForm = true;
        _errorMessage = null;
        _successMessage = null;
    }

    private void CancelForm()
    {
        _showForm = false;
        _editingRuleId = null;
    }

    private async Task SaveRuleAsync()
    {
        _isSaving = true;
        _errorMessage = null;
        _successMessage = null;

        if (_editingRuleId.HasValue)
        {
            var request = new UpdateCategorizationRuleRequest
            {
                Name = _formName,
                Priority = _formPriority,
                Conditions = _formConditions,
                Actions = _formActions,
                IsEnabled = _formIsEnabled,
            };

            var result = await RuleService.UpdateRuleAsync(_editingRuleId.Value, request);
            if (result is null)
            {
                _errorMessage = "Failed to update rule.";
                _isSaving = false;
                return;
            }
            _successMessage = $"Rule \"{result.Name}\" updated.";
        }
        else
        {
            var request = new CreateCategorizationRuleRequest
            {
                Name = _formName,
                Priority = _formPriority,
                Conditions = _formConditions,
                Actions = _formActions,
                IsEnabled = _formIsEnabled,
            };

            var result = await RuleService.CreateRuleAsync(request);
            if (result is null)
            {
                _errorMessage = "Failed to create rule.";
                _isSaving = false;
                return;
            }
            _successMessage = $"Rule \"{result.Name}\" created.";
        }

        _showForm = false;
        _editingRuleId = null;
        await LoadRulesAsync();
        _isSaving = false;
    }

    private async Task DeleteRuleAsync(Guid id)
    {
        _errorMessage = null;
        _successMessage = null;

        var success = await RuleService.DeleteRuleAsync(id);
        if (success)
        {
            _successMessage = "Rule deleted.";
            await LoadRulesAsync();
        }
        else
        {
            _errorMessage = "Failed to delete rule.";
        }
    }
}
