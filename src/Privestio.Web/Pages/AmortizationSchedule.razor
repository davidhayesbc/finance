@page "/amortization"
@inject IAmortizationService AmortizationService
@inject IAccountService AccountService

<PageTitle>Amortization Schedule — Privestio</PageTitle>

<section class="page-shell">
    <PageHeader Eyebrow="Account Management" Title="Amortization schedule"
                Description="View and generate loan amortization schedules." />

    <FluentCard Class="surface-card" style="margin-bottom: 1.5rem;">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                     Style="gap: 1rem;">
            <FluentSelect TOption="string" @bind-Value="_selectedAccountIdStr" Label="Loan account"
                          Style="min-width: 250px;">
                <FluentOption TOption="string" Value="">Select a loan account...</FluentOption>
                @foreach (var account in _loanAccounts)
                {
                    <FluentOption TOption="string" Value="@account.Id.ToString()">@account.Name</FluentOption>
                }
            </FluentSelect>
            <FluentButton Appearance="Appearance.Outline" OnClick="LoadScheduleAsync" Style="align-self: flex-end;">
                Load
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="ShowGenerateForm" Style="align-self: flex-end;"
                          Disabled="@(string.IsNullOrEmpty(_selectedAccountIdStr))">
                Generate
            </FluentButton>
        </FluentStack>
    </FluentCard>

    @if (_showForm)
    {
        <FluentCard Class="surface-card form-card" style="margin-bottom: 1.5rem;">
            <h3>Generate Amortization Schedule</h3>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <FluentMessageBar Intent="@MessageIntent.Error">
                    @_errorMessage
                </FluentMessageBar>
            }

            <FluentStack Orientation="Orientation.Vertical" Width="100%" Class="form-stack">
                <FluentNumberField @bind-Value="_principal" Label="Principal amount" Step="0.01m" Required="true" />
                <FluentNumberField @bind-Value="_annualRate" Label="Annual interest rate (%)" Step="0.01m"
                                   Required="true" />
                <FluentNumberField @bind-Value="_termMonths" Label="Term (months)" Step="1" Required="true" />
                <FluentNumberField @bind-Value="_monthlyPayment" Label="Monthly payment" Step="0.01m" Required="true" />
                <FluentDatePicker @bind-Value="_startDate" Label="Start date" />

                <FluentSelect TOption="string" @bind-Value="_currency" Label="Currency">
                    <FluentOption TOption="string" Value="CAD">CAD — Canadian Dollar</FluentOption>
                    <FluentOption TOption="string" Value="USD">USD — US Dollar</FluentOption>
                </FluentSelect>

                <FluentStack Orientation="Orientation.Horizontal" Class="form-actions">
                    <FluentButton Appearance="Appearance.Accent" OnClick="GenerateScheduleAsync" Loading="_isSaving">
                        Generate Schedule
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="CancelForm">Cancel</FluentButton>
                </FluentStack>
            </FluentStack>
        </FluentCard>
    }

    @if (_isLoading)
    {
        <FluentProgressRing />
    }
    else if (_schedule is null && !string.IsNullOrEmpty(_selectedAccountIdStr))
    {
        <EmptyStateCard Message="No amortization schedule found. Generate one using the button above.">
            <Actions>
                <FluentButton Appearance="Appearance.Accent" OnClick="ShowGenerateForm">Generate</FluentButton>
            </Actions>
        </EmptyStateCard>
    }
    else if (_schedule is not null && _schedule.Entries.Count > 0)
    {
        <FluentCard Class="surface-card" style="margin-bottom: 1.5rem;">
            <div class="summary-strip">
                <div>
                    <span class="summary-strip__label">Total principal</span>
                    <strong>@_schedule.TotalPrincipal.ToString("C") @_schedule.Currency</strong>
                </div>
                <div>
                    <span class="summary-strip__label">Total interest</span>
                    <strong style="color: #c50f1f;">@_schedule.TotalInterest.ToString("C") @_schedule.Currency</strong>
                </div>
                <div>
                    <span class="summary-strip__label">Total cost</span>
                    <strong>@((_schedule.TotalPrincipal + _schedule.TotalInterest).ToString("C"))
                        @_schedule.Currency</strong>
                    </div>
                    <div>
                        <span class="summary-strip__label">Payments</span>
                        <strong>@_schedule.Entries.Count</strong>
                    </div>
                </div>
            </FluentCard>

            <FluentCard Class="surface-card data-card" style="margin-bottom: 1.5rem;">
                <h3 style="margin: 0 0 1rem 0;">Balance Over Time</h3>

                <ApexChart TItem="AmortizationEntryResponse"                       Title=""                       Height="350">
                    <ApexPointSeries TItem="AmortizationEntryResponse"                                 Items="_schedule.Entries.ToList()"
                                     SeriesType="SeriesType.Line"                                 Name="Remaining Balance"
                                     XValue="@(e => e.PaymentDate.ToString("MMM yyyy"))"
                                     YAggregate="@(items => items.Sum(i => i.RemainingBalance))" />
                </ApexChart>
            </FluentCard>

            <FluentCard Class="surface-card data-card">
                <h3 style="margin: 0 0 1rem 0;">Payment Schedule</h3>

                <FluentDataGrid Items="_schedule.Entries.AsQueryable()" TGridItem="AmortizationEntryResponse"
                                Class="data-grid--elevated">
                    <PropertyColumn Property="@(e => e.PaymentNumber)" Title="#" Sortable="true" />
                    <TemplateColumn Title="Date">
                        @context.PaymentDate.ToString("MMM dd, yyyy")
                    </TemplateColumn>
                    <TemplateColumn Title="Payment">
                        @context.PaymentAmount.ToString("C")
                    </TemplateColumn>
                    <TemplateColumn Title="Principal">
                        @context.PrincipalAmount.ToString("C")
                    </TemplateColumn>
                    <TemplateColumn Title="Interest">
                        <span style="color: #c50f1f;">@context.InterestAmount.ToString("C")</span>
                    </TemplateColumn>
                    <TemplateColumn Title="Remaining">
                        <strong>@context.RemainingBalance.ToString("C")</strong>
                    </TemplateColumn>
                </FluentDataGrid>
            </FluentCard>
        }
    else if (string.IsNullOrEmpty(_selectedAccountIdStr))
        {
            <EmptyStateCard Message="Select a loan account to view or generate an amortization schedule." />
        }
    </section>

@code {
    private List<AccountResponse> _accounts = [];
    private List<AccountResponse> _loanAccounts = [];
    private AmortizationScheduleResponse? _schedule;
    private bool _isLoading;
    private bool _isSaving;
    private bool _showForm;
    private string? _errorMessage;
    private string _selectedAccountIdStr = string.Empty;

    // Generate form fields
    private decimal _principal;
    private decimal _annualRate;
    private int _termMonths = 300;
    private decimal _monthlyPayment;
    private DateTime? _startDate = DateTime.Today;
    private string _currency = "CAD";

    protected override async Task OnInitializedAsync()
    {
        _accounts = (await AccountService.GetAccountsAsync()).ToList();
        _loanAccounts = _accounts
            .Where(a => a.AccountType.Equals("Loan", StringComparison.OrdinalIgnoreCase)
                     || a.AccountType.Equals("Liability", StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private async Task LoadScheduleAsync()
    {
        if (string.IsNullOrEmpty(_selectedAccountIdStr) || !Guid.TryParse(_selectedAccountIdStr, out var accountId))
            return;

        _isLoading = true;
        _schedule = await AmortizationService.GetScheduleAsync(accountId);
        _isLoading = false;
    }

    private void ShowGenerateForm()
    {
        _principal = 0;
        _annualRate = 0;
        _termMonths = 300;
        _monthlyPayment = 0;
        _startDate = DateTime.Today;
        _currency = "CAD";
        _errorMessage = null;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _errorMessage = null;
    }

    private async Task GenerateScheduleAsync()
    {
        if (string.IsNullOrEmpty(_selectedAccountIdStr) || !Guid.TryParse(_selectedAccountIdStr, out var accountId))
        {
            _errorMessage = "Please select an account first.";
            return;
        }

        _isSaving = true;
        _errorMessage = null;

        var result = await AmortizationService.GenerateAsync(
            new GenerateAmortizationRequest(
                accountId,
                _principal,
                _annualRate,
                _termMonths,
                _monthlyPayment,
                DateOnly.FromDateTime(_startDate ?? DateTime.Today),
                _currency
            )
        );

        if (result is null)
        {
            _errorMessage = "Failed to generate amortization schedule.";
            _isSaving = false;
            return;
        }

        _schedule = result;
        _isSaving = false;
        _showForm = false;
    }
}
