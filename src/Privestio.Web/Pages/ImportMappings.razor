@page "/import/mappings"
@inject IImportService ImportService
@inject IPluginCatalogWebService PluginCatalogService
@inject NavigationManager Navigation

<PageTitle>Saved Mappings — Privestio</PageTitle>

<section class="page-shell panel-stack">
    <FluentBreadcrumb aria-label="Breadcrumb navigation">
        <FluentBreadcrumbItem Href="/accounts">Accounts</FluentBreadcrumbItem>
        <FluentBreadcrumbItem Href="/import">Import</FluentBreadcrumbItem>
        <FluentBreadcrumbItem>Saved Mappings</FluentBreadcrumbItem>
    </FluentBreadcrumb>

    <PageHeader Eyebrow="Import" Title="Saved mappings"
                Description="Review reusable file mappings and remove obsolete templates before the next import run."
                Compact="true" />

    <MessageStack ErrorMessage="@_errorMessage" />

    @if (_isLoading)
    {
        <LoadingSpinner AriaLabel="Loading mappings" />
    }
    else if (_mappings.Count == 0)
    {
        <EmptyStateCard Message="No saved mappings yet. Create a mapping during the import process." />
    }
    else
    {
        <FluentCard Class="surface-card data-card">
            @if (_registeredFormats.Count == 0)
            {
                <FluentMessageBar Intent="@MessageIntent.Warning" style="margin-bottom: 0.75rem;">
                    No registered transaction-import plugins are available. Existing mappings may fail until a compatible
                    importer is registered.
                </FluentMessageBar>
            }

            <FluentDataGrid Items="_mappings.AsQueryable()" aria-label="Saved import mappings"
                            TGridItem="ImportMappingResponse" Class="data-grid--elevated">
                <PropertyColumn Property="@(m => m.Name)" Title="Name" />
                <PropertyColumn Property="@(m => m.FileFormat)" Title="Format" />
                <TemplateColumn Title="Registration">
                    <FluentBadge
                        Appearance="@(_registeredFormats.Contains(context.FileFormat) ? Appearance.Accent : Appearance.Neutral)">
                        @(_registeredFormats.Contains(context.FileFormat) ? "Registered" : "Unregistered")
                    </FluentBadge>
                </TemplateColumn>
                <PropertyColumn Property="@(m => m.Institution ?? "—")" Title="Institution" />
                <TemplateColumn Title="Mapped Columns">
                    <FluentBadge Appearance="Appearance.Neutral">
                        @context.ColumnMappings.Count columns
                    </FluentBadge>
                </TemplateColumn>
                <TemplateColumn Title="">
                    <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => DeleteMappingAsync(context.Id))"
                                  aria-label="@($"Delete mapping {context.Name}")">
                        Delete
                    </FluentButton>
                </TemplateColumn>
            </FluentDataGrid>
        </FluentCard>
    }
</section>

@code {
    private List<ImportMappingResponse> _mappings = [];
    private readonly HashSet<string> _registeredFormats = new(StringComparer.OrdinalIgnoreCase);
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var catalog = await PluginCatalogService.GetPluginCatalogAsync();
        foreach (var format in catalog?.TransactionImportFormats ?? [])
        {
            if (!string.IsNullOrWhiteSpace(format))
                _registeredFormats.Add(format.Trim());
        }

        _mappings = (await ImportService.GetMappingsAsync()).ToList();
        _isLoading = false;
    }

    private async Task DeleteMappingAsync(Guid id)
    {
        _errorMessage = null;
        var success = await ImportService.DeleteMappingAsync(id);
        if (success)
            _mappings = (await ImportService.GetMappingsAsync()).ToList();
        else
            _errorMessage = "Failed to delete mapping.";
    }
}
