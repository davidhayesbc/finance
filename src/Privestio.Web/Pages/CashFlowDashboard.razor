@page "/cash-flow"
@inject IAnalyticsService AnalyticsService

<PageTitle>Cash Flow — Privestio</PageTitle>

<section class="page-shell">
    <PageHeader Eyebrow="Analytics" Title="Cash flow dashboard"
                Description="Track income, expenses, and savings over time." />

    <FluentCard Class="surface-card" style="margin-bottom: 1.5rem;">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                     Style="gap: 1rem;">
            <FluentDatePicker @bind-Value="_startDate" Label="Start date" />
            <FluentDatePicker @bind-Value="_endDate" Label="End date" />
            <FluentButton Appearance="Appearance.Outline" OnClick="LoadDataAsync" Style="align-self: flex-end;">
                Refresh
            </FluentButton>
        </FluentStack>
    </FluentCard>

    @if (_isLoading)
    {
        <LoadingSpinner AriaLabel="Loading cash flow" />
    }
    else if (_cashFlow is null)
    {
        <EmptyStateCard Message="No cash flow data available for the selected period." />
    }
    else
    {
        <div class="summary-strip" style="margin-bottom: 1.5rem;">
            <FluentCard Class="surface-card">
                <span class="summary-strip__label">Total Income</span>
                <strong style="color: #107c10;">@_cashFlow.TotalIncome.ToString("C") @_cashFlow.Currency</strong>
            </FluentCard>
            <FluentCard Class="surface-card">
                <span class="summary-strip__label">Total Expenses</span>
                <strong style="color: #c50f1f;">@_cashFlow.TotalExpenses.ToString("C") @_cashFlow.Currency</strong>
            </FluentCard>
            <FluentCard Class="surface-card">
                <span class="summary-strip__label">Net Savings</span>
                <strong>@_cashFlow.NetSavings.ToString("C") @_cashFlow.Currency</strong>
            </FluentCard>
            <FluentCard Class="surface-card">
                <span class="summary-strip__label">Savings Rate</span>
                <strong>@_cashFlow.SavingsRate.ToString("F1")%</strong>
                <FluentProgress Value="@((int)Math.Max(0, Math.Min(_cashFlow.SavingsRate, 100)))" Min="0" Max="100" />
            </FluentCard>
        </div>

        @if (_cashFlow.MonthlyBreakdown.Count > 0)
        {
            <FluentCard Class="surface-card data-card" style="margin-bottom: 1.5rem;">
                <h3 style="margin: 0 0 1rem 0;">Income vs Expenses</h3>

                <ApexChart TItem="MonthlyBreakdownItem" Title="" Height="350">
                    <ApexPointSeries TItem="MonthlyBreakdownItem" Items="_cashFlow.MonthlyBreakdown.ToList()"
                                     SeriesType="SeriesType.Bar" Name="Income"
                                     XValue="@(item => new DateTime(item.Year, item.Month, 1).ToString("MMM yyyy"))"
                                     YAggregate="@(items => items.Sum(i => i.Income))" />
                    <ApexPointSeries TItem="MonthlyBreakdownItem" Items="_cashFlow.MonthlyBreakdown.ToList()"
                                     SeriesType="SeriesType.Bar" Name="Expenses"
                                     XValue="@(item => new DateTime(item.Year, item.Month, 1).ToString("MMM yyyy"))"
                                     YAggregate="@(items => items.Sum(i => i.Expenses))" />
                </ApexChart>
            </FluentCard>

            <FluentCard Class="surface-card data-card">
                <h3 style="margin: 0 0 1rem 0;">Monthly Breakdown</h3>

                <FluentDataGrid Items="_cashFlow.MonthlyBreakdown.AsQueryable()" TGridItem="MonthlyBreakdownItem"
                                Class="data-grid--elevated"
                                ResizableColumns="true"
                                ResizeType="DataGridResizeType.Discrete"
                                HeaderCellAsButtonWithMenu="true"
                                ResizeColumnOnAllRows="false"
                                ShowHover="true"
                                DisplayMode="DataGridDisplayMode.Table"
                                RowSize="DataGridRowSize.Medium">
                    <TemplateColumn Title="Period">
                        @(new DateTime(context.Year, context.Month, 1).ToString("MMM yyyy"))
                    </TemplateColumn>
                    <TemplateColumn Title="Income" Sortable="true"
                                    SortBy="@(GridSort<MonthlyBreakdownItem>.ByAscending(m => m.Income))">
                        <span style="color: #107c10;">@context.Income.ToString("C")</span>
                    </TemplateColumn>
                    <TemplateColumn Title="Expenses" Sortable="true"
                                    SortBy="@(GridSort<MonthlyBreakdownItem>.ByAscending(m => m.Expenses))">
                        <span style="color: #c50f1f;">@context.Expenses.ToString("C")</span>
                    </TemplateColumn>
                    <TemplateColumn Title="Net">
                        <FluentBadge Appearance="@(context.Net >= 0 ? Appearance.Accent : Appearance.Neutral)"
                                     BackgroundColor="@(context.Net < 0 ? "#c50f1f" : null)" Color="@(context.Net < 0 ? "white" : null)">
                            @context.Net.ToString("C")
                        </FluentBadge>
                    </TemplateColumn>
                </FluentDataGrid>
            </FluentCard>
        }
    }
</section>

@code {
    private CashFlowSummaryResponse? _cashFlow;
    private bool _isLoading = true;
    private DateTime? _startDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(-5);
    private DateTime? _endDate = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        var start = DateOnly.FromDateTime(_startDate ?? DateTime.Today.AddMonths(-5));
        var end = DateOnly.FromDateTime(_endDate ?? DateTime.Today);
        _cashFlow = await AnalyticsService.GetCashFlowSummaryAsync(start, end);
        _isLoading = false;
    }
}