@page "/securities"
@inject ISecurityWebService SecurityService
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

<PageTitle>Securities - Privestio</PageTitle>

<section class="page-shell">
    <PageHeader Eyebrow="Reference data" Title="Securities"
                Description="View and manage securities, pricing, and aliases." />

    @if (_isLoading)
    {
        <LoadingSpinner AriaLabel="Loading securities" />
    }
    else if (_securities.Count == 0)
    {
        <EmptyStateCard Message="No securities are linked to your accounts yet." />
    }
    else
    {
        <FluentCard Class="surface-card">
            <div class="table-surface table-surface--grid table-surface--scroll securities-grid-wrap">
                <FluentDataGrid Items="_securities.AsQueryable()" TGridItem="SecurityCatalogItemResponse"
                                Class="data-grid--elevated data-grid--securities data-grid--dense" aria-label="Securities" ResizableColumns="true"
                                Style="min-width: 1220px; width: max-content;"
                                ResizeType="DataGridResizeType.Discrete" HeaderCellAsButtonWithMenu="true" ResizeColumnOnAllRows="false"
                                ShowHover="true" DisplayMode="DataGridDisplayMode.Table" RowSize="DataGridRowSize.Small">
                <TemplateColumn Title="Symbol" SortBy="@(GridSort<SecurityCatalogItemResponse>.ByAscending(s => s.DisplaySymbol))"
                                Width="88px">
                    <span class="cell-truncate"
                          @oncontextmenu="@(args => OpenContextMenu(args, context))"
                          @oncontextmenu:preventDefault="true">@context.DisplaySymbol</span>
                </TemplateColumn>
                <TemplateColumn Title="Name" SortBy="@(GridSort<SecurityCatalogItemResponse>.ByAscending(s => s.Name))"
                                Width="220px">
                    <span class="cell-truncate"
                          title="@(string.IsNullOrWhiteSpace(context.Name) ? "Unnamed security" : context.Name)"
                          @oncontextmenu="@(args => OpenContextMenu(args, context))"
                          @oncontextmenu:preventDefault="true">@context.Name</span>
                </TemplateColumn>
                <TemplateColumn Title="Exchange" SortBy="@(GridSort<SecurityCatalogItemResponse>.ByAscending(s => s.Exchange ?? string.Empty))"
                                Width="108px">
                    <span @oncontextmenu="@(args => OpenContextMenu(args, context))"
                          @oncontextmenu:preventDefault="true">@DisplayOrDash(context.Exchange)</span>
                </TemplateColumn>
                <TemplateColumn Title="Currency" SortBy="@(GridSort<SecurityCatalogItemResponse>.ByAscending(s => s.Currency ?? string.Empty))"
                                Width="88px">
                    <span @oncontextmenu="@(args => OpenContextMenu(args, context))"
                          @oncontextmenu:preventDefault="true">@DisplayOrDash(context.Currency)</span>
                </TemplateColumn>
                <TemplateColumn Title="Cash" Width="72px">
                    <span @oncontextmenu="@(args => OpenContextMenu(args, context))"
                          @oncontextmenu:preventDefault="true">
                        @if (context.IsCashEquivalent)
                        {
                            <FluentBadge Appearance="Appearance.Accent">Yes</FluentBadge>
                        }
                    </span>
                </TemplateColumn>
                <TemplateColumn Title="Price source"
                                SortBy="@(GridSort<SecurityCatalogItemResponse>.ByAscending(s => s.LatestPriceSource ?? string.Empty))"
                                Width="184px">
                    @if (context.LatestPriceAsOfDate is { } asOfDate)
                    {
                        <span class="cell-truncate"
                              title="@($"{(string.IsNullOrWhiteSpace(context.LatestPriceSource) ? "No source" : context.LatestPriceSource)} ({asOfDate:yyyy-MM-dd})")"
                              @oncontextmenu="@(args => OpenContextMenu(args, context))"
                              @oncontextmenu:preventDefault="true">@DisplayOrDash(context.LatestPriceSource)
                            (@asOfDate.ToString("yyyy-MM-dd"))</span>
                        }
                    else
                        {
                            <span class="txn-no-value"
                                  @oncontextmenu="@(args => OpenContextMenu(args, context))"
                                  @oncontextmenu:preventDefault="true">—</span>
                        }
                    </TemplateColumn>
                    <TemplateColumn Title="Latest price"
                                    SortBy="@(GridSort<SecurityCatalogItemResponse>.ByDescending(s => s.LatestPrice ?? decimal.MinValue))"
                                    Width="132px">
                        @if (context.LatestPrice is { } latestPrice)
                        {
                            <span @oncontextmenu="@(args => OpenContextMenu(args, context))"
                                  @oncontextmenu:preventDefault="true">@latestPrice.ToString("N4") @DisplayOrDash(context.LatestPriceCurrency)</span>
                        }
                        else
                        {
                            <span class="txn-no-value"
                                  @oncontextmenu="@(args => OpenContextMenu(args, context))"
                                  @oncontextmenu:preventDefault="true">—</span>
                        }
                    </TemplateColumn>
                </FluentDataGrid>
            </div>
            <p class="securities-context-hint">Right-click any cell in a row to open actions.</p>
            </FluentCard>

        @if (_isContextMenuOpen)
        {
            <div class="securities-context-backdrop" @onclick="CloseContextMenu"></div>
            <div class="securities-context-menu" style="@ContextMenuStyle">
                <div class="securities-context-menu__title">@(_contextMenuSecurity?.DisplaySymbol ?? "Security")</div>
                <button type="button" class="securities-context-menu__action"
                        disabled="@(_contextMenuSecurity is null || _fetchingPriceFor == _contextMenuSecurity.Id)"
                        @onclick="FetchPriceFromMenuAsync">
                    @if (_contextMenuSecurity is not null && _fetchingPriceFor == _contextMenuSecurity.Id)
                    {
                        <span>Fetching…</span>
                    }
                    else
                    {
                        <span>Fetch price</span>
                    }
                </button>
                <button type="button" class="securities-context-menu__action"
                        disabled="@(_contextMenuSecurity is null || _fetchingHistoricalPricesFor == _contextMenuSecurity.Id)"
                        @onclick="FetchHistoricalPricesFromMenuAsync">
                    @if (_contextMenuSecurity is not null && _fetchingHistoricalPricesFor == _contextMenuSecurity.Id)
                    {
                        <span>Fetching…</span>
                    }
                    else
                    {
                        <span>Fetch historical prices</span>
                    }
                </button>
                <button type="button" class="securities-context-menu__action" disabled="@(_contextMenuSecurity is null)"
                        @onclick="OpenEditFromMenuAsync">Edit</button>
                <button type="button" class="securities-context-menu__action" disabled="@(_contextMenuSecurity is null)"
                        @onclick="OpenPriceHistoryFromMenuAsync">Price history</button>
            </div>
        }
        }
    </section>

@code {
    private readonly List<SecurityCatalogItemResponse> _securities = [];

    private bool _isLoading = true;
    private Guid? _fetchingPriceFor;
    private Guid? _fetchingHistoricalPricesFor;
    private bool _isContextMenuOpen;
    private SecurityCatalogItemResponse? _contextMenuSecurity;
    private double _contextMenuX;
    private double _contextMenuY;

    private string ContextMenuStyle => $"left: {_contextMenuX}px; top: {_contextMenuY}px;";

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _isLoading = true;

        var results = await SecurityService.GetSecuritiesAsync();
        _securities.Clear();
        _securities.AddRange(results.OrderBy(s => s.DisplaySymbol, StringComparer.OrdinalIgnoreCase));

        _isLoading = false;
    }

    private async Task FetchPriceAsync(SecurityCatalogItemResponse security)
    {
        _fetchingPriceFor = security.Id;
        try
        {
            var updated = await SecurityService.FetchPriceAsync(security.Id);
            if (updated is not null)
            {
                var index = _securities.FindIndex(s => s.Id == security.Id);
                if (index >= 0)
                    _securities[index] = updated;
            }
        }
        finally
        {
            _fetchingPriceFor = null;
        }
    }

    private async Task FetchHistoricalPricesAsync(SecurityCatalogItemResponse security)
    {
        _fetchingHistoricalPricesFor = security.Id;
        try
        {
            await SecurityService.FetchHistoricalPricesAsync(security.Id);
        }
        finally
        {
            _fetchingHistoricalPricesFor = null;
        }
    }

    private async Task OpenEditDialogAsync(SecurityCatalogItemResponse security)
    {
        var dialog = await DialogService.ShowDialogAsync<SecurityEditDialog>(security, new DialogParameters
        {
            Title = $"Edit {security.DisplaySymbol}",
            Width = "720px",
            PrimaryAction = null,
            SecondaryAction = "Close",
            PreventDismissOnOverlayClick = true,
        });

        var result = await dialog.Result;

        // Always reload after dialog closes — edits are saved inline
        await ReloadAsync();
        StateHasChanged();
    }

    private async Task OpenPriceHistoryDialogAsync(SecurityCatalogItemResponse security)
    {
        var dialog = await DialogService.ShowDialogAsync<PriceHistoryDialog>(security, new DialogParameters
        {
            Title = $"Price history — {security.DisplaySymbol}",
            Width = "900px",
            PrimaryAction = null,
            SecondaryAction = "Close",
            PreventDismissOnOverlayClick = true,
        });

        await dialog.Result;

        // Reload so Latest Price column reflects any manual changes
        await ReloadAsync();
        StateHasChanged();
    }

    private static string DisplayOrDash(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private async Task OpenContextMenu(MouseEventArgs args, SecurityCatalogItemResponse security)
    {
        _contextMenuSecurity = security;

        var menuX = args.ClientX;
        var menuY = args.ClientY;

        try
        {
            var point = await JSRuntime.InvokeAsync<ContextMenuPoint?>("uiState.getLastContextMenuPoint");
            if (point is { X: > 0, Y: > 0 })
            {
                menuX = point.X;
                menuY = point.Y;
            }
        }
        catch
        {
            // Fall back to Blazor event coordinates when JS interop is unavailable.
        }

        _contextMenuX = Math.Max(8, menuX - 4);
        _contextMenuY = Math.Max(8, menuY - 4);
        _isContextMenuOpen = true;
    }

    private void CloseContextMenu()
    {
        _isContextMenuOpen = false;
    }

    private async Task FetchPriceFromMenuAsync()
    {
        if (_contextMenuSecurity is null)
            return;

        var security = _contextMenuSecurity;
        CloseContextMenu();
        await FetchPriceAsync(security);
    }

    private async Task FetchHistoricalPricesFromMenuAsync()
    {
        if (_contextMenuSecurity is null)
            return;

        var security = _contextMenuSecurity;
        CloseContextMenu();
        await FetchHistoricalPricesAsync(security);
    }

    private async Task OpenEditFromMenuAsync()
    {
        if (_contextMenuSecurity is null)
            return;

        var security = _contextMenuSecurity;
        CloseContextMenu();
        await OpenEditDialogAsync(security);
    }

    private async Task OpenPriceHistoryFromMenuAsync()
    {
        if (_contextMenuSecurity is null)
            return;

        var security = _contextMenuSecurity;
        CloseContextMenu();
        await OpenPriceHistoryDialogAsync(security);
    }

    private sealed class ContextMenuPoint
    {
        public double X { get; init; }
        public double Y { get; init; }
    }
}
