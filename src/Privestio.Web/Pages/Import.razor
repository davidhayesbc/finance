@page "/import"
@inject IImportService ImportService
@inject IAccountService AccountService
@inject ICategoryService CategoryService
@inject IPluginCatalogWebService PluginCatalogService
@inject NavigationManager Navigation

@using Microsoft.AspNetCore.Components

<PageTitle>Import Transactions — Privestio</PageTitle>

<section class="page-shell import-shell" data-testid="import-page">
    <PageRegion Name="orientation" Class="import-orientation">
        <PageHeader Eyebrow="Import" Title="Import"
                    Description="Upload, map, preview, and commit transaction files with full visibility before write."
                    UtilityDescription="Keep the workbench centered while supporting context and exceptions stay anchored around it."
                    Compact="true">
            <Actions>
                <div class="action-cluster">
                    <FluentButton Appearance="Appearance.Outline"
                                  OnClick="@(() => Navigation.NavigateTo("/import/mappings"))">
                        Saved Mappings
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Outline"
                                  OnClick="@(() => Navigation.NavigateTo("/import/history"))">
                        Import History
                    </FluentButton>
                </div>
            </Actions>
        </PageHeader>

        <MessageStack ErrorMessage="@_errorMessage" SuccessMessage="@_successMessage" />
    </PageRegion>

    <div class="import-workbench">
        <PageRegion Name="supporting" TagName="aside" Class="import-step-rail" aria-labelledby="import-step-rail-title">
            <div class="import-section-heading">
                <h2 id="import-step-rail-title">Step rail</h2>
                <p>Keep upload, mapping, preview, and commit visible at all times.</p>
            </div>

            <ol class="import-step-rail__list">
                @foreach (var step in ImportSteps)
                {
                    <li class="@GetStepClass(step.Step)">
                        <span class="import-step-rail__index">@step.Index</span>
                        <div>
                            <strong>@step.Label</strong>
                            <p>@step.Description</p>
                        </div>
                    </li>
                }
            </ol>
        </PageRegion>

        <PageRegion Name="primary" Class="import-workspace" aria-labelledby="import-workspace-title">
            @if (_step == ImportStep.Upload)
            {
                <section class="import-stage">
                    <div class="import-section-heading import-section-heading--split">
                        <div>
                            <h2 id="import-workspace-title">Source file</h2>
                            <p>Choose the target account, attach one file, and inspect the detected format before anything writes.</p>
                        </div>
                        <span class="import-stage__eyebrow">Step 1 · Upload</span>
                    </div>

                    <div class="import-stage__body">
                        <AccountSelect Accounts="_accounts" @bind-Value="_selectedAccountIdStr" Required="true" />

                        <FluentInputFile @ref="_fileInput" Mode="InputFileMode.Stream" Accept=".csv,.ofx,.qfx,.qif"
                                         MaximumFileCount="1" MaximumFileSize="@(10 * 1024 * 1024)" Label="Select file to import"
                                         OnFileUploaded="HandleFileSelectedAsync" aria-label="Choose a file to import" />

                        @if (_selectedFile is not null)
                        {
                            <FluentBadge Appearance="Appearance.Neutral">@_selectedFileName</FluentBadge>
                        }

                        <div class="action-cluster">
                            <FluentButton Appearance="Appearance.Accent"
                                          Disabled="@(_selectedAccountId is null || _selectedFile is null || _isLoading)"
                                          Loading="_isLoading"
                                          OnClick="PreviewFileAsync">
                                Preview Import
                            </FluentButton>
                        </div>
                    </div>
                </section>
            }

            @if (_step == ImportStep.ColumnMapping && _filePreview is not null)
            {
                <section class="import-stage">
                    <div class="import-section-heading import-section-heading--split">
                        <div>
                            <h2 id="import-workspace-title">Column mapping</h2>
                            <p>@_filePreview.TotalRows rows detected. Confirm required fields and inspect sample rows before preview.</p>
                        </div>
                        <span class="import-stage__eyebrow">Step 2 · Mapping</span>
                    </div>

                    <div class="mapping-grid">
                        @foreach (var column in _filePreview.DetectedColumns)
                        {
                            <div class="mapping-row">
                                <FluentLabel Class="mapping-row__label">@column</FluentLabel>
                                <FluentSelect TOption="string" Value="@GetMappingValue(column)"
                                              ValueChanged="@(value => SetMappingValue(column, value))">
                                    <FluentOption TOption="string" Value="">Skip</FluentOption>
                                    <FluentOption TOption="string" Value="Date">Date</FluentOption>
                                    <FluentOption TOption="string" Value="Amount">Amount</FluentOption>
                                    <FluentOption TOption="string" Value="Description">Description</FluentOption>
                                    <FluentOption TOption="string" Value="Payee">Payee</FluentOption>
                                    <FluentOption TOption="string" Value="Category">Category</FluentOption>
                                    <FluentOption TOption="string" Value="Notes">Notes</FluentOption>
                                    <FluentOption TOption="string" Value="ExternalId">External ID</FluentOption>
                                    <FluentOption TOption="string" Value="SettlementDate">Settlement date</FluentOption>
                                    <FluentOption TOption="string" Value="ActivityType">Activity type</FluentOption>
                                    <FluentOption TOption="string" Value="ActivitySubType">Activity sub-type</FluentOption>
                                    <FluentOption TOption="string" Value="Direction">Direction</FluentOption>
                                    <FluentOption TOption="string" Value="Symbol">Symbol</FluentOption>
                                    <FluentOption TOption="string" Value="SecurityName">Security name</FluentOption>
                                    <FluentOption TOption="string" Value="Quantity">Quantity</FluentOption>
                                    <FluentOption TOption="string" Value="UnitPrice">Unit price</FluentOption>
                                    <FluentOption TOption="string" Value="Exchange">Exchange</FluentOption>
                                    <FluentOption TOption="string" Value="Cusip">CUSIP</FluentOption>
                                    <FluentOption TOption="string" Value="Isin">ISIN</FluentOption>
                                </FluentSelect>
                            </div>
                        }
                    </div>

                    <section class="import-stage__panel">
                        <h3 class="section-heading">Sample rows</h3>
                        <FluentDataGrid Items="_sampleRows.AsQueryable()" aria-label="File preview data" TGridItem="SampleRow"
                                        Class="data-grid--elevated table-surface table-surface--grid data-grid--import-preview" ResizableColumns="true"
                                        ResizeType="DataGridResizeType.Discrete" HeaderCellAsButtonWithMenu="true" ResizeColumnOnAllRows="false"
                                        ShowHover="true" DisplayMode="DataGridDisplayMode.Table" RowSize="DataGridRowSize.Medium">
                            @foreach (var (columnName, index) in _filePreview.DetectedColumns.Select((value, idx) => (value, idx)))
                            {
                                var columnIndex = index;
                                <TemplateColumn Title="@columnName"
                                                SortBy="@(GridSort<SampleRow>.ByAscending(row => row.Values.Count > columnIndex ? row.Values[columnIndex] : string.Empty))"
                                                Width="200px">
                                    @{
                                        var cell = context.Values.Count > columnIndex ? context.Values[columnIndex] : string.Empty;
                                    }
                                    <span class="cell-truncate" title="@(string.IsNullOrWhiteSpace(cell) ? "Empty value" : cell)">@cell</span>
                                </TemplateColumn>
                            }
                        </FluentDataGrid>
                    </section>

                    <details class="import-advanced-panel">
                        <summary>Advanced settings</summary>
                        <FluentStack Orientation="Orientation.Vertical" Width="100%" Class="form-stack" style="margin-top:0.75rem">
                            <FluentTextField Label="Buy keywords (comma-separated)" @bind-Value="_buyKeywords" style="width:100%" Placeholder="buy, purchase, long, ..." />
                            <FluentTextField Label="Sell keywords (comma-separated)" @bind-Value="_sellKeywords" style="width:100%" Placeholder="sell, redeem, withdraw, ..." />
                            <FluentTextField Label="Income keywords (comma-separated)" @bind-Value="_incomeKeywords" style="width:100%" Placeholder="interest, dividend, distribution, ..." />
                            <FluentTextField Label="Cash-equivalent symbol prefixes (comma-separated)" @bind-Value="_cashEquivalentSymbols" style="width:100%" Placeholder="CASH, PSA, CSAV, ..." />
                            <FluentTextField Label="Ignore row patterns — skip rows whose Date cell starts with (comma-separated)" @bind-Value="_ignoreRowPatterns" style="width:100%" Placeholder="As of , TOTAL:, ..." />
                            <FluentCheckbox Label="Invert amount sign (institution exports debits as positive)" @bind-Value="_amountSignFlipped" />
                        </FluentStack>
                    </details>

                    <div class="action-cluster">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@(!HasRequiredMappings() || _isLoading)" Loading="_isLoading" OnClick="RunPreviewImportAsync">
                            Preview Results
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Outline" OnClick="SaveMappingAsync">
                            Save Mapping
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => _step = ImportStep.Upload)">
                            Back
                        </FluentButton>
                    </div>
                </section>
            }

            @if (_step == ImportStep.Preview && _previewResult is not null)
            {
                <section class="import-stage">
                    <div class="import-section-heading import-section-heading--split">
                        <div>
                            <h2 id="import-workspace-title">Preview results</h2>
                            <p>Inspect import counts, duplicates, and row-level failures before committing anything.</p>
                        </div>
                        <span class="import-stage__eyebrow">Step 3 · Preview</span>
                    </div>

                    <div class="detail-grid">
                        <StatCard Label="Total rows">@_previewResult.TotalRows</StatCard>
                        <StatCard Label="Will import">@_previewResult.ImportedCount</StatCard>
                        <StatCard Label="Duplicates">@_previewResult.DuplicateCount</StatCard>
                        <StatCard Label="Errors">@_previewResult.ErrorCount</StatCard>
                    </div>

                    @if (_previewResult.Errors.Count > 0)
                    {
                        <section class="import-stage__panel">
                            <h3 class="section-heading">Errors</h3>
                            <FluentDataGrid Items="_previewResult.Errors.OrderBy(error => error.RowNumber).AsQueryable()"
                                            aria-label="Import errors" TGridItem="ImportErrorDetail"
                                            Class="data-grid--elevated table-surface table-surface--grid data-grid--import-errors" ResizableColumns="true"
                                            ResizeType="DataGridResizeType.Discrete" HeaderCellAsButtonWithMenu="true" ResizeColumnOnAllRows="false"
                                            ShowHover="true" DisplayMode="DataGridDisplayMode.Table" RowSize="DataGridRowSize.Medium">
                                <PropertyColumn Property="@(error => error.RowNumber)" Title="Row" Sortable="true" Width="88px" />
                                <TemplateColumn Title="Error" SortBy="@(GridSort<ImportErrorDetail>.ByAscending(error => error.Message))" Width="320px">
                                    <span class="cell-truncate" title="@(string.IsNullOrWhiteSpace(context.Message) ? "No error message" : context.Message)">@context.Message</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Raw Data" SortBy="@(GridSort<ImportErrorDetail>.ByAscending(error => error.RawData ?? string.Empty))" Width="420px">
                                    <span class="cell-truncate cell-truncate--mono" title="@(string.IsNullOrWhiteSpace(context.RawData) ? "No raw data" : context.RawData)">@(context.RawData ?? string.Empty)</span>
                                </TemplateColumn>
                            </FluentDataGrid>
                        </section>
                    }

                    <section class="import-stage__panel">
                        <div class="import-section-heading import-section-heading--split">
                            <div>
                                <h3 class="section-heading">AI rule suggestions</h3>
                                <p>Use local Ollama to suggest reusable rules. Suggestions do not categorize transactions until you accept one.</p>
                            </div>
                            <FluentButton Appearance="Appearance.Outline"
                                          Disabled="@(_isSuggesting || _isLoading || _selectedFile is null || _selectedAccountId is null)"
                                          Loading="_isSuggesting"
                                          OnClick="SuggestRulesAsync">
                                Suggest Rules (AI)
                            </FluentButton>
                        </div>

                        @if (_ruleSuggestions.Count == 0)
                        {
                            <p class="field-hint">No suggestions yet. Generate suggestions after previewing your import file.</p>
                        }
                        else
                        {
                            <FluentDataGrid Items="_ruleSuggestions.AsQueryable()" aria-label="AI rule suggestions" TGridItem="RuleSuggestionResponse"
                                            Class="data-grid--elevated table-surface table-surface--grid" ResizableColumns="true"
                                            ResizeType="DataGridResizeType.Discrete" HeaderCellAsButtonWithMenu="true" ResizeColumnOnAllRows="false"
                                            ShowHover="true" DisplayMode="DataGridDisplayMode.Table" RowSize="DataGridRowSize.Medium">
                                <TemplateColumn Title="Suggestion" SortBy="@(GridSort<RuleSuggestionResponse>.ByAscending(r => r.Name))" Width="260px">
                                    <span class="cell-truncate" title="@context.Name">@context.Name</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Suggested Category" SortBy="@(GridSort<RuleSuggestionResponse>.ByAscending(r => r.SuggestedCategoryName))" Width="200px">
                                    <span class="cell-truncate" title="@context.SuggestedCategoryName">@context.SuggestedCategoryName</span>
                                </TemplateColumn>
                                <PropertyColumn Property="@(r => r.MatchCount)" Title="Matches" Width="90px" />
                                <PropertyColumn Property="@(r => r.MatchRate)" Title="Match Rate" Format="P1" Width="110px" />
                                <TemplateColumn Title="Rule Conditions" Width="360px">
                                    <span class="cell-truncate cell-truncate--mono" title="@context.Conditions">@context.Conditions</span>
                                </TemplateColumn>
                                <TemplateColumn Title="Accept" Width="320px">
                                    <FluentStack Orientation="Orientation.Horizontal" Class="grid-actions grid-actions--compact">
                                        <FluentSelect TOption="string"
                                                      Value="@GetSelectedCategoryId(context)"
                                                      ValueChanged="@(value => SetSelectedCategoryId(context, value))"
                                                      Width="200px"
                                                      AriaLabel="Select category for accepted rule">
                                            <FluentOption TOption="string" Value="">Select category</FluentOption>
                                            @foreach (var category in _categories.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase))
                                            {
                                                <FluentOption TOption="string" Value="@category.Id.ToString()">@category.Name</FluentOption>
                                            }
                                        </FluentSelect>
                                        <FluentSelect TOption="string"
                                                      Value="@GetSelectedApplyScope(context)"
                                                      ValueChanged="@(value => SetSelectedApplyScope(context, value))"
                                                      Width="220px"
                                                      AriaLabel="Select apply scope for accepted rule">
                                            <FluentOption TOption="string" Value="AllMatching">All matching transactions</FluentOption>
                                            <FluentOption TOption="string" Value="UncategorizedOnly">Uncategorized only</FluentOption>
                                        </FluentSelect>
                                        <FluentButton Appearance="Appearance.Accent"
                                                      Disabled="@(_isAccepting || !CanAcceptSuggestion(context))"
                                                      Loading="_isAccepting"
                                                      OnClick="@(() => AcceptSuggestionAsync(context))">
                                            Accept
                                        </FluentButton>
                                    </FluentStack>
                                </TemplateColumn>
                            </FluentDataGrid>
                        }
                    </section>

                    <div class="action-cluster">
                        <FluentButton Appearance="Appearance.Accent" Disabled="@(_previewResult.ImportedCount == 0 || _isLoading)" Loading="_isLoading" OnClick="CommitImportAsync">
                            Commit Import (@_previewResult.ImportedCount transactions)
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => _step = ImportStep.ColumnMapping)">
                            Back to Mapping
                        </FluentButton>
                    </div>
                </section>
            }

            @if (_step == ImportStep.Complete && _importResult is not null)
            {
                <section class="import-stage">
                    <div class="import-section-heading import-section-heading--split">
                        <div>
                            <h2 id="import-workspace-title">Commit</h2>
                            <p>Review the result summary and move directly to the next useful action.</p>
                        </div>
                        <span class="import-stage__eyebrow">Step 4 · Complete</span>
                    </div>

                    <div class="detail-grid">
                        <StatCard Label="Imported">@_importResult.ImportedCount</StatCard>
                        <StatCard Label="Duplicates skipped">@_importResult.DuplicateCount</StatCard>
                        <StatCard Label="Errors">@_importResult.ErrorCount</StatCard>
                        <StatCard Label="Status">@_importResult.Status</StatCard>
                    </div>

                    <div class="action-cluster">
                        <FluentButton Appearance="Appearance.Accent" OnClick='@(() => Navigation.NavigateTo($"/accounts/{_selectedAccountId}"))'>
                            View Account
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Outline" OnClick="ResetImport">
                            Import Another File
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => Navigation.NavigateTo("/import/history"))">
                            Import History
                        </FluentButton>
                    </div>
                </section>
            }
        </PageRegion>

        <PageRegion Name="supporting" TagName="aside" Class="import-inspector" aria-labelledby="import-inspector-title">
            <InspectorPanel Title="Workflow context"
                            TitleId="import-inspector-title"
                            Description="Keep account, mapping, plugin, and commit context visible without crowding the central bench."
                            Class="import-inspector__panel"
                            BodyClass="import-inspector__stack">
                <article class="import-inspector__item">
                    <span>Selected account</span>
                    <strong>@SelectedAccountLabel</strong>
                    <p>@SelectedAccountDetail</p>
                </article>
                <article class="import-inspector__item">
                    <span>Detected format</span>
                    <strong>@DetectedFormatLabel</strong>
                    <p>@RegisteredFormatsLabel</p>
                </article>
                <article class="import-inspector__item">
                    <span>Mapping health</span>
                    <strong>@MappingHealthTitle</strong>
                    <p>@MappingHealthDetail</p>
                </article>
                <article class="import-inspector__item">
                    <span>Commit impact</span>
                    <strong>@CommitImpactTitle</strong>
                    <p>@CommitImpactDetail</p>
                </article>
            </InspectorPanel>
        </PageRegion>
    </div>

    <PageRegion Name="exceptions" Class="import-exceptions" aria-labelledby="import-exceptions-title">
        <SectionBand Title="Errors and exceptions"
                     TitleId="import-exceptions-title"
                     Description="Make unsupported formats, missing mappings, and row failures legible and actionable."
                     HeaderClass="import-section-heading">

        <div class="import-exceptions__list">
            @foreach (var item in WorkflowExceptions)
            {
                <OperationalExceptionRow Title="@item.Title"
                                         Detail="@item.Detail"
                                         Severity="@ToSeverity(item.Tone)" />
            }
        </div>
        </SectionBand>
    </PageRegion>
</section>

@code {
    private enum ImportStep
    {
        Upload,
        ColumnMapping,
        Preview,
        Complete,
    }

    private static readonly IReadOnlyList<ImportStepDescriptor> ImportSteps =
    [
        new(1, ImportStep.Upload, "Upload", "Select the account, attach the file, and detect the format."),
        new(2, ImportStep.ColumnMapping, "Mapping", "Confirm required fields, sample rows, and advanced settings."),
        new(3, ImportStep.Preview, "Preview", "Inspect duplicates, errors, and the exact write impact."),
        new(4, ImportStep.Complete, "Commit", "Confirm the result and move to the next useful action."),
    ];

    [Parameter]
    [SupplyParameterFromQuery(Name = "accountId")]
    public Guid? PreselectedAccountId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "focus")]
    public string? FocusArea { get; set; }

    private ImportStep _step = ImportStep.Upload;
    private List<AccountResponse> _accounts = [];
    private string? _selectedAccountIdStr;
    private Guid? _selectedAccountId => Guid.TryParse(_selectedAccountIdStr, out var id) ? id : null;
    private FluentInputFile? _fileInput;
    private MemoryStream? _selectedFile;
    private string? _selectedFileName;
    private FilePreviewResponse? _filePreview;
    private ImportResultResponse? _previewResult;
    private ImportResultResponse? _importResult;
    private Dictionary<string, string> _columnMappings = new();
    private readonly Dictionary<string, string> _selectedCategoryBySuggestion =
        new(StringComparer.Ordinal);
    private readonly Dictionary<string, string> _selectedApplyScopeBySuggestion =
        new(StringComparer.Ordinal);
    private Guid? _activeMappingId;
    private List<SampleRow> _sampleRows = [];
    private List<CategoryResponse> _categories = [];
    private List<RuleSuggestionResponse> _ruleSuggestions = [];
    private string? _errorMessage;
    private string? _successMessage;
    private bool _isLoading;
    private bool _isSuggesting;
    private bool _isAccepting;
    private readonly HashSet<string> _registeredImportFormats = new(StringComparer.OrdinalIgnoreCase);
    private string _buyKeywords = "buy, purchase, contribution, reinvest, deposit, in, long";
    private string _sellKeywords = "sell, redeem, withdraw, out";
    private string _incomeKeywords = "interest, dividend, distribution";
    private string _cashEquivalentSymbols = "CASH";
    private string _ignoreRowPatterns = string.Empty;
    private bool _amountSignFlipped;

    private AccountResponse? SelectedAccount =>
        _selectedAccountId is null
            ? null
            : _accounts.FirstOrDefault(account => account.Id == _selectedAccountId.Value);

    private string SelectedAccountLabel => SelectedAccount?.Name ?? "No account selected";

    private string SelectedAccountDetail =>
        SelectedAccount is null
            ? "Pick a destination account before previewing the file."
            : $"{SelectedAccount.AccountType} · {FormatInstitution(SelectedAccount)}";

    private string DetectedFormatLabel => _filePreview?.FileFormat ?? (_selectedFile is null ? "No file attached" : "Scanning pending");

    private string RegisteredFormatsLabel =>
        _registeredImportFormats.Count == 0
            ? "No registered import plugins are available."
            : $"Registered formats: {string.Join(", ", _registeredImportFormats.OrderBy(format => format, StringComparer.OrdinalIgnoreCase))}";

    private string MappingHealthTitle => _step switch
    {
        ImportStep.Upload => "Waiting for preview",
        ImportStep.ColumnMapping when HasRequiredMappings() => "Required fields mapped",
        ImportStep.ColumnMapping => "Required mappings missing",
        ImportStep.Preview => "Preview mapping locked",
        ImportStep.Complete => "Committed with saved mapping",
        _ => "Pending",
    };

    private string MappingHealthDetail => _filePreview is null
        ? "Date, Amount, and Description are still waiting for source columns."
        : $"{_columnMappings.Count} of {_filePreview.DetectedColumns.Count} detected columns are assigned.";

    private string CommitImpactTitle => _previewResult is null ? "No preview yet" : $"{_previewResult.ImportedCount} rows ready";

    private string CommitImpactDetail => _previewResult is null
        ? "Run preview to see duplicates, errors, and write volume before commit."
        : $"{_previewResult.DuplicateCount} duplicates and {_previewResult.ErrorCount} errors in the current pass.";

    private List<WorkflowExceptionItem> WorkflowExceptions => BuildWorkflowExceptions();

    protected override async Task OnInitializedAsync()
    {
        _accounts = (await AccountService.GetAccountsAsync()).ToList();
        _categories = (await CategoryService.GetCategoriesAsync()).ToList();
        ApplyPreselectedAccount();

        if (
            string.Equals(FocusArea, "ai", StringComparison.OrdinalIgnoreCase)
            && _selectedAccountId is not null
        )
        {
            _successMessage =
                "Account selected from AI rules workspace. Upload a sample file, preview it, then generate AI suggestions.";
        }

        var catalog = await PluginCatalogService.GetPluginCatalogAsync();
        foreach (var format in catalog?.TransactionImportFormats ?? [])
        {
            if (!string.IsNullOrWhiteSpace(format))
            {
                _registeredImportFormats.Add(format.Trim());
            }
        }
    }

    protected override Task OnParametersSetAsync()
    {
        ApplyPreselectedAccount();
        return Task.CompletedTask;
    }

    private async Task HandleFileSelectedAsync(FluentInputFileEventArgs args)
    {
        _errorMessage = null;
        if (args.Stream is null)
        {
            return;
        }

        _selectedFile = new MemoryStream();
        await args.Stream.CopyToAsync(_selectedFile);
        _selectedFile.Position = 0;
        _selectedFileName = args.Name;
    }

    private async Task PreviewFileAsync()
    {
        if (_selectedAccountId is null || _selectedFile is null)
        {
            return;
        }

        _isLoading = true;
        _errorMessage = null;

        _selectedFile.Position = 0;
        _filePreview = await ImportService.PreviewFileAsync(_selectedFile, _selectedFileName!);

        if (_filePreview is null)
        {
            _errorMessage = "Failed to preview file. Ensure it is a valid CSV, OFX, QFX, or QIF file.";
            _isLoading = false;
            return;
        }

        if (!IsDetectedFormatRegistered())
        {
            _errorMessage = $"Detected format '{_filePreview.FileFormat}' is not provided by a registered transaction importer plugin.";
            _isLoading = false;
            return;
        }

        _sampleRows = _filePreview.SampleRows.Select(row => new SampleRow { Values = row.ToList() }).ToList();
        _activeMappingId = null;
        _columnMappings.Clear();

        foreach (var column in _filePreview.DetectedColumns)
        {
            var lower = column.ToLowerInvariant();
            if (lower.Contains("date"))
            {
                _columnMappings[column] = "Date";
            }
            else if (lower.Contains("amount") || lower.Contains("total"))
            {
                _columnMappings[column] = "Amount";
            }
            else if (lower.Contains("desc") || lower.Contains("memo") || lower.Contains("narrative"))
            {
                _columnMappings[column] = "Description";
            }
            else if (lower.Contains("payee"))
            {
                _columnMappings[column] = "Payee";
            }
            else if (lower.Contains("category") || lower.Contains("cat"))
            {
                _columnMappings[column] = "Category";
            }
            else if (lower.Contains("note") || lower.Contains("comment"))
            {
                _columnMappings[column] = "Notes";
            }
            else if (lower.Contains("ref") || lower.Contains("id") || lower.Contains("check"))
            {
                _columnMappings[column] = "ExternalId";
            }
            else if (lower.Contains("settlement"))
            {
                _columnMappings[column] = "SettlementDate";
            }
            else if (lower.Contains("activity") && lower.Contains("sub"))
            {
                _columnMappings[column] = "ActivitySubType";
            }
            else if (lower.Contains("activity"))
            {
                _columnMappings[column] = "ActivityType";
            }
            else if (lower.Contains("direction") || lower.Contains("side"))
            {
                _columnMappings[column] = "Direction";
            }
            else if (lower == "symbol" || lower.Contains("ticker"))
            {
                _columnMappings[column] = "Symbol";
            }
            else if (lower.Contains("security"))
            {
                _columnMappings[column] = "SecurityName";
            }
            else if (lower.Contains("quantity") || lower.Contains("shares") || lower == "qty")
            {
                _columnMappings[column] = "Quantity";
            }
            else if (lower.Contains("unit price") || lower.Contains("price") || lower.Contains("rate"))
            {
                _columnMappings[column] = "UnitPrice";
            }
            else if (lower.Contains("exchange") || lower == "exch" || lower == "market")
            {
                _columnMappings[column] = "Exchange";
            }
            else if (lower.Contains("cusip"))
            {
                _columnMappings[column] = "Cusip";
            }
            else if (lower.Contains("isin"))
            {
                _columnMappings[column] = "Isin";
            }
        }

        _step = ImportStep.ColumnMapping;
        _isLoading = false;
    }

    private string GetMappingValue(string column) =>
        _columnMappings.TryGetValue(column, out var value) ? value : string.Empty;

    private void SetMappingValue(string column, string? value)
    {
        _activeMappingId = null;
        if (string.IsNullOrEmpty(value))
        {
            _columnMappings.Remove(column);
        }
        else
        {
            _columnMappings[column] = value;
        }
    }

    private async Task<Guid?> EnsureActiveMappingAsync()
    {
        if (_activeMappingId.HasValue)
        {
            return _activeMappingId;
        }

        if (_filePreview is null || !IsDetectedFormatRegistered())
        {
            return null;
        }

        var request = new CreateImportMappingRequest
        {
            Name = $"Auto mapping {_selectedFileName} {DateTime.UtcNow:yyyyMMddHHmmss}",
            FileFormat = _filePreview.FileFormat,
            ColumnMappings = _columnMappings,
            HasHeaderRow = true,
            BuyKeywords = ParseKeywordList(_buyKeywords),
            SellKeywords = ParseKeywordList(_sellKeywords),
            IncomeKeywords = ParseKeywordList(_incomeKeywords),
            CashEquivalentSymbols = ParseKeywordList(_cashEquivalentSymbols),
            IgnoreRowPatterns = ParseKeywordList(_ignoreRowPatterns),
            AmountSignFlipped = _amountSignFlipped,
        };

        var result = await ImportService.CreateMappingAsync(request);
        if (result is null)
        {
            return null;
        }

        _activeMappingId = result.Id;
        return result.Id;
    }

    private bool HasRequiredMappings() =>
        _columnMappings.ContainsValue("Date")
        && _columnMappings.ContainsValue("Amount")
        && _columnMappings.ContainsValue("Description");

    private async Task RunPreviewImportAsync()
    {
        if (_selectedAccountId is null || _selectedFile is null)
        {
            return;
        }

        if (!IsDetectedFormatRegistered())
        {
            _errorMessage = $"Detected format '{_filePreview?.FileFormat ?? "unknown"}' is not provided by a registered transaction importer plugin.";
            return;
        }

        _isLoading = true;
        _errorMessage = null;

        var mappingId = await EnsureActiveMappingAsync();
        if (!mappingId.HasValue)
        {
            _errorMessage = "Failed to persist column mapping for preview.";
            _isLoading = false;
            return;
        }

        _selectedFile.Position = 0;
        _previewResult = await ImportService.ImportFileAsync(
            _selectedAccountId.Value,
            _selectedFile,
            _selectedFileName!,
            mappingId: mappingId,
            policy: "PreviewOnly"
        );

        if (_previewResult is null)
        {
            _errorMessage = "Failed to preview import. Please try again.";
            _isLoading = false;
            return;
        }

        _step = ImportStep.Preview;
        _isLoading = false;
    }

    private async Task CommitImportAsync()
    {
        if (_selectedAccountId is null || _selectedFile is null)
        {
            return;
        }

        if (!IsDetectedFormatRegistered())
        {
            _errorMessage = $"Detected format '{_filePreview?.FileFormat ?? "unknown"}' is not provided by a registered transaction importer plugin.";
            return;
        }

        _isLoading = true;
        _errorMessage = null;

        var mappingId = await EnsureActiveMappingAsync();
        if (!mappingId.HasValue)
        {
            _errorMessage = "Failed to persist column mapping for import.";
            _isLoading = false;
            return;
        }

        _selectedFile.Position = 0;
        _importResult = await ImportService.ImportFileAsync(
            _selectedAccountId.Value,
            _selectedFile,
            _selectedFileName!,
            mappingId: mappingId
        );

        if (_importResult is null)
        {
            _errorMessage = "Import failed. Please try again.";
            _isLoading = false;
            return;
        }

        _step = ImportStep.Complete;
        _isLoading = false;
    }

    private async Task SuggestRulesAsync()
    {
        if (_selectedAccountId is null || _selectedFile is null)
        {
            return;
        }

        _isSuggesting = true;
        _errorMessage = null;
        _successMessage = null;

        var mappingId = await EnsureActiveMappingAsync();
        if (!mappingId.HasValue)
        {
            _errorMessage = "Failed to persist column mapping for AI suggestions.";
            _isSuggesting = false;
            return;
        }

        _selectedFile.Position = 0;
        _ruleSuggestions = (
            await ImportService.SuggestRulesAsync(
                _selectedAccountId.Value,
                _selectedFile,
                _selectedFileName!,
                mappingId.Value,
                maxSuggestions: 8
            )
        ).ToList();

        _selectedCategoryBySuggestion.Clear();
        _selectedApplyScopeBySuggestion.Clear();

        if (_ruleSuggestions.Count == 0)
        {
            _errorMessage = "No rule suggestions were returned by Ollama. Try with a larger or more repetitive sample.";
        }
        else
        {
            _successMessage = $"Generated {_ruleSuggestions.Count} suggested rule(s).";
        }

        _isSuggesting = false;
    }

    private async Task AcceptSuggestionAsync(RuleSuggestionResponse suggestion)
    {
        if (_selectedAccountId is null)
        {
            return;
        }

        var selectedCategoryId = GetSelectedCategoryId(suggestion);
        if (!Guid.TryParse(selectedCategoryId, out var categoryId))
        {
            _errorMessage = "Select a category before accepting the rule suggestion.";
            return;
        }

        _isAccepting = true;
        _errorMessage = null;
        _successMessage = null;

        var request = new AcceptRuleSuggestionRequest
        {
            Name = suggestion.Name,
            Priority = suggestion.Priority,
            Conditions = suggestion.Conditions,
            CategoryId = categoryId,
            IsEnabled = true,
            ApplyScope = ParseApplyScope(GetSelectedApplyScope(suggestion)),
        };

        var result = await ImportService.AcceptSuggestedRuleAsync(_selectedAccountId.Value, request);
        if (result is null)
        {
            _errorMessage = "Failed to accept and apply the suggested rule.";
            _isAccepting = false;
            return;
        }

        _ruleSuggestions.Remove(suggestion);
        _selectedCategoryBySuggestion.Remove(GetSuggestionKey(suggestion));
        _selectedApplyScopeBySuggestion.Remove(GetSuggestionKey(suggestion));
        _successMessage =
            $"Rule \"{result.Rule.Name}\" created and applied to {result.AppliedTransactionCount} transaction(s) in this account.";
        _isAccepting = false;
    }

    private async Task SaveMappingAsync()
    {
        if (_filePreview is null)
        {
            return;
        }

        if (!IsDetectedFormatRegistered())
        {
            _errorMessage = $"Detected format '{_filePreview.FileFormat}' is not provided by a registered transaction importer plugin.";
            return;
        }

        var request = new CreateImportMappingRequest
        {
            Name = $"{_selectedFileName} mapping",
            FileFormat = _filePreview.FileFormat,
            ColumnMappings = _columnMappings,
            HasHeaderRow = true,
            BuyKeywords = ParseKeywordList(_buyKeywords),
            SellKeywords = ParseKeywordList(_sellKeywords),
            IncomeKeywords = ParseKeywordList(_incomeKeywords),
            CashEquivalentSymbols = ParseKeywordList(_cashEquivalentSymbols),
            IgnoreRowPatterns = ParseKeywordList(_ignoreRowPatterns),
            AmountSignFlipped = _amountSignFlipped,
        };

        var result = await ImportService.CreateMappingAsync(request);
        if (result is not null)
        {
            _successMessage = $"Mapping \"{result.Name}\" saved.";
        }
        else
        {
            _errorMessage = "Failed to save mapping.";
        }
    }

    private void ResetImport()
    {
        _step = ImportStep.Upload;
        _selectedFile?.Dispose();
        _selectedFile = null;
        _selectedFileName = null;
        _filePreview = null;
        _previewResult = null;
        _importResult = null;
        _columnMappings.Clear();
        _activeMappingId = null;
        _sampleRows.Clear();
        _ruleSuggestions.Clear();
        _selectedCategoryBySuggestion.Clear();
        _selectedApplyScopeBySuggestion.Clear();
        _errorMessage = null;
        _successMessage = null;
        _buyKeywords = "buy, purchase, contribution, reinvest, deposit, in, long";
        _sellKeywords = "sell, redeem, withdraw, out";
        _incomeKeywords = "interest, dividend, distribution";
        _cashEquivalentSymbols = "CASH";
        _ignoreRowPatterns = string.Empty;
        _amountSignFlipped = false;
    }

    private void ApplyPreselectedAccount()
    {
        if (PreselectedAccountId is null)
        {
            return;
        }

        var accountExists = _accounts.Any(account => account.Id == PreselectedAccountId.Value);
        if (!accountExists)
        {
            return;
        }

        _selectedAccountIdStr = PreselectedAccountId.Value.ToString();
    }

    private bool IsDetectedFormatRegistered()
    {
        if (_filePreview is null || _registeredImportFormats.Count == 0)
        {
            return false;
        }

        return _registeredImportFormats.Contains(_filePreview.FileFormat);
    }

    private List<WorkflowExceptionItem> BuildWorkflowExceptions()
    {
        var items = new List<WorkflowExceptionItem>();

        if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            items.Add(new("Active import error", _errorMessage, "risk"));
        }

        if (!string.IsNullOrWhiteSpace(_successMessage))
        {
            items.Add(new("Recent success", _successMessage, "ok"));
        }

        if (_registeredImportFormats.Count == 0)
        {
            items.Add(new("No registered import plugins", "Register at least one transaction importer before uploading a file.", "risk"));
        }

        if (_accounts.Count == 0)
        {
            items.Add(new("No destination accounts", "Add an account first so the workflow has a valid import target.", "warning"));
        }

        if (_step == ImportStep.ColumnMapping && !HasRequiredMappings())
        {
            items.Add(new("Required mappings incomplete", "Map Date, Amount, and Description before previewing the import outcome.", "warning"));
        }

        if (_previewResult is not null && _previewResult.Errors.Count > 0)
        {
            items.Add(new("Preview errors present", $"{_previewResult.Errors.Count} row-level errors need review before commit.", "risk"));
        }

        if (_filePreview is not null && !IsDetectedFormatRegistered())
        {
            items.Add(new("Unsupported detected format", $"Detected format '{_filePreview.FileFormat}' is not backed by a registered importer.", "risk"));
        }

        if (items.Count == 0)
        {
            items.Add(new("No blocking exceptions", "The workflow context is clear and ready for the next step.", "ok"));
        }

        return items;
    }

    private string GetStepClass(ImportStep step)
    {
        if (_step == step)
        {
            return "import-step-rail__item import-step-rail__item--active";
        }

        return (int)_step > (int)step
            ? "import-step-rail__item import-step-rail__item--complete"
            : "import-step-rail__item";
    }

    private static UiSeverity ToSeverity(string tone) => tone switch
    {
        "risk" => UiSeverity.Urgent,
        "warning" => UiSeverity.Advisory,
        _ => UiSeverity.Informational,
    };

    private static List<string>? ParseKeywordList(string value) =>
        string.IsNullOrWhiteSpace(value)
            ? null
            : value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private bool CanAcceptSuggestion(RuleSuggestionResponse suggestion) =>
        Guid.TryParse(GetSelectedCategoryId(suggestion), out _);

    private string GetSelectedCategoryId(RuleSuggestionResponse suggestion) =>
        _selectedCategoryBySuggestion.TryGetValue(GetSuggestionKey(suggestion), out var value)
            ? value
            : string.Empty;

    private void SetSelectedCategoryId(RuleSuggestionResponse suggestion, string? categoryId)
    {
        var key = GetSuggestionKey(suggestion);
        if (string.IsNullOrWhiteSpace(categoryId))
        {
            _selectedCategoryBySuggestion.Remove(key);
            return;
        }

        _selectedCategoryBySuggestion[key] = categoryId;
    }

    private string GetSelectedApplyScope(RuleSuggestionResponse suggestion) =>
        _selectedApplyScopeBySuggestion.TryGetValue(GetSuggestionKey(suggestion), out var value)
            ? value
            : "AllMatching";

    private void SetSelectedApplyScope(RuleSuggestionResponse suggestion, string? scope)
    {
        var key = GetSuggestionKey(suggestion);
        if (string.IsNullOrWhiteSpace(scope))
        {
            _selectedApplyScopeBySuggestion.Remove(key);
            return;
        }

        _selectedApplyScopeBySuggestion[key] = scope;
    }

    private static RuleApplyScope ParseApplyScope(string? value) =>
        Enum.TryParse<RuleApplyScope>(value, ignoreCase: true, out var parsed)
            ? parsed
            : RuleApplyScope.AllMatching;

    private static string GetSuggestionKey(RuleSuggestionResponse suggestion) =>
        $"{suggestion.Name}|{suggestion.Conditions}|{suggestion.Priority}";

    private static string FormatInstitution(AccountResponse account) =>
        string.IsNullOrWhiteSpace(account.Institution) ? "No institution" : account.Institution;

    public record SampleRow
    {
        public List<string> Values { get; init; } = [];
    }

    private sealed record ImportStepDescriptor(int Index, ImportStep Step, string Label, string Description);

    private sealed record WorkflowExceptionItem(string Title, string Detail, string Tone);
}
