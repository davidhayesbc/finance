@page "/sinking-funds"
@inject ISinkingFundService SinkingFundService
@inject ICategoryService CategoryService
@inject IAccountService AccountService
@inject NavigationManager Navigation

<PageTitle>Sinking Funds — Privestio</PageTitle>

<section class="page-shell">
    <PageHeader Eyebrow="Sinking Funds" Title="Savings goals" Description="Track targeted savings toward lump-sum expenses.">
        <Actions>
            <FluentButton Appearance="Appearance.Accent" OnClick="ShowCreateForm">
                Add Sinking Fund
            </FluentButton>
        </Actions>
    </PageHeader>

    @if (_showForm)
    {
        <FluentCard Class="surface-card form-card" style="margin-bottom: 1.5rem;">
            <h3>@(_editingFundId.HasValue ? "Edit Sinking Fund" : "New Sinking Fund")</h3>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <FluentMessageBar Intent="@MessageIntent.Error">@_errorMessage</FluentMessageBar>
            }

            <EditForm Model="_form" OnValidSubmit="SaveFundAsync" aria-label="Sinking fund form">
                <DataAnnotationsValidator />
                <FluentValidationSummary />

                <FluentStack Orientation="Orientation.Vertical" Width="100%" Class="form-stack">
                    <FluentTextField @bind-Value="_form.Name" Label="Name" Placeholder="e.g., Annual Insurance" Required="true" maxlength="200" />
                    <FluentValidationMessage For="@(() => _form.Name)" />

                    <FluentNumberField @bind-Value="_form.TargetAmount" Label="Target amount" Step="0.01m" Required="true" />
                    <FluentValidationMessage For="@(() => _form.TargetAmount)" />

                    <FluentDatePicker @bind-Value="_formDueDate" Label="Due date" Required="true" />

                    <FluentSelect TOption="string" @bind-Value="_form.Currency" Label="Currency">
                        <FluentOption TOption="string" Value="CAD">CAD — Canadian Dollar</FluentOption>
                        <FluentOption TOption="string" Value="USD">USD — US Dollar</FluentOption>
                    </FluentSelect>

                    <FluentSelect TOption="string" @bind-Value="_form.AccountId" Label="Funding account (optional)">
                        <FluentOption TOption="string" Value="">None</FluentOption>
                        @foreach (var acct in _accounts)
                        {
                            <FluentOption TOption="string" Value="@acct.Id.ToString()">@acct.Name</FluentOption>
                        }
                    </FluentSelect>

                    <FluentSelect TOption="string" @bind-Value="_form.CategoryId" Label="Category (optional)">
                        <FluentOption TOption="string" Value="">None</FluentOption>
                        @foreach (var cat in _categories)
                        {
                            <FluentOption TOption="string" Value="@cat.Id.ToString()">@cat.Name</FluentOption>
                        }
                    </FluentSelect>

                    <FluentTextArea @bind-Value="_form.Notes" Label="Notes" Rows="2" />

                    <FluentStack Orientation="Orientation.Horizontal" Class="form-actions">
                        <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Loading="_isSaving">
                            @(_editingFundId.HasValue ? "Update Fund" : "Create Fund")
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="CancelForm">Cancel</FluentButton>
                    </FluentStack>
                </FluentStack>
            </EditForm>
        </FluentCard>
    }

    @if (_showContributeForm)
    {
        <FluentCard Class="surface-card form-card" style="margin-bottom: 1.5rem;">
            <h3>Contribute to @_contributingFundName</h3>

            <FluentStack Orientation="Orientation.Vertical" Width="100%" Class="form-stack">
                <FluentNumberField @bind-Value="_contributeAmount" Label="Contribution amount" Step="0.01m" />
                <FluentStack Orientation="Orientation.Horizontal" Class="form-actions">
                    <FluentButton Appearance="Appearance.Accent" Loading="_isSaving" OnClick="SubmitContributionAsync">Contribute</FluentButton>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="CancelContribute">Cancel</FluentButton>
                </FluentStack>
            </FluentStack>
        </FluentCard>
    }

    @if (_isLoading)
    {
        <FluentProgressRing />
    }
    else if (_funds.Count == 0)
    {
        <EmptyStateCard Message="No sinking funds yet. Start saving toward your next big expense.">
            <Actions>
                <FluentButton Appearance="Appearance.Accent" OnClick="ShowCreateForm">Add Sinking Fund</FluentButton>
            </Actions>
        </EmptyStateCard>
    }
    else
    {
        <FluentCard Class="surface-card data-card">
            <div class="summary-strip">
                <div>
                    <span class="summary-strip__label">Active funds</span>
                    <strong>@_funds.Count(f => f.IsActive)</strong>
                </div>
                <div>
                    <span class="summary-strip__label">Total target</span>
                    <strong>@_funds.Where(f => f.IsActive).Sum(f => f.TargetAmount).ToString("C")</strong>
                </div>
                <div>
                    <span class="summary-strip__label">Total saved</span>
                    <strong>@_funds.Where(f => f.IsActive).Sum(f => f.AccumulatedAmount).ToString("C")</strong>
                </div>
                <div>
                    <span class="summary-strip__label">Behind schedule</span>
                    <strong>@_funds.Count(f => f.IsActive && !f.IsOnTrack)</strong>
                </div>
            </div>

            <FluentDataGrid Items="_funds.AsQueryable()" TGridItem="SinkingFundResponse" Class="data-grid--elevated">
                <PropertyColumn Property="@(f => f.Name)" Title="Name" Sortable="true" />
                <TemplateColumn Title="Progress">
                    <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" Style="gap: 0.5rem;">
                        <FluentProgress Value="@((int)Math.Min(context.ProgressPercentage, 100))" Min="0" Max="100" Style="flex: 1;" />
                        <span style="font-size: 0.85rem; min-width: 3rem;">@context.ProgressPercentage.ToString("F0")%</span>
                    </FluentStack>
                </TemplateColumn>
                <TemplateColumn Title="Saved / Target">
                    @context.AccumulatedAmount.ToString("C") / @context.TargetAmount.ToString("C")
                </TemplateColumn>
                <TemplateColumn Title="Monthly">
                    @context.MonthlySetAside.ToString("C")
                </TemplateColumn>
                <TemplateColumn Title="Due">
                    @context.DueDate.ToString("MMM d, yyyy")
                </TemplateColumn>
                <TemplateColumn Title="Status">
                    @if (!context.IsActive)
                    {
                        <FluentBadge Appearance="Appearance.Neutral">Completed</FluentBadge>
                    }
                    else if (context.IsOnTrack)
                    {
                        <FluentBadge Appearance="Appearance.Accent">On Track</FluentBadge>
                    }
                    else
                    {
                        <FluentBadge Appearance="Appearance.Accent" BackgroundColor="#c50f1f" Color="white">Behind</FluentBadge>
                    }
                </TemplateColumn>
                <TemplateColumn Title="">
                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 4px;">
                        @if (context.IsActive)
                        {
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => ShowContribute(context))">Contribute</FluentButton>
                        }
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => EditFund(context))">Edit</FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => DeleteFundAsync(context.Id))">Delete</FluentButton>
                    </FluentStack>
                </TemplateColumn>
            </FluentDataGrid>
        </FluentCard>
    }
</section>

@code {
    private List<SinkingFundResponse> _funds = [];
    private List<CategoryResponse> _categories = [];
    private List<AccountResponse> _accounts = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _showForm;
    private bool _showContributeForm;
    private Guid? _editingFundId;
    private string? _errorMessage;

    private CreateSinkingFundFormModel _form = new();
    private DateTime? _formDueDate;

    private Guid _contributingFundId;
    private string _contributingFundName = string.Empty;
    private decimal _contributeAmount;

    protected override async Task OnInitializedAsync()
    {
        var categoriesTask = CategoryService.GetCategoriesAsync();
        var accountsTask = AccountService.GetAccountsAsync();
        await Task.WhenAll(categoriesTask, accountsTask);
        _categories = (await categoriesTask).ToList();
        _accounts = (await accountsTask).ToList();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _funds = (await SinkingFundService.GetSinkingFundsAsync()).ToList();
        _isLoading = false;
    }

    private void ShowCreateForm()
    {
        _editingFundId = null;
        _form = new CreateSinkingFundFormModel();
        _formDueDate = _form.DueDate;
        _errorMessage = null;
        _showForm = true;
        _showContributeForm = false;
    }

    private void EditFund(SinkingFundResponse fund)
    {
        _editingFundId = fund.Id;
        _form = new CreateSinkingFundFormModel
        {
            Name = fund.Name,
            TargetAmount = fund.TargetAmount,
            DueDate = fund.DueDate,
            Currency = fund.Currency,
            AccountId = fund.AccountId?.ToString(),
            CategoryId = fund.CategoryId?.ToString(),
            Notes = fund.Notes
        };
        _formDueDate = fund.DueDate;
        _errorMessage = null;
        _showForm = true;
        _showContributeForm = false;
    }

    private void CancelForm()
    {
        _showForm = false;
        _errorMessage = null;
    }

    private void ShowContribute(SinkingFundResponse fund)
    {
        _contributingFundId = fund.Id;
        _contributingFundName = fund.Name;
        _contributeAmount = fund.MonthlySetAside;
        _showContributeForm = true;
        _showForm = false;
    }

    private void CancelContribute()
    {
        _showContributeForm = false;
    }

    private async Task SaveFundAsync()
    {
        _isSaving = true;
        _errorMessage = null;
        _form.DueDate = _formDueDate ?? DateTime.Today.AddMonths(6);

        Guid? accountId = string.IsNullOrEmpty(_form.AccountId) ? null : Guid.Parse(_form.AccountId);
        Guid? categoryId = string.IsNullOrEmpty(_form.CategoryId) ? null : Guid.Parse(_form.CategoryId);

        if (_editingFundId.HasValue)
        {
            var result = await SinkingFundService.UpdateSinkingFundAsync(
                _editingFundId.Value,
                new UpdateSinkingFundRequest(_form.Name, _form.TargetAmount, _form.DueDate, _form.Currency, accountId, categoryId, _form.Notes)
            );
            if (result is null)
            {
                _errorMessage = "Failed to update sinking fund.";
                _isSaving = false;
                return;
            }
        }
        else
        {
            var result = await SinkingFundService.CreateSinkingFundAsync(
                new CreateSinkingFundRequest(_form.Name, _form.TargetAmount, _form.DueDate, _form.Currency, accountId, categoryId, _form.Notes)
            );
            if (result is null)
            {
                _errorMessage = "Failed to create sinking fund.";
                _isSaving = false;
                return;
            }
        }

        _isSaving = false;
        _showForm = false;
        await LoadDataAsync();
    }

    private async Task SubmitContributionAsync()
    {
        _isSaving = true;
        await SinkingFundService.ContributeAsync(_contributingFundId, new ContributeSinkingFundRequest(_contributeAmount));
        _isSaving = false;
        _showContributeForm = false;
        await LoadDataAsync();
    }

    private async Task DeleteFundAsync(Guid id)
    {
        await SinkingFundService.DeleteSinkingFundAsync(id);
        await LoadDataAsync();
    }
}
