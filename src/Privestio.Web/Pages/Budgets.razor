@page "/budgets"
@inject IBudgetService BudgetService
@inject ICategoryService CategoryService
@inject NavigationManager Navigation

<PageTitle>Budgets — Privestio</PageTitle>

<section class="page-shell">
    <PageHeader Eyebrow="Budgets" Title="Monthly budgets" Description="Set and track spending limits per category.">
        <Actions>
            <FluentButton Appearance="Appearance.Accent" OnClick="ShowCreateForm">
                Add Budget
            </FluentButton>
        </Actions>
    </PageHeader>

    <FluentCard Class="surface-card" style="margin-bottom: 1.5rem;">
        <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center"
                     Style="gap: 1rem;">
            <FluentSelect TOption="string" @bind-Value="_selectedYearStr" Label="Year" Style="min-width: 120px;">
                @for (var y = DateTime.Today.Year + 1; y >= DateTime.Today.Year - 2; y--)
                {
                    <FluentOption TOption="string" Value="@y.ToString()">@y</FluentOption>
                }
            </FluentSelect>
            <FluentSelect TOption="string" @bind-Value="_selectedMonthStr" Label="Month" Style="min-width: 150px;">
                @for (var m = 1; m <= 12; m++)
                {
                    <FluentOption TOption="string" Value="@m.ToString()">@(new DateTime(2000, m, 1).ToString("MMMM"))
                    </FluentOption>
                }
            </FluentSelect>
            <FluentButton Appearance="Appearance.Outline" OnClick="LoadDataAsync" Style="align-self: flex-end;">
                Refresh
            </FluentButton>
        </FluentStack>
    </FluentCard>

    @if (_showForm)
    {
        <FluentCard Class="surface-card form-card" style="margin-bottom: 1.5rem;">
            <h3>@(_editingBudgetId.HasValue ? "Edit Budget" : "New Budget")</h3>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <FluentMessageBar Intent="@MessageIntent.Error">
                    @_errorMessage
                </FluentMessageBar>
            }

            <EditForm Model="_form" OnValidSubmit="SaveBudgetAsync" aria-label="Budget form">
                <DataAnnotationsValidator />
                <FluentValidationSummary />

                <FluentStack Orientation="Orientation.Vertical" Width="100%" Class="form-stack">
                    <CategorySelect Categories="_categories" @bind-Value="_form.CategoryId" NoneLabel="Select category..."
                                    Required="true" />
                    <FluentValidationMessage For="@(() => _form.CategoryId)" />

                    <FluentNumberField @bind-Value="_form.Amount" Label="Budget amount" Step="0.01m" Required="true" />
                    <FluentValidationMessage For="@(() => _form.Amount)" />

                    <CurrencySelect @bind-Value="_form.Currency" Label="Currency" />

                    <FluentCheckbox @bind-Value="_form.RolloverEnabled"
                                    Label="Enable rollover (carry unused budget to next month)" />

                    <FluentTextArea @bind-Value="_form.Notes" Label="Notes" Rows="2" />

                    <FluentStack Orientation="Orientation.Horizontal" Class="form-actions">
                        <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Loading="_isSaving">
                            @(_editingBudgetId.HasValue ? "Update Budget" : "Create Budget")
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="CancelForm">Cancel</FluentButton>
                    </FluentStack>
                </FluentStack>
            </EditForm>
        </FluentCard>
    }

    @if (_isLoading)
    {
        <LoadingSpinner AriaLabel="Loading budgets" />
    }
    else if (_summaries.Count == 0 && _budgets.Count == 0)
    {
        <EmptyStateCard Message="No budgets set for this period. Add a budget to start tracking spending.">
            <Actions>
                <FluentButton Appearance="Appearance.Accent" OnClick="ShowCreateForm">Add Budget</FluentButton>
            </Actions>
        </EmptyStateCard>
    }
    else
    {
        @if (_summaries.Count > 0)
        {
            <FluentCard Class="surface-card data-card" style="margin-bottom: 1.5rem;">
                <h3 style="margin: 0 0 1rem 0;">Budget vs Actual — @(new DateTime(_selectedYear, _selectedMonth,
                                1).ToString("MMMM yyyy"))</h3>

                    <div class="summary-strip">
                        <div>
                            <span class="summary-strip__label">Total budgeted</span>
                            <strong>@_summaries.Sum(s => s.BudgetedAmount).ToString("C")</strong>
                        </div>
                        <div>
                            <span class="summary-strip__label">Total spent</span>
                            <strong>@_summaries.Sum(s => s.ActualAmount).ToString("C")</strong>
                        </div>
                        <div>
                            <span class="summary-strip__label">Remaining</span>
                            <strong>@_summaries.Sum(s => s.RemainingAmount).ToString("C")</strong>
                        </div>
                        <div>
                            <span class="summary-strip__label">Over budget</span>
                            <strong>@_summaries.Count(s => s.IsOverBudget)</strong>
                        </div>
                    </div>

                    <FluentDataGrid Items="_summaries.AsQueryable()" TGridItem="BudgetSummaryResponse" Class="data-grid--elevated">
                        <PropertyColumn Property="@(s => s.CategoryName)" Title="Category" Sortable="true" />
                        <TemplateColumn Title="Budgeted" Sortable="true"
                                        SortBy="@(GridSort<BudgetSummaryResponse>.ByAscending(s => s.BudgetedAmount))">
                            @context.BudgetedAmount.ToString("C") @context.Currency
                        </TemplateColumn>
                        <TemplateColumn Title="Actual" Sortable="true"
                                        SortBy="@(GridSort<BudgetSummaryResponse>.ByAscending(s => s.ActualAmount))">
                            @context.ActualAmount.ToString("C") @context.Currency
                        </TemplateColumn>
                        <TemplateColumn Title="Remaining">
                            <FluentBadge Appearance="@(context.IsOverBudget? Appearance.Accent: Appearance.Neutral)"
                                         BackgroundColor="@(context.IsOverBudget ? "#c50f1f" : null)"
                                         Color="@(context.IsOverBudget ? "white" : null)">
                                @context.RemainingAmount.ToString("C")
                            </FluentBadge>
                        </TemplateColumn>
                        <TemplateColumn Title="Used">
                            <FluentProgress Value="@((int)Math.Min(context.PercentageUsed, 100))" Min="0" Max="100" />
                            <span style="font-size: 0.85rem; margin-left: 0.5rem;">@context.PercentageUsed.ToString("F0")%</span>
                        </TemplateColumn>
                    </FluentDataGrid>
                </FluentCard>
            }

            <FluentCard Class="surface-card data-card">
                <h3 style="margin: 0 0 1rem 0;">Budget Definitions</h3>

                <FluentDataGrid Items="_budgets.AsQueryable()" TGridItem="BudgetResponse" Class="data-grid--elevated">
                    <PropertyColumn Property="@(b => b.CategoryName)" Title="Category" Sortable="true" />
                    <TemplateColumn Title="Amount">
                        @context.Amount.ToString("C") @context.Currency
                    </TemplateColumn>
                    <TemplateColumn Title="Period">
                        @(new DateTime(context.Year, context.Month, 1).ToString("MMMM yyyy"))
                    </TemplateColumn>
                    <TemplateColumn Title="Rollover">
                        <FluentBadge Appearance="@(context.RolloverEnabled? Appearance.Accent: Appearance.Neutral)">
                            @(context.RolloverEnabled ? "Yes" : "No")
                        </FluentBadge>
                    </TemplateColumn>
                    <TemplateColumn Title="">
                        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 4px;">
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => EditBudget(context))">Edit
                            </FluentButton>
                            <FluentButton Appearance="Appearance.Stealth" OnClick="@(() => DeleteBudgetAsync(context.Id))">
                                Delete</FluentButton>
                            </FluentStack>
                        </TemplateColumn>
                    </FluentDataGrid>
                </FluentCard>
            }
        </section>

@code {
    private List<BudgetResponse> _budgets = [];
    private List<BudgetSummaryResponse> _summaries = [];
    private List<CategoryResponse> _categories = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _showForm;
    private Guid? _editingBudgetId;
    private string? _errorMessage;
    private string _selectedYearStr = DateTime.Today.Year.ToString();
    private string _selectedMonthStr = DateTime.Today.Month.ToString();
    private int _selectedYear => int.TryParse(_selectedYearStr, out var y) ? y : DateTime.Today.Year;
    private int _selectedMonth => int.TryParse(_selectedMonthStr, out var m) ? m : DateTime.Today.Month;

    private CreateBudgetFormModel _form = new();

    protected override async Task OnInitializedAsync()
    {
        _categories = (await CategoryService.GetCategoriesAsync()).ToList();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        var budgetTask = BudgetService.GetBudgetsAsync(_selectedYear, _selectedMonth);
        var summaryTask = BudgetService.GetBudgetSummaryAsync(_selectedYear, _selectedMonth);
        await Task.WhenAll(budgetTask, summaryTask);
        _budgets = (await budgetTask).ToList();
        _summaries = (await summaryTask).ToList();
        _isLoading = false;
    }

    private void ShowCreateForm()
    {
        _editingBudgetId = null;
        _form = new CreateBudgetFormModel { Year = _selectedYear, Month = _selectedMonth };
        _errorMessage = null;
        _showForm = true;
    }

    private void EditBudget(BudgetResponse budget)
    {
        _editingBudgetId = budget.Id;
        _form = new CreateBudgetFormModel
        {
            CategoryId = budget.CategoryId.ToString(),
            Year = budget.Year,
            Month = budget.Month,
            Amount = budget.Amount,
            Currency = budget.Currency,
            RolloverEnabled = budget.RolloverEnabled,
            Notes = budget.Notes
        };
        _errorMessage = null;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _errorMessage = null;
    }

    private async Task SaveBudgetAsync()
    {
        _isSaving = true;
        _errorMessage = null;

        if (_editingBudgetId.HasValue)
        {
            var result = await BudgetService.UpdateBudgetAsync(
                _editingBudgetId.Value,
                new UpdateBudgetRequest(
                    _form.Amount,
                    _form.Currency,
                    _form.RolloverEnabled,
                    _form.Notes
                )
            );
            if (result is null)
            {
                _errorMessage = "Failed to update budget.";
                _isSaving = false;
                return;
            }
        }
        else
        {
            var result = await BudgetService.CreateBudgetAsync(
                new CreateBudgetRequest(
                    Guid.Parse(_form.CategoryId),
                    _form.Year,
                    _form.Month,
                    _form.Amount,
                    _form.Currency,
                    _form.RolloverEnabled,
                    _form.Notes
                )
            );
            if (result is null)
            {
                _errorMessage = "Failed to create budget. It may already exist for this category and period.";
                _isSaving = false;
                return;
            }
        }

        _isSaving = false;
        _showForm = false;
        await LoadDataAsync();
    }

    private async Task DeleteBudgetAsync(Guid id)
    {
        await BudgetService.DeleteBudgetAsync(id);
        await LoadDataAsync();
    }
}