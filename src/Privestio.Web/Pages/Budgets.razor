@page "/budgets"
@inject IBudgetService BudgetService
@inject ICategoryService CategoryService

<PageTitle>Budgets — Privestio</PageTitle>

<section class="page-shell budgets-shell" data-testid="budgets-page">
    <PageRegion Name="orientation" Class="budgets-orientation">
        <PageHeader Eyebrow="Budgets" Title="Budgets"
                    Description="Track the current month against category limits, rollover rules, and actual spend."
                    UtilityDescription="Use the period selector to move month by month while keeping the creation action fixed.">
            <Context>
                <div>
                    <span class="filter-label">Period</span>
                    <div class="action-cluster">
                        <FluentButton Appearance="Appearance.Stealth" OnClick="ShowPreviousMonthAsync">Previous</FluentButton>
                        <FluentButton Appearance="Appearance.Outline" OnClick="JumpToCurrentPeriodAsync">Current period</FluentButton>
                        <FluentButton Appearance="Appearance.Stealth" OnClick="ShowNextMonthAsync">Next</FluentButton>
                    </div>
                </div>
            </Context>
            <Actions>
                <div class="action-cluster">
                    <FluentButton Appearance="Appearance.Outline" OnClick="LoadDataAsync">Refresh</FluentButton>
                    <FluentButton Appearance="Appearance.Accent" OnClick="ShowCreateForm">Add Budget</FluentButton>
                </div>
            </Actions>
        </PageHeader>
    </PageRegion>

    <PageRegion Name="supporting" Class="budgets-posture" aria-labelledby="budgets-posture-title">
        <PostureStrip Title="Monthly posture"
                      TitleId="budgets-posture-title"
                      Description="Read the month before drilling into individual categories."
                      HeaderClass="budgets-section-heading"
                      GridClass="budgets-posture__grid">

        @if (_isLoading)
        {
            <LoadingSurface Variant="posture" Columns="5" />
        }
        else
        {
                <article class="budgets-posture__item">
                    <span>Total budgeted</span>
                    <strong>@FormatMoney(TotalBudgeted)</strong>
                    <p>@_budgets.Count definition@(_budgets.Count == 1 ? string.Empty : "s") in scope.</p>
                </article>
                <article class="budgets-posture__item">
                    <span>Total spent</span>
                    <strong>@FormatMoney(TotalSpent)</strong>
                    <p>@_summaries.Count category performance row@(_summaries.Count == 1 ? string.Empty : "s").</p>
                </article>
                <article class="budgets-posture__item">
                    <span>Remaining</span>
                    <strong>@FormatMoney(TotalRemaining)</strong>
                    <p>@BuildRemainingDetail()</p>
                </article>
                <article class="budgets-posture__item">
                    <span>Over budget</span>
                    <strong>@OverBudgetCount</strong>
                    <p>@BuildOverBudgetDetail()</p>
                </article>
                <article class="budgets-posture__item">
                    <span>Rollover exposure</span>
                    <strong>@FormatMoney(RolloverExposure)</strong>
                    <p>@BuildRolloverDetail()</p>
                </article>
        }
        </PostureStrip>
    </PageRegion>

    <div class="budgets-review-grid">
        <PageRegion Name="primary" Class="budgets-performance" aria-labelledby="budgets-performance-title">
            <SectionBand Title="Category performance"
                         TitleId="budgets-performance-title"
                         Description="The category table is the primary judgment surface for the month."
                         Meta='@($"{_summaries.Count} categor{(_summaries.Count == 1 ? "y" : "ies")}")'
                         HeaderClass="budgets-section-heading budgets-section-heading--split">

            <DenseTableSurface IsLoading="@_isLoading"
                               IsUpdating="@(_hasLoadedData && _isLoading)"
                               IsEmpty="@(_summaries.Count == 0)"
                               LoadingRows="6"
                               LoadingColumns="6"
                               EmptyTitle="No category performance yet."
                               EmptyMessage="Add a budget definition for this period to turn the month review into a live ledger.">
                <div class="budgets-table-wrap table-surface table-surface--native">
                    <table class="budgets-table">
                        <thead>
                            <tr>
                                <th scope="col">Category</th>
                                <th scope="col" class="budgets-table__numeric">Budgeted</th>
                                <th scope="col" class="budgets-table__numeric">Actual</th>
                                <th scope="col" class="budgets-table__numeric">Remaining</th>
                                <th scope="col">Percent used</th>
                                <th scope="col">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var summary in OrderedSummaries)
                            {
                                <tr>
                                    <td>
                                        <div class="budgets-table__identity">
                                            <strong>@summary.CategoryName</strong>
                                            <span>@BuildCategorySubline(summary)</span>
                                        </div>
                                    </td>
                                    <td class="budgets-table__numeric">@FormatMoney(summary.BudgetedAmount, summary.Currency)</td>
                                    <td class="budgets-table__numeric">@FormatMoney(summary.ActualAmount, summary.Currency)</td>
                                    <td class="budgets-table__numeric">@FormatMoney(summary.RemainingAmount, summary.Currency)</td>
                                    <td>
                                        <div class="budgets-pressure-meter" aria-label="@($"{summary.PercentageUsed:F0}% used")">
                                            <span class="budgets-pressure-meter__bar" style="@BuildPressureMeterStyle(summary)"></span>
                                        </div>
                                        <span class="budgets-pressure-meter__label">@summary.PercentageUsed.ToString("F0")%</span>
                                    </td>
                                    <td>
                                        <span class="@GetStatusClass(summary)">@GetStatusLabel(summary)</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </DenseTableSurface>
            </SectionBand>
        </PageRegion>

        <PageRegion Name="exceptions" Class="budgets-pressure" aria-labelledby="budgets-pressure-title">
            <SectionBand Title="At risk"
                         TitleId="budgets-pressure-title"
                         Description="Isolate interventions without burying the main performance table."
                         HeaderClass="budgets-section-heading">

            <div class="budgets-pressure__list">
                @foreach (var item in PressureItems)
                {
                    <OperationalExceptionRow Title="@item.Title"
                                             Detail="@item.Detail"
                                             Severity="@ToSeverity(item.Tone)" />
                }
            </div>
            </SectionBand>
        </PageRegion>
    </div>

    <PageRegion Name="supporting" Class="budgets-definitions" aria-labelledby="budgets-definitions-title">
        <SectionBand Title="Budget definitions"
                     TitleId="budgets-definitions-title"
                     Description="Keep setup subordinate to the current-month judgment surface."
                     Meta='@($"{_budgets.Count} saved definition{(_budgets.Count == 1 ? string.Empty : "s")}")'
                     HeaderClass="budgets-section-heading budgets-section-heading--split">

        @if (_showForm)
        {
            <InspectorPanel Title="@(_editingBudgetId.HasValue ? "Edit budget" : "New budget")"
                            TitleId="budgets-edit-title"
                            Description="Adjust one definition without losing the surrounding month context."
                            HeadingLevel="3"
                            Variant="sheet"
                            Class="budgets-edit-band">
                <HeaderActions>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="CancelForm">Close</FluentButton>
                </HeaderActions>
                <ChildContent>
                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <FluentMessageBar Intent="@MessageIntent.Error">@_errorMessage</FluentMessageBar>
                    }

                    <EditForm Model="_form" OnValidSubmit="SaveBudgetAsync" aria-label="Budget form">
                        <DataAnnotationsValidator />
                        <FluentValidationSummary />

                        <div class="budgets-form-grid">
                            <label class="budgets-form-field">
                                <span>Category</span>
                                <select @bind="_form.CategoryId" class="budgets-native-select" aria-label="Category" disabled="@(_categories.Count == 0)">
                                    <option value="">Select category...</option>
                                    @foreach (var category in OrderedCategories)
                                    {
                                        <option value="@category.Id.ToString()">@category.Name</option>
                                    }
                                </select>
                            </label>

                            <label class="budgets-form-field">
                                <span>Budget amount</span>
                                <InputNumber @bind-Value="_form.Amount" class="budgets-native-input" />
                            </label>

                            <label class="budgets-form-field">
                                <span>Currency</span>
                                <CurrencySelect @bind-Value="_form.Currency" Label="Currency" />
                            </label>

                            <label class="budgets-form-field budgets-form-field--wide">
                                <span>Notes</span>
                                <InputTextArea @bind-Value="_form.Notes" class="budgets-native-textarea" />
                            </label>
                        </div>

                        <div class="budgets-form-actions">
                            <FluentCheckbox @bind-Value="_form.RolloverEnabled" Label="Enable rollover for this category" />
                            <div class="action-cluster">
                                <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent" Loading="_isSaving">
                                    @(_editingBudgetId.HasValue ? "Update Budget" : "Create Budget")
                                </FluentButton>
                                <FluentButton Appearance="Appearance.Stealth" OnClick="CancelForm">Cancel</FluentButton>
                            </div>
                        </div>
                    </EditForm>
                </ChildContent>
            </InspectorPanel>
        }

        <DenseTableSurface IsLoading="@_isLoading"
                           IsUpdating="@(_hasLoadedData && _isLoading)"
                           IsEmpty="@(_budgets.Count == 0)"
                           LoadingRows="5"
                           LoadingColumns="6"
                           EmptyTitle='@($"No budget definitions saved for {PeriodLabel}.")'
                           EmptyMessage="Use the add action to create the first budget definition for this period.">
            <div class="budgets-table-wrap table-surface table-surface--native">
                <table class="budgets-table budgets-table--definitions">
                    <thead>
                        <tr>
                            <th scope="col">Category</th>
                            <th scope="col" class="budgets-table__numeric">Amount</th>
                            <th scope="col">Period</th>
                            <th scope="col">Rollover</th>
                            <th scope="col">Notes</th>
                            <th scope="col">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var budget in OrderedBudgets)
                        {
                            <tr>
                                <td>@budget.CategoryName</td>
                                <td class="budgets-table__numeric">@FormatMoney(budget.Amount, budget.Currency)</td>
                                <td>@(new DateTime(budget.Year, budget.Month, 1).ToString("MMMM yyyy"))</td>
                                <td>@(budget.RolloverEnabled ? "Enabled" : "Off")</td>
                                <td>@(string.IsNullOrWhiteSpace(budget.Notes) ? "-" : budget.Notes)</td>
                                <td>
                                    <div class="budgets-actions">
                                        <button type="button" class="budgets-link-action" @onclick="() => EditBudget(budget)">Edit</button>
                                        <button type="button" class="budgets-link-action budgets-link-action--danger" @onclick="() => DeleteBudgetAsync(budget.Id)">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </DenseTableSurface>
        </SectionBand>
    </PageRegion>
</section>

@code {
    private List<BudgetResponse> _budgets = [];
    private List<BudgetSummaryResponse> _summaries = [];
    private List<CategoryResponse> _categories = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _hasLoadedData;
    private bool _showForm;
    private Guid? _editingBudgetId;
    private string? _errorMessage;
    private int _selectedYear = DateTime.Today.Year;
    private int _selectedMonth = DateTime.Today.Month;

    private CreateBudgetFormModel _form = new();

    private string PeriodLabel => new DateTime(_selectedYear, _selectedMonth, 1).ToString("MMMM yyyy");

    private decimal TotalBudgeted => _summaries.Sum(summary => summary.BudgetedAmount);

    private decimal TotalSpent => _summaries.Sum(summary => summary.ActualAmount);

    private decimal TotalRemaining => _summaries.Sum(summary => summary.RemainingAmount);

    private int OverBudgetCount => _summaries.Count(summary => summary.IsOverBudget);

    private decimal RolloverExposure => _budgets.Where(budget => budget.RolloverEnabled).Sum(budget => budget.Amount);

    private string PrimaryCurrency => _summaries.FirstOrDefault()?.Currency ?? _budgets.FirstOrDefault()?.Currency ?? "CAD";

    private List<BudgetSummaryResponse> OrderedSummaries =>
        _summaries
            .OrderByDescending(summary => summary.IsOverBudget)
            .ThenByDescending(summary => summary.PercentageUsed)
            .ThenBy(summary => summary.CategoryName, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private List<BudgetResponse> OrderedBudgets =>
        _budgets
            .OrderBy(budget => budget.CategoryName, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private List<CategoryResponse> OrderedCategories =>
        _categories
            .OrderBy(category => category.SortOrder)
            .ThenBy(category => category.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private List<BudgetAlert> PressureItems => BuildPressureItems();

    protected override async Task OnInitializedAsync()
    {
        _categories = (await CategoryService.GetCategoriesAsync()).ToList();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;

        try
        {
            var budgetTask = BudgetService.GetBudgetsAsync(_selectedYear, _selectedMonth);
            var summaryTask = BudgetService.GetBudgetSummaryAsync(_selectedYear, _selectedMonth);
            await Task.WhenAll(budgetTask, summaryTask);
            _budgets = (await budgetTask).ToList();
            _summaries = (await summaryTask).ToList();
            _hasLoadedData = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ShowPreviousMonthAsync()
    {
        ShiftMonth(-1);
        await LoadDataAsync();
    }

    private async Task ShowNextMonthAsync()
    {
        ShiftMonth(1);
        await LoadDataAsync();
    }

    private async Task JumpToCurrentPeriodAsync()
    {
        _selectedYear = DateTime.Today.Year;
        _selectedMonth = DateTime.Today.Month;
        await LoadDataAsync();
    }

    private void ShiftMonth(int delta)
    {
        var next = new DateTime(_selectedYear, _selectedMonth, 1).AddMonths(delta);
        _selectedYear = next.Year;
        _selectedMonth = next.Month;
    }

    private void ShowCreateForm()
    {
        _editingBudgetId = null;
        _form = new CreateBudgetFormModel { Year = _selectedYear, Month = _selectedMonth, Currency = PrimaryCurrency };
        _errorMessage = null;
        _showForm = true;
    }

    private void EditBudget(BudgetResponse budget)
    {
        _editingBudgetId = budget.Id;
        _form = new CreateBudgetFormModel
        {
            CategoryId = budget.CategoryId.ToString(),
            Year = budget.Year,
            Month = budget.Month,
            Amount = budget.Amount,
            Currency = budget.Currency,
            RolloverEnabled = budget.RolloverEnabled,
            Notes = budget.Notes,
        };
        _errorMessage = null;
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _errorMessage = null;
    }

    private async Task SaveBudgetAsync()
    {
        _isSaving = true;
        _errorMessage = null;

        try
        {
            if (_editingBudgetId.HasValue)
            {
                var updated = await BudgetService.UpdateBudgetAsync(
                    _editingBudgetId.Value,
                    new UpdateBudgetRequest(_form.Amount, _form.Currency, _form.RolloverEnabled, _form.Notes)
                );

                if (updated is null)
                {
                    _errorMessage = "Failed to update budget.";
                    return;
                }
            }
            else
            {
                var created = await BudgetService.CreateBudgetAsync(
                    new CreateBudgetRequest(
                        Guid.Parse(_form.CategoryId),
                        _selectedYear,
                        _selectedMonth,
                        _form.Amount,
                        _form.Currency,
                        _form.RolloverEnabled,
                        _form.Notes
                    )
                );

                if (created is null)
                {
                    _errorMessage = "Failed to create budget. It may already exist for this category and period.";
                    return;
                }
            }

            _showForm = false;
            await LoadDataAsync();
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task DeleteBudgetAsync(Guid id)
    {
        await BudgetService.DeleteBudgetAsync(id);
        await LoadDataAsync();
    }

    private string BuildRemainingDetail() =>
        TotalRemaining >= 0m ? "Headroom left before the month goes negative." : "Current spend has already exhausted the month.";

    private string BuildOverBudgetDetail() =>
        OverBudgetCount == 0 ? "No categories are over budget right now." : "Categories needing immediate intervention.";

    private string BuildRolloverDetail()
    {
        var rolloverCount = _budgets.Count(budget => budget.RolloverEnabled);
        return rolloverCount == 0
            ? "No definitions are carrying exposure into the next month."
            : $"{rolloverCount} definition{(rolloverCount == 1 ? string.Empty : "s")} can carry unused balances forward.";
    }

    private string BuildCategorySubline(BudgetSummaryResponse summary)
    {
        if (summary.IsOverBudget)
        {
            return "Over budget and needs action.";
        }

        if (summary.PercentageUsed >= 85m)
        {
            return "Approaching limit this month.";
        }

        return "Within budget target.";
    }

    private static string GetStatusLabel(BudgetSummaryResponse summary)
    {
        if (summary.IsOverBudget)
        {
            return "Over budget";
        }

        if (summary.PercentageUsed >= 85m)
        {
            return "At risk";
        }

        return "On track";
    }

    private static string GetStatusClass(BudgetSummaryResponse summary) =>
        summary.IsOverBudget
            ? "budgets-status budgets-status--risk"
            : summary.PercentageUsed >= 85m
                ? "budgets-status budgets-status--warning"
                : "budgets-status budgets-status--ok";

    private static string BuildPressureMeterStyle(BudgetSummaryResponse summary)
    {
        var clamped = Math.Min(summary.PercentageUsed, 100m);
        var tone = summary.IsOverBudget ? "var(--danger-soft)" : summary.PercentageUsed >= 85m ? "#8b661f" : "var(--accent-strong)";
        return $"width: {clamped:F0}%; background: {tone};";
    }

    private List<BudgetAlert> BuildPressureItems()
    {
        var items = new List<BudgetAlert>();

        foreach (var summary in OrderedSummaries.Where(summary => summary.IsOverBudget).Take(3))
        {
            items.Add(new(summary.CategoryName, $"{FormatMoney(Math.Abs(summary.RemainingAmount), summary.Currency)} over the monthly limit.", "risk"));
        }

        foreach (var summary in OrderedSummaries.Where(summary => !summary.IsOverBudget && summary.PercentageUsed >= 85m).Take(3))
        {
            items.Add(new(summary.CategoryName, $"{summary.PercentageUsed:F0}% used with {FormatMoney(summary.RemainingAmount, summary.Currency)} left.", "warning"));
        }

        var budgetedCategoryIds = _budgets.Select(budget => budget.CategoryId).ToHashSet();
        foreach (var category in OrderedCategories.Where(category => !budgetedCategoryIds.Contains(category.Id)).Take(3))
        {
            items.Add(new(category.Name, "Activity can land here without a budget definition for the selected month.", "warning"));
        }

        if (items.Count == 0)
        {
            items.Add(new("No acute pressure", "The month is currently tracking without over-budget or missing-budget exceptions.", "ok"));
        }

        return items.Take(6).ToList();
    }

    private static UiSeverity ToSeverity(string tone) => tone switch
    {
        "risk" => UiSeverity.Urgent,
        "warning" => UiSeverity.Advisory,
        _ => UiSeverity.Informational,
    };

    private string FormatMoney(decimal amount, string? currency = null) => $"{amount:C} {currency ?? PrimaryCurrency}";

    private sealed record BudgetAlert(string Title, string Detail, string Tone);
}
