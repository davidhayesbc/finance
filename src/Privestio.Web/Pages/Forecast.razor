@page "/forecast"
@inject INotificationWebService NotificationService

<PageTitle>Forecast — Privestio</PageTitle>

<section class="page-shell forecast-shell" data-testid="forecast-page">
    <PageRegion Name="orientation" Class="forecast-orientation">
        <PageHeader Eyebrow="Forecast" Title="Forecast"
                    Description="Project balances from recurring income, expenses, budgets, and sinking-fund contributions."
                    UtilityDescription="Keep one horizon selector in view and reserve the action lane for the highest-value refresh.">
            <Context>
                <div>
                    <span class="filter-label">Horizon</span>
                    <div class="action-cluster">
                        @foreach (var horizon in HorizonOptions)
                        {
                            <FluentButton Appearance="@GetHorizonAppearance(horizon)" OnClick="() => ChangeHorizonAsync(horizon)">
                                @GetHorizonLabel(horizon)
                            </FluentButton>
                        }
                    </div>
                </div>
            </Context>
            <Actions>
                <FluentButton Appearance="Appearance.Outline" OnClick="LoadForecastAsync">Refresh</FluentButton>
            </Actions>
        </PageHeader>
    </PageRegion>

    <PageRegion Name="supporting" Class="forecast-posture" aria-labelledby="forecast-posture-title">
        <PostureStrip Title="Forecast posture"
                      TitleId="forecast-posture-title"
                      Description="Summarize the selected horizon before reading the trajectory itself."
                      HeaderClass="forecast-section-heading"
                      GridClass="forecast-posture__grid">

        @if (_isLoading)
        {
            <LoadingSurface Variant="posture" Columns="5" />
        }
        else
        {
                <article class="forecast-posture__item">
                    <span>Total projected income</span>
                    <strong>@FormatMoney(TotalProjectedIncome)</strong>
                    <p>Incoming cash across @Periods.Count projected month@(Periods.Count == 1 ? string.Empty : "s").</p>
                </article>
                <article class="forecast-posture__item">
                    <span>Total projected expenses</span>
                    <strong>@FormatMoney(TotalProjectedExpenses)</strong>
                    <p>Recurring outflow plus budget and sinking-fund pressure.</p>
                </article>
                <article class="forecast-posture__item">
                    <span>Net projected</span>
                    <strong class="@(NetProjected >= 0m ? "forecast-posture__value--gain" : "forecast-posture__value--risk")">@FormatMoney(NetProjected)</strong>
                    <p>@BuildNetDetail()</p>
                </article>
                <article class="forecast-posture__item">
                    <span>End balance</span>
                    <strong>@FormatMoney(EndBalance)</strong>
                    <p>@BuildEndBalanceDetail()</p>
                </article>
                <article class="forecast-posture__item">
                    <span>Lowest projected balance</span>
                    <strong class="@(LowestProjectedBalance >= 0m ? string.Empty : "forecast-posture__value--risk")">@FormatMoney(LowestProjectedBalance)</strong>
                    <p>@BuildLowestBalanceDetail()</p>
                </article>
        }
        </PostureStrip>
    </PageRegion>

    <div class="forecast-core-grid">
        <PageRegion Name="primary" Class="forecast-plane" aria-labelledby="forecast-plane-title">
            <ChartFrame Title="Projection"
                        TitleId="forecast-plane-title"
                        Description="The balance trajectory owns the page and marks the months that matter."
                        Meta="@GetHorizonLabel(_months)"
                        HeaderClass="forecast-section-heading forecast-section-heading--split"
                        CanvasClass="forecast-plane__canvas"
                        IsLoading="@_isLoading"
                        IsEmpty="@(Periods.Count == 0)"
                        EmptyTitle="No projection data is available yet."
                        EmptyMessage="Add recurring transactions and budgets to generate a balance trajectory.">
                    <svg class="forecast-plane__svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                        @if (ZeroLineY.HasValue)
                        {
                            <line x1="0" y1="@FormatNumber(ZeroLineY.Value)" x2="100" y2="@FormatNumber(ZeroLineY.Value)" class="forecast-plane__zero-line"></line>
                        }
                        <polyline points="@ProjectionPolyline" class="forecast-plane__polyline"></polyline>
                    </svg>

                    @foreach (var marker in ProjectionMarkers)
                    {
                        <article class="@GetProjectionMarkerClass(marker.Tone)" style="@BuildProjectionMarkerStyle(marker)" title="@marker.Tooltip">
                            <span class="forecast-plane__marker-dot"></span>
                            <span class="forecast-plane__marker-label">@marker.Label</span>
                        </article>
                    }
            </ChartFrame>
        </PageRegion>

        <PageRegion Name="exceptions" Class="forecast-drivers" aria-labelledby="forecast-drivers-title">
            <SectionBand Title="Drivers"
                         TitleId="forecast-drivers-title"
                         Description="Explain why the line bends instead of leaving the trajectory as a black box."
                         HeaderClass="forecast-section-heading">

            <div class="forecast-driver__list">
                @foreach (var driver in DriverItems)
                {
                    <article class="@GetDriverClass(driver.Tone)">
                        <strong>@driver.Title</strong>
                        <p>@driver.Detail</p>
                    </article>
                }
            </div>
            </SectionBand>
        </PageRegion>
    </div>

    <PageRegion Name="supporting" Class="forecast-ledger" aria-labelledby="forecast-ledger-title">
        <SectionBand Title="Monthly periods"
                     TitleId="forecast-ledger-title"
                     Description="Keep the audit trail directly below the projection plane."
                     Meta="Base projection"
                     HeaderClass="forecast-section-heading forecast-section-heading--split">

        <DenseTableSurface IsLoading="@_isLoading"
                           IsEmpty="@(Periods.Count == 0)"
                           LoadingRows="6"
                           LoadingColumns="7"
                           EmptyTitle="No forecast ledger exists for this horizon."
                           EmptyMessage="The projection plane and ledger will populate once forecast inputs are available.">
            <div class="forecast-table-wrap table-surface table-surface--native">
                <table class="forecast-table">
                    <thead>
                        <tr>
                            <th scope="col">Period</th>
                            <th scope="col" class="forecast-table__numeric">Income</th>
                            <th scope="col" class="forecast-table__numeric">Expenses</th>
                            <th scope="col" class="forecast-table__numeric">Budgeted</th>
                            <th scope="col" class="forecast-table__numeric">Sinking funds</th>
                            <th scope="col" class="forecast-table__numeric">Net</th>
                            <th scope="col" class="forecast-table__numeric">Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var period in Periods)
                        {
                            <tr>
                                <td>@(new DateTime(period.Year, period.Month, 1).ToString("MMM yyyy"))</td>
                                <td class="forecast-table__numeric">@FormatMoney(period.ProjectedIncome)</td>
                                <td class="forecast-table__numeric">@FormatMoney(period.ProjectedExpenses)</td>
                                <td class="forecast-table__numeric">@FormatMoney(period.BudgetedExpenses)</td>
                                <td class="forecast-table__numeric">@FormatMoney(period.SinkingFundContributions)</td>
                                <td class="forecast-table__numeric">
                                    <span class="@GetNetClass(period.ProjectedNet)">@FormatMoney(period.ProjectedNet)</span>
                                </td>
                                <td class="forecast-table__numeric"><strong>@FormatMoney(period.ProjectedBalance)</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </DenseTableSurface>
        </SectionBand>
    </PageRegion>
</section>

@code {
    private static readonly IReadOnlyList<int> HorizonOptions = [3, 6, 12, 24];
    private CashFlowForecastResponse? _forecast;
    private bool _isLoading = true;
    private int _months = 6;

    private IReadOnlyList<CashFlowPeriod> Periods => _forecast?.Periods ?? [];

    private decimal TotalProjectedIncome => Periods.Sum(period => period.ProjectedIncome);

    private decimal TotalProjectedExpenses => Periods.Sum(period => period.ProjectedExpenses);

    private decimal NetProjected => Periods.Sum(period => period.ProjectedNet);

    private decimal EndBalance => Periods.LastOrDefault()?.ProjectedBalance ?? 0m;

    private decimal LowestProjectedBalance => Periods.Count == 0 ? 0m : Periods.Min(period => period.ProjectedBalance);

    private string Currency => _forecast?.Currency ?? "CAD";

    private string ProjectionPolyline => BuildProjectionPolyline();

    private decimal? ZeroLineY => BuildZeroLineY();

    private List<ProjectionMarker> ProjectionMarkers => BuildProjectionMarkers();

    private List<ForecastDriver> DriverItems => BuildDriverItems();

    protected override async Task OnInitializedAsync()
    {
        await LoadForecastAsync();
    }

    private async Task LoadForecastAsync()
    {
        _isLoading = true;

        try
        {
            _forecast = await NotificationService.GetCashFlowForecastAsync(_months);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ChangeHorizonAsync(int months)
    {
        if (_months == months)
        {
            return;
        }

        _months = months;
        await LoadForecastAsync();
    }

    private Appearance GetHorizonAppearance(int months) => _months == months ? Appearance.Accent : Appearance.Outline;

    private static string GetHorizonLabel(int months) => months == 1 ? "1 month" : $"{months} months";

    private string BuildNetDetail() =>
        NetProjected >= 0m ? "The horizon stays net positive on current assumptions." : "Projected outflow exceeds projected inflow across the selected horizon.";

    private string BuildEndBalanceDetail() =>
        Periods.Count == 0 ? "No end-period balance yet." : $"Ends in {new DateTime(Periods.Last().Year, Periods.Last().Month, 1):MMMM yyyy}.";

    private string BuildLowestBalanceDetail()
    {
        if (Periods.Count == 0)
        {
            return "No low point exists without a forecast horizon.";
        }

        var lowPoint = Periods.OrderBy(period => period.ProjectedBalance).First();
        return $"Lowest point arrives in {new DateTime(lowPoint.Year, lowPoint.Month, 1):MMMM yyyy}.";
    }

    private string BuildProjectionPolyline()
    {
        if (Periods.Count == 0)
        {
            return string.Empty;
        }

        var min = Periods.Min(period => period.ProjectedBalance);
        var max = Periods.Max(period => period.ProjectedBalance);
        min = Math.Min(min, 0m);
        max = Math.Max(max, 0m);
        var range = max - min;
        if (range == 0m)
        {
            range = 1m;
        }

        var points = Periods.Select((period, index) =>
        {
            var x = Periods.Count == 1 ? 50m : index * 100m / (Periods.Count - 1);
            var y = 100m - ((period.ProjectedBalance - min) / range * 100m);
            return $"{FormatNumber(x)},{FormatNumber(y)}";
        });

        return string.Join(" ", points);
    }

    private decimal? BuildZeroLineY()
    {
        if (Periods.Count == 0)
        {
            return null;
        }

        var min = Periods.Min(period => period.ProjectedBalance);
        var max = Periods.Max(period => period.ProjectedBalance);
        if (min >= 0m || max <= 0m)
        {
            return null;
        }

        var range = max - min;
        return 100m - ((0m - min) / range * 100m);
    }

    private List<ProjectionMarker> BuildProjectionMarkers()
    {
        if (Periods.Count == 0)
        {
            return [];
        }

        var min = Periods.Min(period => period.ProjectedBalance);
        var max = Periods.Max(period => period.ProjectedBalance);
        min = Math.Min(min, 0m);
        max = Math.Max(max, 0m);
        var range = max - min;
        if (range == 0m)
        {
            range = 1m;
        }

        return Periods.Select((period, index) =>
        {
            var left = Periods.Count == 1 ? 50m : index * 100m / (Periods.Count - 1);
            var top = 100m - ((period.ProjectedBalance - min) / range * 100m);
            var tone = period.ProjectedBalance < 0m || period.ProjectedNet < 0m ? "risk" : "ok";
            return new ProjectionMarker(
                left,
                top,
                new DateTime(period.Year, period.Month, 1).ToString("MMM"),
                $"{new DateTime(period.Year, period.Month, 1):MMMM yyyy}: {FormatMoney(period.ProjectedBalance)} balance",
                tone
            );
        }).ToList();
    }

    private List<ForecastDriver> BuildDriverItems()
    {
        if (Periods.Count == 0)
        {
            return [new("No drivers yet", "Add forecast inputs to surface pressure months and turning points.", "ok")];
        }

        var items = new List<ForecastDriver>();

        var mostExpensive = Periods.OrderByDescending(period => period.ProjectedExpenses).First();
        items.Add(new(
            "Largest expense pressure",
            $"{new DateTime(mostExpensive.Year, mostExpensive.Month, 1):MMMM yyyy} carries the heaviest projected expense load at {FormatMoney(mostExpensive.ProjectedExpenses)}.",
            "warning"
        ));

        var negativeMonths = Periods.Where(period => period.ProjectedNet < 0m).ToList();
        if (negativeMonths.Count > 0)
        {
            var firstNegative = negativeMonths.First();
            items.Add(new(
                "Negative net months",
                $"{negativeMonths.Count} projected month{(negativeMonths.Count == 1 ? string.Empty : "s")} go net negative, starting in {new DateTime(firstNegative.Year, firstNegative.Month, 1):MMMM yyyy}.",
                "risk"
            ));
        }

        var sinkingPeak = Periods.OrderByDescending(period => period.SinkingFundContributions).First();
        items.Add(new(
            "Sinking-fund spike",
            $"Peak sinking-fund pressure lands in {new DateTime(sinkingPeak.Year, sinkingPeak.Month, 1):MMMM yyyy} at {FormatMoney(sinkingPeak.SinkingFundContributions)}.",
            sinkingPeak.SinkingFundContributions > 0m ? "warning" : "ok"
        ));

        var incomeShift = Periods.OrderByDescending(period => period.ProjectedIncome).First();
        items.Add(new(
            "Income high point",
            $"Projected income is strongest in {new DateTime(incomeShift.Year, incomeShift.Month, 1):MMMM yyyy} at {FormatMoney(incomeShift.ProjectedIncome)}.",
            "ok"
        ));

        return items.Take(4).ToList();
    }

    private static string GetDriverClass(string tone) => tone switch
    {
        "risk" => "forecast-driver forecast-driver--risk",
        "warning" => "forecast-driver forecast-driver--warning",
        "ok" => "forecast-driver forecast-driver--ok",
        _ => "forecast-driver",
    };

    private static string GetProjectionMarkerClass(string tone) => tone switch
    {
        "risk" => "forecast-plane__marker forecast-plane__marker--risk",
        _ => "forecast-plane__marker",
    };

    private static string BuildProjectionMarkerStyle(ProjectionMarker marker) => $"left: calc({FormatNumber(marker.Left)}% - 7px); top: calc({FormatNumber(marker.Top)}% - 7px);";

    private static string GetNetClass(decimal net) => net >= 0m ? "forecast-net forecast-net--gain" : "forecast-net forecast-net--risk";

    private string FormatMoney(decimal amount) => $"{amount:C} {Currency}";

    private static string FormatNumber(decimal value) => value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private sealed record ProjectionMarker(decimal Left, decimal Top, string Label, string Tooltip, string Tone);

    private sealed record ForecastDriver(string Title, string Detail, string Tone);
}
