@page "/rules/ai"
@inject IAccountService AccountService
@inject ICategoryService CategoryService
@inject IImportService ImportService
@inject NavigationManager Navigation

<PageTitle>AI Rule Suggestions — Privestio</PageTitle>

<section class="page-shell panel-stack" data-testid="ai-rule-suggestions-page">
    <PageHeader Eyebrow="Rules" Title="AI rule suggestions"
                Description="Select an account with uncategorized transactions and let the AI engine suggest reusable categorization rules."
                Compact="true">
        <Actions>
            <FluentButton Appearance="Appearance.Outline" OnClick="@(() => Navigation.NavigateTo("/rules"))">
                Manual Rules
            </FluentButton>
        </Actions>
    </PageHeader>

    <MessageStack ErrorMessage="@_errorMessage" SuccessMessage="@_successMessage" />

    @if (_isLoading)
    {
        <LoadingSpinner AriaLabel="Loading accounts with uncategorized transactions" />
    }
    else if (_rows.Count == 0)
    {
        <EmptyStateCard Message="No uncategorized transactions detected across your accessible accounts." />
    }
    else
    {
        <FluentCard Class="surface-card data-card">
            <FluentDataGrid Items="_rows.AsQueryable()"
                            aria-label="Accounts with uncategorized transactions"
                            TGridItem="AccountUncategorizedRow"
                            Class="data-grid--elevated"
                            ResizableColumns="true"
                            ResizeType="DataGridResizeType.Discrete"
                            HeaderCellAsButtonWithMenu="true"
                            ResizeColumnOnAllRows="false"
                            ShowHover="true"
                            DisplayMode="DataGridDisplayMode.Table"
                            RowSize="DataGridRowSize.Medium">
                <TemplateColumn Title="Account" SortBy="@(GridSort<AccountUncategorizedRow>.ByAscending(r => r.AccountName))" Width="260px">
                    <span class="cell-truncate" title="@context.AccountName">@context.AccountName</span>
                </TemplateColumn>
                <PropertyColumn Property="@(r => r.AccountType)" Title="Type" Width="160px" />
                <PropertyColumn Property="@(r => r.Institution)" Title="Institution" Width="220px" />
                <PropertyColumn Property="@(r => r.UncategorizedCount)" Title="Uncategorized" Width="130px" />
                <TemplateColumn Title="Actions" Width="220px">
                    <FluentButton Appearance="Appearance.Accent"
                                  Disabled="@(_isSuggesting && _selectedAccountId == context.AccountId)"
                                  OnClick="@(() => SelectAccountAsync(context.AccountId, context.AccountName))">
                        Suggest Rules (AI)
                    </FluentButton>
                </TemplateColumn>
            </FluentDataGrid>
        </FluentCard>

        @if (_selectedAccountId.HasValue)
        {
            <section class="import-stage" aria-label="AI suggestions for @_selectedAccountName">
                <div class="import-section-heading import-section-heading--split">
                    <div>
                        <h2>Suggestions for @_selectedAccountName</h2>
                        <p>Review each suggestion, assign a category and apply scope, then accept to create the rule.</p>
                    </div>
                    <FluentButton Appearance="Appearance.Stealth"
                                  Loading="@_isSuggesting"
                                  Disabled="@_isSuggesting"
                                  OnClick="@RefreshSuggestionsAsync">
                        @(_isSuggesting ? "Generating…" : "Regenerate")
                    </FluentButton>
                </div>

                @if (_isSuggesting)
                {
                    <LoadingSpinner AriaLabel="Asking AI for rule suggestions" />
                }
                else if (_ruleSuggestions.Count == 0)
                {
                    <EmptyStateCard Message="No suggestions returned. The account may not have enough varied uncategorized transactions yet." />
                }
                else
                {
                    <FluentDataGrid Items="_ruleSuggestions.AsQueryable()"
                                    aria-label="AI rule suggestions"
                                    TGridItem="RuleSuggestionResponse"
                                    Class="data-grid--elevated"
                                    ShowHover="true"
                                    DisplayMode="DataGridDisplayMode.Table"
                                    RowSize="DataGridRowSize.Large">
                        <PropertyColumn Property="@(r => r.Name)" Title="Rule Name" Width="220px" />
                        <PropertyColumn Property="@(r => r.SuggestedCategoryName)" Title="Suggested Category" Width="200px" />
                        <PropertyColumn Property="@(r => r.Rationale)" Title="Rationale" Width="300px" />
                        <PropertyColumn Property="@(r => r.MatchCount)" Title="Matches" Width="90px" />
                        <PropertyColumn Property="@(r => r.MatchRate)" Title="Match Rate" Format="P1" Width="110px" />
                        <TemplateColumn Title="Accept" Width="360px">
                            <FluentStack Orientation="Orientation.Horizontal" Class="grid-actions grid-actions--compact">
                                <FluentSelect TOption="string"
                                              Value="@GetSelectedCategoryId(context)"
                                              ValueChanged="@(value => SetSelectedCategoryId(context, value))"
                                              Width="200px"
                                              AriaLabel="Select category for accepted rule">
                                    <FluentOption TOption="string" Value="">Select category</FluentOption>
                                    @foreach (var category in _categories.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase))
                                    {
                                        <FluentOption TOption="string" Value="@category.Id.ToString()">@category.Name</FluentOption>
                                    }
                                </FluentSelect>
                                <FluentSelect TOption="string"
                                              Value="@GetSelectedApplyScope(context)"
                                              ValueChanged="@(value => SetSelectedApplyScope(context, value))"
                                              Width="200px"
                                              AriaLabel="Select apply scope for accepted rule">
                                    <FluentOption TOption="string" Value="AllMatching">All matching</FluentOption>
                                    <FluentOption TOption="string" Value="UncategorizedOnly">Uncategorized only</FluentOption>
                                </FluentSelect>
                                <FluentButton Appearance="Appearance.Accent"
                                              Disabled="@(_isAccepting || !CanAcceptSuggestion(context))"
                                              Loading="@_isAccepting"
                                              OnClick="@(() => AcceptSuggestionAsync(context))">
                                    Accept
                                </FluentButton>
                            </FluentStack>
                        </TemplateColumn>
                    </FluentDataGrid>
                }
            </section>
        }
    }
</section>

@code {
    private readonly List<AccountUncategorizedRow> _rows = [];
    private readonly List<RuleSuggestionResponse> _ruleSuggestions = [];
    private readonly Dictionary<string, string> _selectedCategoryBySuggestion = new(StringComparer.Ordinal);
    private readonly Dictionary<string, string> _selectedApplyScopeBySuggestion = new(StringComparer.Ordinal);
    private List<CategoryResponse> _categories = [];

    private bool _isLoading = true;
    private bool _isSuggesting;
    private bool _isAccepting;
    private string? _errorMessage;
    private string? _successMessage;

    private Guid? _selectedAccountId;
    private string _selectedAccountName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var accountsTask = AccountService.GetAccountsAsync();
            var countsTask = AccountService.GetUncategorizedCountsAsync();
            var categoriesTask = CategoryService.GetCategoriesAsync();

            await Task.WhenAll(accountsTask, countsTask, categoriesTask);

            var accounts = accountsTask.Result;
            var countByAccountId = countsTask.Result.ToDictionary(c => c.AccountId, c => c.UncategorizedCount);
            _categories = categoriesTask.Result.ToList();

            _rows.Clear();
            _rows.AddRange(
                accounts
                    .Select(account =>
                    {
                        var count = countByAccountId.GetValueOrDefault(account.Id, 0);
                        return new AccountUncategorizedRow(
                            account.Id,
                            account.Name,
                            account.AccountType,
                            string.IsNullOrWhiteSpace(account.Institution) ? "-" : account.Institution,
                            count
                        );
                    })
                    .Where(row => row.UncategorizedCount > 0)
                    .OrderByDescending(row => row.UncategorizedCount)
                    .ThenBy(row => row.AccountName, StringComparer.OrdinalIgnoreCase)
            );
        }
        catch
        {
            _errorMessage = "Unable to load account categorization posture.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectAccountAsync(Guid accountId, string accountName)
    {
        _selectedAccountId = accountId;
        _selectedAccountName = accountName;
        _ruleSuggestions.Clear();
        _selectedCategoryBySuggestion.Clear();
        _selectedApplyScopeBySuggestion.Clear();
        _errorMessage = null;
        _successMessage = null;
        await RefreshSuggestionsAsync();
    }

    private async Task RefreshSuggestionsAsync()
    {
        if (_selectedAccountId is null)
            return;

        _isSuggesting = true;
        _errorMessage = null;
        _successMessage = null;
        StateHasChanged();

        var results = await ImportService.SuggestRulesFromDbAsync(_selectedAccountId.Value, maxSuggestions: 8);
        _ruleSuggestions.Clear();
        _ruleSuggestions.AddRange(results);
        _selectedCategoryBySuggestion.Clear();
        _selectedApplyScopeBySuggestion.Clear();

        if (_ruleSuggestions.Count == 0)
            _errorMessage = "No rule suggestions were returned by the AI. Try after importing more transactions.";
        else
            _successMessage = $"Generated {_ruleSuggestions.Count} suggested rule(s).";

        _isSuggesting = false;
    }

    private async Task AcceptSuggestionAsync(RuleSuggestionResponse suggestion)
    {
        if (_selectedAccountId is null)
            return;

        var selectedCategoryId = GetSelectedCategoryId(suggestion);
        if (!Guid.TryParse(selectedCategoryId, out var categoryId))
        {
            _errorMessage = "Select a category before accepting the suggestion.";
            return;
        }

        _isAccepting = true;
        _errorMessage = null;
        _successMessage = null;

        var request = new AcceptRuleSuggestionRequest
        {
            Name = suggestion.Name,
            Priority = suggestion.Priority,
            Conditions = suggestion.Conditions,
            CategoryId = categoryId,
            IsEnabled = true,
            ApplyScope = ParseApplyScope(GetSelectedApplyScope(suggestion)),
        };

        var result = await ImportService.AcceptSuggestedRuleAsync(_selectedAccountId.Value, request);
        if (result is null)
        {
            _errorMessage = "Failed to accept and apply the suggested rule.";
            _isAccepting = false;
            return;
        }

        _ruleSuggestions.Remove(suggestion);
        _selectedCategoryBySuggestion.Remove(GetSuggestionKey(suggestion));
        _selectedApplyScopeBySuggestion.Remove(GetSuggestionKey(suggestion));
        _successMessage = $"Rule \"{result.Rule.Name}\" created and applied to {result.AppliedTransactionCount} transaction(s).";
        _isAccepting = false;
    }

    private static string GetSuggestionKey(RuleSuggestionResponse suggestion) => suggestion.Name;

    private string GetSelectedCategoryId(RuleSuggestionResponse suggestion) =>
        _selectedCategoryBySuggestion.GetValueOrDefault(GetSuggestionKey(suggestion), string.Empty);

    private void SetSelectedCategoryId(RuleSuggestionResponse suggestion, string value) =>
        _selectedCategoryBySuggestion[GetSuggestionKey(suggestion)] = value;

    private string GetSelectedApplyScope(RuleSuggestionResponse suggestion) =>
        _selectedApplyScopeBySuggestion.GetValueOrDefault(GetSuggestionKey(suggestion), "AllMatching");

    private void SetSelectedApplyScope(RuleSuggestionResponse suggestion, string value) =>
        _selectedApplyScopeBySuggestion[GetSuggestionKey(suggestion)] = value;

    private bool CanAcceptSuggestion(RuleSuggestionResponse suggestion) =>
        Guid.TryParse(GetSelectedCategoryId(suggestion), out _);

    private static RuleApplyScope ParseApplyScope(string value) =>
        value == "UncategorizedOnly" ? RuleApplyScope.UncategorizedOnly : RuleApplyScope.AllMatching;

    private sealed record AccountUncategorizedRow(
        Guid AccountId,
        string AccountName,
        string AccountType,
        string Institution,
        int UncategorizedCount
    );
}
