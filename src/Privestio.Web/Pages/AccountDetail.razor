@page "/accounts/{Id:guid}"
@inject IAccountService AccountService
@inject IPriceHistoryService PriceHistoryService
@inject IPortfolioService PortfolioService
@inject ITransactionService TransactionService
@inject NavigationManager Navigation

<PageTitle>@(_account?.Name ?? "Account") — Privestio</PageTitle>

@if (_isLoading)
{
    <LoadingSpinner AriaLabel="Loading account details" Class="page-shell" />
}
else if (_account is null)
{
    <section class="page-shell account-dossier-shell">
        <section class="account-dossier-orientation">
            <PageHeader Eyebrow="Account dossier" Title="Account not found"
                        Description="The requested account could not be loaded, but the dossier shell stays intact so you can recover context.">
                <Actions>
                    <FluentButton Appearance="Appearance.Outline" @onclick="@(() => Navigation.NavigateTo("/accounts"))">
                        Back to Accounts
                    </FluentButton>
                </Actions>
            </PageHeader>
        </section>
    </section>
}
else
{
    <section class="page-shell account-dossier-shell" aria-labelledby="account-name" data-testid="account-detail-page">
        <section class="account-dossier-orientation">
            <PageHeader Eyebrow="Account dossier" Title="@_account.Name"
                        Description="Review identity, value history, and the supporting evidence for this account without leaving the dossier frame."
                        Compact="true">
                <Actions>
                    <div class="action-cluster">
                        <FluentButton Appearance="Appearance.Outline" @onclick="@(() => Navigation.NavigateTo("/accounts"))">
                            Back to Accounts
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Accent"
                                      @onclick="@(() => Navigation.NavigateTo($"/accounts/{Id}/transactions/new"))"
                                      aria-label="Add a transaction to this account">
                            Add Transaction
                        </FluentButton>
                        @if (IsInvestmentAccount)
                        {
                            <FluentButton Appearance="Appearance.Outline"
                                          Loading="_isSyncingHistoricalPrices"
                                          @onclick="SyncHistoricalPricesAsync"
                                          aria-label="Sync historical prices from Yahoo Finance">
                                Sync Market History
                            </FluentButton>
                        }
                    </div>
                </Actions>
            </PageHeader>
        </section>

        <section class="account-dossier-identity" aria-labelledby="account-identity-title">
            <div class="account-dossier-heading">
                <h2 id="account-identity-title">Identity</h2>
                <p>Core account facts first, so the rest of the dossier reads in context.</p>
            </div>

            <div class="account-dossier-identity__grid">
                <article class="account-dossier-identity__item">
                    <span>Type</span>
                    <strong>@_account.AccountType</strong>
                    <p>@(string.IsNullOrWhiteSpace(_account.AccountSubType) ? "No subtype recorded." : _account.AccountSubType)</p>
                </article>
                <article class="account-dossier-identity__item">
                    <span>Institution</span>
                    <strong>@FormatInstitution()</strong>
                    <p>@BuildOwnershipDetail()</p>
                </article>
                <article class="account-dossier-identity__item">
                    <span>Current balance</span>
                    <strong>@FormatMoney(GetDisplayedCurrentBalance())</strong>
                    <p>@BuildBalanceDetail()</p>
                </article>
                <article class="account-dossier-identity__item">
                    <span>Opened</span>
                    <strong>@_account.OpeningDate.ToString("MMM d, yyyy")</strong>
                    <p>@BuildFreshnessDetail()</p>
                </article>
            </div>
        </section>

        <section class="account-dossier-history" aria-labelledby="account-history-title">
            <div class="account-dossier-heading account-dossier-heading--split">
                <div>
                    <h2 id="account-history-title">History</h2>
                    <p>@(IsInvestmentAccount ? "Market value growth built from holdings and persisted prices." : "Account value history built from recorded activity and stored balances.")</p>
                </div>
                <HistoryRangeSelector CurrentKey="@_selectedValueHistoryRange"
                                      Disabled="@(_isLoadingValueHistory || _isSyncingHistoricalPrices)"
                                      OnChange="HandleValueHistoryRangeChangedAsync" />
            </div>

            @if (!string.IsNullOrWhiteSpace(_historicalPriceSyncMessage))
            {
                <FluentMessageBar Intent="@_historicalPriceSyncIntent">@_historicalPriceSyncMessage</FluentMessageBar>
            }

            @if (_isLoadingValueHistory)
            {
                <LoadingSpinner AriaLabel="Loading account value history" />
            }
            else if (!string.IsNullOrWhiteSpace(_valueHistoryErrorMessage))
            {
                <FluentMessageBar Intent="@MessageIntent.Warning">@_valueHistoryErrorMessage</FluentMessageBar>
            }
            else if (_valueHistory is not null)
            {
                <HistoricalValueChart Points="_valueHistory.Points"
                                      SeriesName="@_valueHistory.Label"
                                      EmptyTitle="No historical values yet."
                                      EmptyMessage="Record transactions, valuations, or price history to build this chart." />
            }
        </section>

        <section class="account-dossier-evidence" aria-labelledby="account-evidence-title">
            <div class="account-dossier-heading">
                <h2 id="account-evidence-title">Evidence</h2>
                <p>Keep the supporting transactions, holdings, and property records below the history plane.</p>
            </div>

            @if (IsPropertyAccount)
            {
                <div class="account-dossier-evidence__stack">
                    <PropertyValuationsSection AccountId="Id" Currency="@_account.Currency"
                                               DefaultAmount="@(_account.CurrentBalance)"
                                               OnValuationSaved="HandleValuationSaved" />
                    <PropertyExpensesSection AccountId="Id" Currency="@_account.Currency" />
                    <MortgageAmortizationSection />
                </div>
            }
            else if (IsInvestmentAccount)
            {
                <div class="account-dossier-evidence__stack">
                    <PortfolioPerformanceSection Performance="_performance"
                                                 IsLoading="_isLoadingPerformance"
                                                 ErrorMessage="@_performanceErrorMessage" />
                    <HoldingsLotsSection AccountId="Id" OnAliasChanged="HandleAliasChanged" />
                    <InvestmentTransactionsSection Transactions="_transactions" IsLoading="_isLoadingTransactions" />
                </div>
            }
            else
            {
                <div class="account-dossier-evidence__stack">
                    <TransactionListSection AccountId="Id" />
                </div>
            }
        </section>
    </section>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private AccountResponse? _account;
    private AccountValueHistoryResponse? _valueHistory;
    private PortfolioPerformanceResponse? _performance;
    private readonly List<TransactionResponse> _transactions = new();

    private bool _isLoading = true;
    private bool _isLoadingValueHistory = true;
    private bool _isLoadingPerformance = true;
    private bool _isLoadingTransactions = true;
    private bool _isSyncingHistoricalPrices;

    private string? _valueHistoryErrorMessage;
    private string? _performanceErrorMessage;
    private string? _historicalPriceSyncMessage;
    private MessageIntent _historicalPriceSyncIntent = MessageIntent.Success;
    private string _selectedValueHistoryRange = "1y";

    private bool IsPropertyAccount =>
        _account?.AccountType.Equals("Property", StringComparison.OrdinalIgnoreCase) == true;

    private bool IsInvestmentAccount =>
        _account?.AccountType.Equals("Investment", StringComparison.OrdinalIgnoreCase) == true;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _account = await AccountService.GetAccountByIdAsync(Id);
        _isLoading = false;

        if (_account is not null)
        {
            if (IsPropertyAccount)
            {
                await LoadValueHistoryAsync();
            }
            else if (IsInvestmentAccount)
            {
                await Task.WhenAll(
                    LoadValueHistoryAsync(),
                    LoadPerformanceAsync(),
                    LoadInvestmentTransactionsAsync()
                );
            }
            else
            {
                await LoadValueHistoryAsync();
            }
        }
    }

    private async Task LoadValueHistoryAsync()
    {
        _isLoadingValueHistory = true;
        _valueHistoryErrorMessage = null;

        try
        {
            var (fromDate, toDate) = ResolveValueHistoryRange();
            _valueHistory = await AccountService.GetAccountValueHistoryAsync(Id, fromDate, toDate);
            if (_valueHistory is null)
                _valueHistoryErrorMessage = "Account value history could not be loaded right now.";
        }
        catch
        {
            _valueHistory = null;
            _valueHistoryErrorMessage = "Account value history could not be loaded right now.";
        }
        finally
        {
            _isLoadingValueHistory = false;
        }
    }

    private async Task HandleValueHistoryRangeChangedAsync(string rangeKey)
    {
        _selectedValueHistoryRange = rangeKey;
        await LoadValueHistoryAsync();
    }

    private async Task SyncHistoricalPricesAsync()
    {
        _isSyncingHistoricalPrices = true;
        _historicalPriceSyncMessage = null;

        try
        {
            var result = await PriceHistoryService.SyncHistoricalPricesAsync();
            if (result is null)
            {
                _historicalPriceSyncIntent = MessageIntent.Error;
                _historicalPriceSyncMessage = "Historical price sync failed.";
                return;
            }

            _historicalPriceSyncIntent = MessageIntent.Success;
            _historicalPriceSyncMessage = $"Historical price sync complete. Inserted {result.QuotesInserted} quotes and skipped {result.QuotesSkipped}.";
            await Task.WhenAll(LoadValueHistoryAsync(), LoadPerformanceAsync());
        }
        finally
        {
            _isSyncingHistoricalPrices = false;
        }
    }

    private (DateOnly? FromDate, DateOnly ToDate) ResolveValueHistoryRange()
    {
        var toDate = DateOnly.FromDateTime(DateTime.UtcNow);
        return _selectedValueHistoryRange switch
        {
            "90d" => (toDate.AddDays(-89), toDate),
            "1y" => (toDate.AddYears(-1), toDate),
            "all" => (_account?.OpeningDate, toDate),
            _ => (toDate.AddYears(-1), toDate),
        };
    }

    private async Task LoadPerformanceAsync()
    {
        _isLoadingPerformance = true;
        _performanceErrorMessage = null;

        try
        {
            _performance = await PortfolioService.GetPerformanceAsync(Id);
            if (_performance is null)
                _performanceErrorMessage = "Portfolio performance could not be loaded right now.";
        }
        catch
        {
            _performance = null;
            _performanceErrorMessage = "Portfolio performance could not be loaded right now.";
        }
        finally
        {
            _isLoadingPerformance = false;
        }
    }

    private async Task LoadInvestmentTransactionsAsync()
    {
        _isLoadingTransactions = true;

        try
        {
            var fromDate = DateTime.Today.AddDays(-90);
            var result = await TransactionService.GetTransactionsAsync(
                Id,
                pageSize: 15,
                fromDate: fromDate,
                toDate: DateTime.Today
            );

            _transactions.Clear();
            _transactions.AddRange(result.Items);
        }
        catch
        {
            _transactions.Clear();
        }
        finally
        {
            _isLoadingTransactions = false;
        }
    }

    private decimal GetDisplayedCurrentBalance()
    {
        if (IsInvestmentAccount && _performance?.TotalMarketValue is { } marketValue)
            return marketValue;

        return _account?.CurrentBalance ?? 0m;
    }

    private async Task HandleValuationSaved()
    {
        await LoadValueHistoryAsync();
    }

    private async Task HandleAliasChanged()
    {
        await LoadPerformanceAsync();
    }

    private string FormatInstitution() =>
        string.IsNullOrWhiteSpace(_account?.Institution) ? "No institution" : _account.Institution;

    private string BuildOwnershipDetail() => _account?.IsShared == true ? "Shared household account." : "Single-owner account context.";

    private string BuildBalanceDetail() =>
        IsInvestmentAccount
            ? "Displayed as current market value when performance data is available."
            : "Displayed from the current account balance record.";

    private string BuildFreshnessDetail()
    {
        if (_account is null)
        {
            return string.Empty;
        }

        var age = DateTime.UtcNow - _account.UpdatedAt;
        return age.TotalDays < 1
            ? "Updated today."
            : age.TotalDays < 30
                ? $"Updated {Math.Floor(age.TotalDays)} days ago."
                : $"Last updated on {_account.UpdatedAt:MMM d, yyyy}.";
    }

    private string FormatMoney(decimal amount) => $"{amount:C} {_account?.Currency ?? "CAD"}";
}
