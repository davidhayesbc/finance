@page "/accounts"
@inject IAccountService AccountService
@inject IAnalyticsService AnalyticsService
@inject IPriceHistoryService PriceHistoryService
@inject NavigationManager Navigation

<PageTitle>Accounts — Privestio</PageTitle>

<section class="page-shell" data-testid="accounts-page">
    <PageHeader Eyebrow="Accounts" Title="Account workspace"
                Description="Review balances, institutions, and account types in one consistently styled table.">
        <Actions>
            <FluentButton Appearance="Appearance.Outline" Loading="_isSyncingHistory"
                          @onclick="SyncHistoricalPricesAsync" aria-label="Sync historical prices from Yahoo Finance">
                Sync Market History
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" @onclick="@(() => Navigation.NavigateTo("/accounts/new"))"
                          aria-label="Add new account">
                Add Account
            </FluentButton>
        </Actions>
    </PageHeader>

    @if (_isLoading)
    {
        <LoadingSpinner AriaLabel="Loading accounts" />
    }
    else if (_accounts.Count == 0)
    {
        <EmptyStateCard Message="No accounts yet. Add your first account to get started.">
            <Actions>
                <FluentButton Appearance="Appearance.Accent" @onclick="@(() => Navigation.NavigateTo("/accounts/new"))">
                    Add Account
                </FluentButton>
            </Actions>
        </EmptyStateCard>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_syncMessage))
        {
            <FluentMessageBar Intent="@_syncMessageIntent" style="margin-bottom: 1rem;">@_syncMessage</FluentMessageBar>
        }

        @if (_netWorthHistory is not null)
        {
            <FluentCard Class="surface-card data-card" style="margin-bottom: 1.5rem;">
                <div class="section-heading-row" style="margin-bottom: 1rem;">
                    <div>
                        <h3 style="margin: 0 0 0.25rem 0;">Net Worth Growth</h3>
                        <p class="section-copy">Trend line built from recorded balances, valuations, and persisted market
                            prices.</p>
                        </div>
                        <HistoryRangeSelector CurrentKey="@_selectedHistoryRange"
                                              Disabled="@(_isLoadingHistory || _isSyncingHistory)" OnChange="HandleHistoryRangeChangedAsync" />
                    </div>

                    @if (_isLoadingHistory)
                    {
                        <LoadingSpinner AriaLabel="Loading net worth history" />
                    }
                    else
                    {
                        <HistoricalValueChart Points="_netWorthHistory.Points" SeriesName="Net Worth"
                                              EmptyTitle="No net worth history yet."
                                              EmptyMessage="Sync historical prices and keep account activity current to visualize growth over time." />
                    }
                </FluentCard>
            }

            <FluentCard Class="surface-card data-card">
                <div class="summary-strip">
                    <div>
                        <span class="summary-strip__label">Total accounts</span>
                        <strong>@_accounts.Count</strong>
                    </div>
                    <div>
                        <span class="summary-strip__label">Institutions</span>
                        <strong>@_accounts.Select(a => a.Institution).Where(i =>
                                                                                                                        !string.IsNullOrWhiteSpace(i)).Distinct(StringComparer.OrdinalIgnoreCase).Count()</strong>
                        </div>
                    </div>

                    <FluentDataGrid Items="_accounts.OrderByDescending(a => a.CurrentBalance).ThenBy(a => a.Name).AsQueryable()"
                                    aria-label="Accounts table" TGridItem="AccountResponse" Class="data-grid--elevated data-grid--accounts"
                                    ResizableColumns="true" ResizeType="DataGridResizeType.Discrete" HeaderCellAsButtonWithMenu="true"
                                    ResizeColumnOnAllRows="false" ShowHover="true" DisplayMode="DataGridDisplayMode.Table"
                                    RowSize="DataGridRowSize.Medium">
                        <TemplateColumn Title="Account Name" SortBy="@(GridSort<AccountResponse>.ByAscending(a => a.Name))"
                                        Width="260px">
                            <span class="cell-truncate" title="@(string.IsNullOrWhiteSpace(context.Name) ? "Unnamed account" : context.Name)">@context.Name</span>
                        </TemplateColumn>
                        <PropertyColumn Property="a => a.AccountType" Title="Type" Sortable="true" Width="150px" />
                        <TemplateColumn Title="Institution"
                                        SortBy="@(GridSort<AccountResponse>.ByAscending(a => a.Institution ?? string.Empty))" Width="200px">
                            <span class="cell-truncate" title="@(string.IsNullOrWhiteSpace(context.Institution) ? "No institution" : context.Institution)">@(context.Institution ??
                                         "-")</span>
                            </TemplateColumn>
                            <TemplateColumn Title="Balance" SortBy="@(GridSort<AccountResponse>.ByDescending(a => a.CurrentBalance))"
                                            Width="160px">
                                <FluentBadge Appearance="Appearance.Neutral" Class="balance-badge">
                                    @context.CurrentBalance.ToString("C") @context.Currency
                                </FluentBadge>
                            </TemplateColumn>
                            <TemplateColumn Title="" Width="100px">
                                <FluentStack Orientation="Orientation.Horizontal" Class="grid-actions grid-actions--compact">
                                    <FluentButton Appearance="Appearance.Outline" Class="account-view-button"
                                                  @onclick="@(() => Navigation.NavigateTo($"/accounts/{context.Id}"))"
                                                  aria-label="@($"View {context.Name}")">
                                        View
                                    </FluentButton>
                                </FluentStack>
                            </TemplateColumn>
                        </FluentDataGrid>
                    </FluentCard>
                }
            </section>

@code {
    private List<AccountResponse> _accounts = new();
    private NetWorthHistoryResponse? _netWorthHistory;
    private bool _isLoadingHistory = true;
    private bool _isLoading = true;
    private bool _isSyncingHistory;
    private string _selectedHistoryRange = "1y";
    private string? _syncMessage;
    private MessageIntent _syncMessageIntent = MessageIntent.Success;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageAsync();
        _isLoading = false;
    }

    private async Task LoadPageAsync()
    {
        _isLoadingHistory = true;

        var accountsTask = AccountService.GetAccountsAsync();
        await accountsTask;
        _accounts = (await accountsTask).ToList();

        var (fromDate, toDate) = ResolveHistoryRange();
        _netWorthHistory = await AnalyticsService.GetNetWorthHistoryAsync(fromDate, toDate);
        _isLoadingHistory = false;
    }

    private async Task HandleHistoryRangeChangedAsync(string rangeKey)
    {
        _selectedHistoryRange = rangeKey;
        _isLoadingHistory = true;

        var (fromDate, toDate) = ResolveHistoryRange();
        _netWorthHistory = await AnalyticsService.GetNetWorthHistoryAsync(fromDate, toDate);
        _isLoadingHistory = false;
    }

    private async Task SyncHistoricalPricesAsync()
    {
        _isSyncingHistory = true;
        _syncMessage = null;

        try
        {
            var result = await PriceHistoryService.SyncHistoricalPricesAsync();
            if (result is null)
            {
                _syncMessageIntent = MessageIntent.Error;
                _syncMessage = "Historical price sync failed.";
                return;
            }

            _syncMessageIntent = MessageIntent.Success;
            _syncMessage = $"Historical price sync complete. Inserted {result.QuotesInserted} quotes and skipped {result.QuotesSkipped}.";
            await LoadPageAsync();
        }
        finally
        {
            _isSyncingHistory = false;
        }
    }

    private (DateOnly? FromDate, DateOnly ToDate) ResolveHistoryRange()
    {
        var toDate = DateOnly.FromDateTime(DateTime.UtcNow);
        return _selectedHistoryRange switch
        {
            "90d" => (toDate.AddDays(-89), toDate),
            "1y" => (toDate.AddYears(-1), toDate),
            "all" => (_accounts.Count == 0 ? null : _accounts.Min(account => account.OpeningDate), toDate),
            _ => (toDate.AddYears(-1), toDate),
        };
    }
}
