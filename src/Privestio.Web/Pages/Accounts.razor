@page "/accounts"
@inject IAccountService AccountService
@inject IAnalyticsService AnalyticsService
@inject IJSRuntime JS
@inject IPriceHistoryService PriceHistoryService
@inject NavigationManager Navigation

<PageTitle>Accounts — Privestio</PageTitle>

<section class="page-shell accounts-shell" data-testid="accounts-page">
    <PageRegion Name="orientation" Class="accounts-orientation" aria-labelledby="accounts-title">
        <PageHeader Eyebrow="Accounts" Title="Accounts" Description="Review balances, institutions, types, and data freshness across the full account set.">
            <Actions>
                <FluentButton Appearance="Appearance.Outline" Loading="_isSyncingHistory"
                              @onclick="SyncHistoricalPricesAsync" aria-label="Sync historical prices from Yahoo Finance">
                    Sync Market History
                </FluentButton>
                <FluentButton Appearance="Appearance.Accent" @onclick="@(() => Navigation.NavigateTo("/accounts/new"))"
                              aria-label="Add new account">
                    Add Account
                </FluentButton>
            </Actions>
        </PageHeader>

        @if (!string.IsNullOrWhiteSpace(_syncMessage))
        {
            <FluentMessageBar Intent="@_syncMessageIntent">@_syncMessage</FluentMessageBar>
        }
    </PageRegion>

    <PageRegion Name="supporting" Class="accounts-posture" aria-labelledby="accounts-posture-title">
        <PostureStrip Title="Financial posture"
                      TitleId="accounts-posture-title"
                      Description="Show the shape of the account universe before the ledger detail."
                      HeaderClass="accounts-section-heading"
                      GridClass="accounts-posture__grid">

            <article class="accounts-posture__item">
                <span class="accounts-posture__label">Accounts</span>
                <strong>@_accounts.Count</strong>
                <span>@BuildAccountsPostureDetail()</span>
            </article>
            <article class="accounts-posture__item">
                <span class="accounts-posture__label">Institutions</span>
                <strong>@InstitutionCount</strong>
                <span>@BuildInstitutionPostureDetail()</span>
            </article>
            <article class="accounts-posture__item">
                <span class="accounts-posture__label">Investment share</span>
                <strong>@FormatPercent(InvestmentShare)</strong>
                <span>@FormatMoney(InvestmentBalances, PrimaryCurrency)</span>
            </article>
            <article class="accounts-posture__item">
                <span class="accounts-posture__label">Debt share</span>
                <strong>@FormatPercent(DebtShare)</strong>
                <span>@FormatMoney(TotalLiabilitiesAbsolute, PrimaryCurrency)</span>
            </article>
            <article class="accounts-posture__item">
                <span class="accounts-posture__label">Stale data</span>
                <strong>@StaleAccounts.Count</strong>
                <span>@BuildStalePostureDetail()</span>
            </article>
        </PostureStrip>
    </PageRegion>

    <PageRegion Name="supporting" Class="accounts-history" aria-labelledby="accounts-history-title">
        <ChartFrame Title="Net worth history"
                    TitleId="accounts-history-title"
                    Description="Compact trend evidence above the main ledger, with the frame kept stable during range changes."
                    HeaderClass="accounts-section-heading accounts-section-heading--split"
                    CanvasClass="accounts-history__body"
                    IsLoading="@(!_hasLoadedHistory && (_isLoading || _isLoadingHistory))"
                    IsUpdating="@(_hasLoadedHistory && _isLoadingHistory)"
                    IsEmpty="@(_netWorthHistory is null || _netWorthHistory.Points.Count == 0)"
                    EmptyTitle="History is unavailable right now."
                    EmptyMessage="The strip stays visible so the page still reads like one ledger workspace.">
            <HeaderActions>
                <HistoryRangeSelector CurrentKey="@_selectedHistoryRange"
                                      Disabled="@(_isLoadingHistory || _isSyncingHistory)" OnChange="HandleHistoryRangeChangedAsync" />
            </HeaderActions>
            <ChildContent>
                @if (_netWorthHistory is not null)
                {
                    <HistoricalValueChart Points="_netWorthHistory.Points" SeriesName="Net Worth"
                                          EmptyTitle="No net worth history yet."
                                          EmptyMessage="Sync historical prices and keep account activity current to build the account trend line." />
                }
            </ChildContent>
        </ChartFrame>
    </PageRegion>

    <div class="accounts-support-grid">
        <PageRegion Name="supporting" Class="accounts-filters" aria-labelledby="accounts-filters-title">
            <SectionBand Title="Grouping support"
                         TitleId="accounts-filters-title"
                         Description="Reduce complexity without displacing the ledger."
                         HeaderClass="accounts-section-heading">

            <div class="accounts-filter-row">
                @foreach (var filter in AccountFilters)
                {
                    <button type="button" class="@GetFilterButtonClass(filter.Key)" @onclick="() => _selectedFilter = filter.Key">
                        <span>@filter.Label</span>
                        <strong>@GetFilterCount(filter.Key)</strong>
                    </button>
                }
            </div>
            </SectionBand>
        </PageRegion>

        <PageRegion Name="exceptions" Class="accounts-exceptions" aria-labelledby="accounts-exceptions-title">
            <SectionBand Title="Data quality"
                         TitleId="accounts-exceptions-title"
                         Description="Visible maintenance work for missing balances, stale records, and dormant accounts."
                         HeaderClass="accounts-section-heading">

            <div class="accounts-exceptions__list">
                @foreach (var item in ExceptionItems)
                {
                    <OperationalExceptionRow Title="@item.Title"
                                             Detail="@item.Detail"
                                             Severity="@ToSeverity(item.Tone)" />
                }
            </div>
            </SectionBand>
        </PageRegion>
    </div>

    <PageRegion Name="primary" Class="accounts-ledger" aria-labelledby="accounts-ledger-title">
        <SectionBand Title="Accounts"
                     TitleId="accounts-ledger-title"
                     Description="Account name, type, institution, status, last updated, and current balance in one calm ledger."
                     Meta='@($"{FilteredAccounts.Count} account{(FilteredAccounts.Count == 1 ? string.Empty : "s")}")'
                     HeaderClass="accounts-section-heading accounts-section-heading--split">
        <DenseTableSurface IsLoading="@_isLoading"
                           IsEmpty="@(FilteredAccounts.Count == 0)"
                           LoadingRows="6"
                           LoadingColumns="7"
                           EmptyTitle="No accounts yet."
                           EmptyMessage="Add your first account to turn this shell into a live ledger.">
            <div class="table-surface table-surface--grid table-surface--scroll" data-testid="accounts-ledger-grid">
                <FluentDataGrid Items="FilteredAccounts.AsQueryable()"
                                TGridItem="AccountResponse"
                                Class="data-grid--elevated data-grid--accounts"
                                aria-label="Accounts ledger"
                                ResizableColumns="true"
                                ResizeType="DataGridResizeType.Discrete"
                                HeaderCellAsButtonWithMenu="true"
                                ResizeColumnOnAllRows="false"
                                ShowHover="true"
                                DisplayMode="DataGridDisplayMode.Table"
                                RowSize="DataGridRowSize.Medium"
                                ItemKey="@(account => account.Id)">
                    <TemplateColumn Title="Account" SortBy="@(GridSort<AccountResponse>.ByAscending(a => a.Name))" Width="250px">
                        <button type="button"
                                id="@GetRowCellButtonId(context.Id, "account")"
                                class="accounts-ledger__row-link"
                                @onclick='@(() => OpenAccountDetailAsync(context.Id))'
                                aria-label='@($"Open details for {context.Name}")'>
                            <div class="accounts-ledger__identity">
                                <strong>@context.Name</strong>
                                <span>@BuildAccountSubline(context)</span>
                            </div>
                        </button>
                    </TemplateColumn>
                    <TemplateColumn Title="Type" SortBy="@(GridSort<AccountResponse>.ByAscending(a => a.AccountType))" Width="140px">
                        <button type="button"
                                class="accounts-ledger__row-link"
                                @onclick='@(() => OpenAccountDetailAsync(context.Id))'
                                aria-label='@($"Open details for {context.Name}")'>
                            @context.AccountType
                        </button>
                    </TemplateColumn>
                    <TemplateColumn Title="Institution" SortBy="@(GridSort<AccountResponse>.ByAscending(a => a.Institution ?? string.Empty))" Width="180px">
                        <button type="button"
                                class="accounts-ledger__row-link"
                                @onclick='@(() => OpenAccountDetailAsync(context.Id))'
                                aria-label='@($"Open details for {context.Name}")'>
                            <span class="cell-truncate" title="@FormatInstitution(context)">@FormatInstitution(context)</span>
                        </button>
                    </TemplateColumn>
                    <TemplateColumn Title="Status" SortBy="@(GridSort<AccountResponse>.ByAscending(a => BuildStatusLabel(a)))" Width="120px">
                        <button type="button"
                                class="accounts-ledger__row-link"
                                @onclick='@(() => OpenAccountDetailAsync(context.Id))'
                                aria-label='@($"Open details for {context.Name}")'>
                            <span class="@GetStatusBadgeClass(context)">@BuildStatusLabel(context)</span>
                        </button>
                    </TemplateColumn>
                    <TemplateColumn Title="Last updated" SortBy="@(GridSort<AccountResponse>.ByDescending(a => a.UpdatedAt))" Width="140px">
                        <button type="button"
                                class="accounts-ledger__row-link"
                                @onclick='@(() => OpenAccountDetailAsync(context.Id))'
                                aria-label='@($"Open details for {context.Name}")'>
                            @FormatUpdated(context.UpdatedAt)
                        </button>
                    </TemplateColumn>
                    <TemplateColumn Title="Balance" SortBy="@(GridSort<AccountResponse>.ByDescending(a => Math.Abs(a.CurrentBalance)))" Width="150px">
                        <button type="button"
                                class="accounts-ledger__row-link accounts-ledger__row-link--numeric"
                                @onclick='@(() => OpenAccountDetailAsync(context.Id))'
                                aria-label='@($"Open details for {context.Name}")'>
                            <div class="accounts-ledger__numeric">@FormatMoney(context.CurrentBalance, context.Currency)</div>
                        </button>
                    </TemplateColumn>
                    <TemplateColumn Title="Action" Width="110px">
                        <div class="grid-actions grid-actions--compact">
                            <FluentButton Appearance="Appearance.Stealth"
                                          Id="@GetQuickViewButtonId(context.Id)"
                                          Class="accounts-ledger__action"
                                          OnClick='@(() => ShowQuickViewAsync(context))'
                                          aria-label='@($"Quick view {context.Name}")'>
                                Quick
                            </FluentButton>
                            <FluentButton Appearance="Appearance.Stealth"
                                          Id="@GetOpenButtonId(context.Id)"
                                          Class="accounts-ledger__action"
                                          OnClick='@(() => OpenAccountDetailAsync(context.Id))'
                                          aria-label='@($"Open dossier for {context.Name}")'>
                                Open
                            </FluentButton>
                        </div>
                    </TemplateColumn>
                </FluentDataGrid>
            </div>
        </DenseTableSurface>

        @if (_selectedQuickViewAccount is not null)
        {
            <InspectorPanel Title="Quick detail"
                            TitleId="accounts-quick-sheet-title"
                            Description="Small account checks stay in a side sheet while filters and ledger context remain visible."
                            HeadingLevel="3"
                            Variant="sheet"
                            Class="accounts-quick-sheet">
                <HeaderActions>
                    <FluentButton Appearance="Appearance.Stealth" OnClick="ClearQuickViewAsync">Close</FluentButton>
                </HeaderActions>
                <ChildContent>
                    <div class="accounts-quick-sheet__facts">
                        <strong>@_selectedQuickViewAccount.Name</strong>
                        <span>@BuildAccountSubline(_selectedQuickViewAccount)</span>
                        <span>@FormatInstitution(_selectedQuickViewAccount)</span>
                        <span>Balance: @FormatMoney(_selectedQuickViewAccount.CurrentBalance, _selectedQuickViewAccount.Currency)</span>
                        <span>Status: @BuildStatusLabel(_selectedQuickViewAccount)</span>
                    </div>
                    <div class="action-cluster">
                        <FluentButton Appearance="Appearance.Accent" OnClick='@(() => OpenAccountDetailAsync(_selectedQuickViewAccount.Id))'>
                            Open dossier
                        </FluentButton>
                    </div>
                </ChildContent>
            </InspectorPanel>
        }
        </SectionBand>
    </PageRegion>
</section>

@code {
    private static readonly IReadOnlyList<AccountFilterOption> AccountFilters =
    [
        new("all", "All"),
        new("investment", "Investment"),
        new("debt", "Debt"),
        new("shared", "Shared"),
        new("stale", "Stale"),
    ];

    private List<AccountResponse> _accounts = new();
    private NetWorthHistoryResponse? _netWorthHistory;
    private bool _isLoadingHistory = true;
    private bool _isLoading = true;
    private bool _isSyncingHistory;
    private bool _hasLoadedHistory;
    private bool _hasRestoredViewState;
    private bool _initialized;
    private string _selectedHistoryRange = "1y";
    private string _selectedFilter = "all";
    private string? _syncMessage;
    private AccountResponse? _selectedQuickViewAccount;
    private string? _lastQuickViewInvokerId;
    private MessageIntent _syncMessageIntent = MessageIntent.Success;

    private List<AccountResponse> FilteredAccounts =>
        _accounts
            .Where(MatchesSelectedFilter)
            .OrderByDescending(account => Math.Abs(account.CurrentBalance))
            .ThenBy(account => account.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private List<AccountResponse> StaleAccounts =>
        _accounts.Where(IsStaleAccount).ToList();

    private List<AccountIssueItem> ExceptionItems => BuildExceptionItems();

    private int InstitutionCount =>
        _accounts.Select(account => account.Institution)
            .Where(institution => !string.IsNullOrWhiteSpace(institution))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();

    private decimal TotalAssets => _accounts.Where(account => account.CurrentBalance > 0m).Sum(account => account.CurrentBalance);

    private decimal TotalLiabilitiesAbsolute =>
        Math.Abs(_accounts.Where(account => account.CurrentBalance < 0m).Sum(account => account.CurrentBalance));

    private decimal InvestmentBalances =>
        _accounts.Where(IsInvestmentAccount).Where(account => account.CurrentBalance > 0m).Sum(account => account.CurrentBalance);

    private decimal InvestmentShare => TotalAssets <= 0m ? 0m : InvestmentBalances / TotalAssets;

    private decimal DebtShare
    {
        get
        {
            var grossExposure = TotalAssets + TotalLiabilitiesAbsolute;
            return grossExposure <= 0m ? 0m : TotalLiabilitiesAbsolute / grossExposure;
        }
    }

    private string PrimaryCurrency =>
        _accounts.Select(account => account.Currency)
            .FirstOrDefault(currency => !string.IsNullOrWhiteSpace(currency))
        ?? "CAD";

    protected override async Task OnParametersSetAsync()
    {
        ApplyFilterFromQuery();

        if (_initialized)
        {
            return;
        }

        await LoadPageAsync();
        _isLoading = false;
        _initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_isLoading && !_hasRestoredViewState)
        {
            _hasRestoredViewState = true;
            await JS.InvokeVoidAsync("uiState.restoreScrollState", "accounts-ledger");
        }
    }

    private async Task LoadPageAsync()
    {
        _isLoadingHistory = true;

        var accountsTask = AccountService.GetAccountsAsync();
        await accountsTask;
        _accounts = (await accountsTask).ToList();

        var (fromDate, toDate) = ResolveHistoryRange();
        _netWorthHistory = await AnalyticsService.GetNetWorthHistoryAsync(fromDate, toDate);
        _hasLoadedHistory = true;
        _isLoadingHistory = false;
    }

    private async Task HandleHistoryRangeChangedAsync(string rangeKey)
    {
        _selectedHistoryRange = rangeKey;
        _isLoadingHistory = true;

        var (fromDate, toDate) = ResolveHistoryRange();
        _netWorthHistory = await AnalyticsService.GetNetWorthHistoryAsync(fromDate, toDate);
        _isLoadingHistory = false;
    }

    private async Task SyncHistoricalPricesAsync()
    {
        _isSyncingHistory = true;
        _syncMessage = null;

        try
        {
            var result = await PriceHistoryService.SyncHistoricalPricesAsync();
            if (result is null)
            {
                _syncMessageIntent = MessageIntent.Error;
                _syncMessage = "Historical price sync failed.";
                return;
            }

            _syncMessageIntent = MessageIntent.Success;
            _syncMessage = $"Historical price sync complete. Inserted {result.QuotesInserted} quotes and skipped {result.QuotesSkipped}.";
            await LoadPageAsync();
        }
        finally
        {
            _isSyncingHistory = false;
        }
    }


    private (DateOnly? FromDate, DateOnly ToDate) ResolveHistoryRange()
    {
        var toDate = DateOnly.FromDateTime(DateTime.UtcNow);
        return _selectedHistoryRange switch
        {
            "90d" => (toDate.AddDays(-89), toDate),
            "1y" => (toDate.AddYears(-1), toDate),
            "all" => (_accounts.Count == 0 ? null : _accounts.Min(account => account.OpeningDate), toDate),
            _ => (toDate.AddYears(-1), toDate),
        };
    }

    private string BuildAccountsPostureDetail() =>
        _accounts.Count == 0
            ? "No accounts on file yet."
            : $"{FilteredAccounts.Count} shown in the current filter.";

    private string BuildInstitutionPostureDetail() =>
        InstitutionCount == 0 ? "No institutions assigned yet." : "Distinct institutions represented in the ledger.";

    private string BuildStalePostureDetail() =>
        StaleAccounts.Count == 0 ? "No stale account records detected." : "Accounts older than 30 days need review.";

    private bool MatchesSelectedFilter(AccountResponse account) => _selectedFilter switch
    {
        "investment" => IsInvestmentAccount(account),
        "debt" => IsLiabilityAccount(account),
        "shared" => account.IsShared,
        "stale" => IsStaleAccount(account),
        _ => true,
    };

    private int GetFilterCount(string key) =>
        _accounts.Count(account => key switch
        {
            "investment" => IsInvestmentAccount(account),
            "debt" => IsLiabilityAccount(account),
            "shared" => account.IsShared,
            "stale" => IsStaleAccount(account),
            _ => true,
        });

    private string GetFilterButtonClass(string key) =>
        string.Equals(_selectedFilter, key, StringComparison.OrdinalIgnoreCase)
            ? "accounts-filter accounts-filter--active"
            : "accounts-filter";

    private static UiSeverity ToSeverity(string tone) => tone switch
    {
        "risk" => UiSeverity.Urgent,
        "warning" => UiSeverity.Advisory,
        _ => UiSeverity.Informational,
    };

    private Task ShowQuickViewAsync(AccountResponse account)
    {
        _selectedQuickViewAccount = account;
        _lastQuickViewInvokerId = GetQuickViewButtonId(account.Id);
        return Task.CompletedTask;
    }

    private async Task ClearQuickViewAsync()
    {
        _selectedQuickViewAccount = null;

        if (!string.IsNullOrWhiteSpace(_lastQuickViewInvokerId))
        {
            await JS.InvokeVoidAsync("uiState.focusElementById", _lastQuickViewInvokerId);
        }
    }

    private async Task OpenAccountDetailAsync(Guid accountId)
    {
        await JS.InvokeVoidAsync("uiState.saveScrollState", "accounts-ledger", GetOpenButtonId(accountId));
        var safeFilter = Uri.EscapeDataString(_selectedFilter);
        Navigation.NavigateTo($"/accounts/{accountId}?returnFilter={safeFilter}");
    }

    private static string GetQuickViewButtonId(Guid accountId) => $"accounts-quick-{accountId:N}";

    private static string GetOpenButtonId(Guid accountId) => $"accounts-open-{accountId:N}";

    private static string GetRowCellButtonId(Guid accountId, string columnKey) => $"accounts-row-{columnKey}-{accountId:N}";

    private void ApplyFilterFromQuery()
    {
        var query = Navigation.ToAbsoluteUri(Navigation.Uri).Query;
        if (string.IsNullOrWhiteSpace(query))
        {
            return;
        }

        var segments = query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries);
        foreach (var segment in segments)
        {
            var keyValue = segment.Split('=', 2);
            if (keyValue.Length != 2 || !string.Equals(keyValue[0], "filter", StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            var requestedFilter = Uri.UnescapeDataString(keyValue[1]);
            if (AccountFilters.Any(option => string.Equals(option.Key, requestedFilter, StringComparison.OrdinalIgnoreCase)))
            {
                _selectedFilter = requestedFilter;
            }
        }
    }

    private static bool IsInvestmentAccount(AccountResponse account)
    {
        var descriptor = $"{account.AccountType} {account.AccountSubType}";
        return ContainsAny(descriptor, "invest", "rrsp", "tfsa", "resp", "fhsa", "broker", "security", "crypto", "lira", "pension");
    }

    private static bool IsLiabilityAccount(AccountResponse account)
    {
        var descriptor = $"{account.AccountType} {account.AccountSubType}";
        return ContainsAny(descriptor, "mortgage", "credit", "loan", "debt", "line of credit", "liability");
    }

    private static bool IsPropertyAccount(AccountResponse account)
    {
        var descriptor = $"{account.AccountType} {account.AccountSubType}";
        return ContainsAny(descriptor, "property", "real estate", "realestate", "home");
    }

    private static bool ContainsAny(string value, params string[] candidates) =>
        candidates.Any(candidate => value.Contains(candidate, StringComparison.OrdinalIgnoreCase));

    private static bool IsStaleAccount(AccountResponse account) =>
        account.UpdatedAt <= DateTime.UtcNow.AddDays(-30);

    private static string FormatPercent(decimal value) => $"{value:P0}";

    private static string FormatMoney(decimal amount, string currency) => $"{amount:C} {currency}";

    private static string FormatInstitution(AccountResponse account) =>
        string.IsNullOrWhiteSpace(account.Institution) ? "No institution" : account.Institution;

    private static string FormatUpdated(DateTime updatedAt)
    {
        var age = DateTime.UtcNow - updatedAt;
        if (age.TotalDays < 1)
        {
            return "Today";
        }

        if (age.TotalDays < 30)
        {
            return $"{Math.Floor(age.TotalDays)}d ago";
        }

        return updatedAt.ToString("yyyy-MM-dd");
    }

    private static string BuildAccountSubline(AccountResponse account)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(account.AccountSubType))
        {
            parts.Add(account.AccountSubType);
        }

        if (account.IsShared)
        {
            parts.Add("Shared");
        }

        if (!account.IsActive)
        {
            parts.Add("Inactive");
        }

        return parts.Count == 0 ? "Household ledger entry" : string.Join(" · ", parts);
    }

    private static string BuildStatusLabel(AccountResponse account)
    {
        if (!account.IsActive)
        {
            return "Inactive";
        }

        if (IsStaleAccount(account))
        {
            return "Stale";
        }

        if (string.IsNullOrWhiteSpace(account.Institution))
        {
            return "Review";
        }

        return "Current";
    }

    private static string GetStatusBadgeClass(AccountResponse account) =>
        BuildStatusLabel(account) switch
        {
            "Inactive" => "accounts-status-badge accounts-status-badge--muted",
            "Stale" => "accounts-status-badge accounts-status-badge--warning",
            "Review" => "accounts-status-badge accounts-status-badge--risk",
            _ => "accounts-status-badge accounts-status-badge--ok",
        };

    private List<AccountIssueItem> BuildExceptionItems()
    {
        if (_accounts.Count == 0)
        {
            return
            [
                new("No account data yet", "Add an account to start the maintenance workflow and populate the ledger.", "neutral"),
            ];
        }

        var zeroOpeningBalances = _accounts.Count(account => account.OpeningBalance == 0m);
        var missingInstitutions = _accounts.Count(account => !IsPropertyAccount(account) && string.IsNullOrWhiteSpace(account.Institution));
        var staleAccounts = StaleAccounts.Count;
        var inactiveAccounts = _accounts.Count(account => !account.IsActive);
        var emptyAccounts = _accounts.Count(account => account.CurrentBalance == 0m);

        var items = new List<AccountIssueItem>
        {
            new(
                "Zero opening balance",
                zeroOpeningBalances == 0
                    ? "All accounts currently start with a non-zero opening balance."
                    : $"{zeroOpeningBalances} account{(zeroOpeningBalances == 1 ? string.Empty : "s")} start at 0.00; review whether that is intentional.",
                zeroOpeningBalances == 0 ? "neutral" : "warning"
            ),
            new(
                "Stale account state",
                staleAccounts == 0
                    ? "No accounts are older than the freshness threshold."
                    : $"{staleAccounts} account{(staleAccounts == 1 ? string.Empty : "s")} have not refreshed in the last 30 days.",
                staleAccounts == 0 ? "neutral" : "risk"
            ),
            new(
                "Institution coverage",
                missingInstitutions == 0
                    ? "Every account is assigned to an institution."
                    : $"{missingInstitutions} account{(missingInstitutions == 1 ? string.Empty : "s")} still need an institution name.",
                missingInstitutions == 0 ? "neutral" : "warning"
            ),
            new(
                "Dormant or empty accounts",
                inactiveAccounts + emptyAccounts == 0
                    ? "No dormant or zero-balance accounts require cleanup."
                    : $"{inactiveAccounts} inactive and {emptyAccounts} zero-balance account entries should be reviewed.",
                inactiveAccounts + emptyAccounts == 0 ? "neutral" : "warning"
            ),
        };

        return items;
    }

    private sealed record AccountFilterOption(string Key, string Label);

    private sealed record AccountIssueItem(string Title, string Detail, string Tone);
}
