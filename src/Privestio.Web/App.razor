<Router AppAssembly="typeof(App).Assembly">
    <Found Context="routeData">
        <div class="route-stage" @key="GetRouteKey(routeData)">
            <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)" />
        </div>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>Not found</PageTitle>
        <LayoutView Layout="typeof(Layout.MainLayout)">
            <EmptyStateCard Message="Sorry, there's nothing at this address." Intent="MessageIntent.Warning"
                            AriaLive="polite" />
        </LayoutView>
    </NotFound>
</Router>

<FluentToastProvider />
<FluentDialogProvider />
<FluentMessageBarProvider />
<FluentMenuProvider />
<FluentTooltipProvider />
<FluentKeyCodeProvider />

@code {
    private static string GetRouteKey(RouteData routeData) => routeData.PageType.FullName ?? routeData.PageType.Name;
}
