@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation

<div class="app-shell">
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="app-header">
        <div class="app-header__inner">
            <div class="brand-block">
                <FluentAnchor Href="/" Appearance="Appearance.Hypertext" Class="brand-link">
                    <span class="brand-mark">P</span>
                    <span>
                        <strong>Privestio</strong>
                        <span class="brand-tagline">Personal finance with clear signal</span>
                    </span>
                </FluentAnchor>
            </div>

            <nav class="primary-nav" aria-label="Primary navigation">
                <FluentAnchor Href="/" Class="nav-pill">Overview</FluentAnchor>
                @if (AuthService.IsAuthenticated)
                {
                    <FluentAnchor Href="/accounts" Class="nav-pill">Accounts</FluentAnchor>
                    <FluentAnchor Href="/import" Class="nav-pill">Import</FluentAnchor>
                    <FluentAnchor Href="/rules" Class="nav-pill">Rules</FluentAnchor>
                }
            </nav>

            <div class="header-actions">
                @if (AuthService.IsAuthenticated)
                {
                    <FluentButton Appearance="Appearance.Outline" OnClick="HandleLogoutAsync">
                        Sign out
                    </FluentButton>
                }
                else
                {
                    <FluentAnchor Href="/login" Class="nav-pill nav-pill--accent">Sign in</FluentAnchor>
                }
            </div>
        </div>
    </header>

    <div class="app-backdrop" aria-hidden="true">
        <div class="app-backdrop__orb app-backdrop__orb--left"></div>
        <div class="app-backdrop__orb app-backdrop__orb--right"></div>
    </div>

    <main id="main-content" class="app-main" role="main">
        <ErrorBoundary>
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent>
                <FluentCard Class="surface-card page-shell">
                    <FluentMessageBar Intent="@MessageIntent.Error">
                        An unexpected error occurred. Please refresh the page and try again.
                    </FluentMessageBar>
                </FluentCard>
            </ErrorContent>
        </ErrorBoundary>
    </main>

    <footer class="app-footer">
        <p>Privestio keeps budgets, imports, and account snapshots in one consistent workspace.</p>
    </footer>
</div>

@code {
    private async Task HandleLogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
