@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject IThemeService ThemeService
@inject NavigationManager Navigation
@implements IDisposable

<div class="app-shell">
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <div class="app-frame @(UseProductShell ? "app-frame--workspace" : "app-frame--public")">
        @if (UseProductShell)
        {
            <aside class="app-rail" aria-label="Primary navigation" data-testid="app-rail">
                <div class="app-rail__inner">
                    <FluentAnchor Href="/dashboard" Appearance="Appearance.Hypertext" Class="brand-link brand-link--rail">
                        <span class="brand-mark">P</span>
                        <span>
                            <strong>Privestio</strong>
                            <span class="brand-tagline">Private household finance instrument</span>
                        </span>
                    </FluentAnchor>

                    @foreach (var navSection in NavigationSections)
                    {
                        <section class="app-rail__section">
                            <span class="app-rail__label">@navSection.Label</span>
                            <nav class="app-rail__nav" aria-label="@navSection.Label">
                                @foreach (var item in navSection.Items)
                                {
                                    <FluentAnchor Href="@item.Href" Class="@GetRailLinkClass(item.Href)">@item.Label</FluentAnchor>
                                }
                            </nav>
                        </section>
                    }
                </div>
            </aside>
        }

        <div class="app-workspace">
            <header class="app-utility-strip" data-testid="app-utility-strip">
                <div class="app-utility-strip__identity">
                    @if (!UseProductShell)
                    {
                        <FluentAnchor Href="/" Appearance="Appearance.Hypertext" Class="brand-link">
                            <span class="brand-mark">P</span>
                            <span>
                                <strong>Privestio</strong>
                                <span class="brand-tagline">Private household finance instrument</span>
                            </span>
                        </FluentAnchor>
                    }
                    else
                    {
                        <span class="app-utility-strip__eyebrow">Stable shell</span>
                        <strong class="app-utility-strip__title">@GetFrameTitle()</strong>
                    }
                </div>

                <div class="app-utility-strip__controls">
                    <div class="status-cluster">
                        <OnlineIndicator />
                        <InstallPrompt />
                    </div>

                    <div class="theme-switcher" role="group" aria-label="Theme preference">
                        <button type="button" class="theme-switcher__button @GetThemeButtonClass("system")"
                                aria-pressed="@GetAriaPressed("system")" @onclick='() => SetThemePreferenceAsync("system")'>
                            Auto
                        </button>
                        <button type="button" class="theme-switcher__button @GetThemeButtonClass("light")"
                                aria-pressed="@GetAriaPressed("light")" @onclick='() => SetThemePreferenceAsync("light")'>
                            Light
                        </button>
                        <button type="button" class="theme-switcher__button @GetThemeButtonClass("dark")"
                                aria-pressed="@GetAriaPressed("dark")" @onclick='() => SetThemePreferenceAsync("dark")'>
                            Dark
                        </button>
                    </div>

                    @if (AuthService.IsAuthenticated)
                    {
                        <button type="button" class="app-button app-button--secondary header-cta"
                                @onclick="HandleLogoutAsync">
                            Sign out
                        </button>
                    }
                    else
                    {
                        <a href="/login" class="app-button app-button--primary header-cta">Sign in</a>
                    }
                </div>
            </header>

            <main id="main-content" class="app-main" role="main">
                <ErrorBoundary>
                    <ChildContent>
                        @Body
                    </ChildContent>
                    <ErrorContent>
                        <FluentCard Class="surface-card page-shell">
                            <FluentMessageBar Intent="@MessageIntent.Error">
                                An unexpected error occurred. Please refresh the page and try again.
                            </FluentMessageBar>
                        </FluentCard>
                    </ErrorContent>
                </ErrorBoundary>
            </main>

            <footer class="app-footer">
                <p>Privestio keeps balances, workflows, and exceptions inside one stable household finance workspace.</p>
            </footer>
        </div>
    </div>

    <div class="app-backdrop" aria-hidden="true">
        <div class="app-backdrop__orb app-backdrop__orb--left"></div>
        <div class="app-backdrop__orb app-backdrop__orb--right"></div>
    </div>
</div>

@code {
    private static readonly IReadOnlyList<NavigationSection> NavigationSections =
    [
        new(
            "Monitor",
            [
                new("/dashboard", "Dashboard"),
                new("/accounts", "Accounts"),
                new("/budgets", "Budgets"),
                new("/forecast", "Forecast"),
                new("/notifications", "Alerts"),
            ]
        ),
        new(
            "Workflow",
            [
                new("/import", "Import"),
                new("/rules", "Rules"),
                new("/reconciliation", "Reconciliation"),
                new("/sync/conflicts", "Sync Conflicts"),
            ]
        ),
        new(
            "Market Data",
            [
                new("/securities", "Pricing Sources"),
                new("/securities/review", "Security Review"),
                new("/forecast-scenarios", "Scenarios"),
                new("/plugins", "Plugin Catalog"),
            ]
        ),
    ];

    private ThemeState _themeState = ThemeState.Default;

    private bool UseProductShell => !IsPublicRoute();

    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitializeAsync();
        _themeState = ThemeService.State;
        ThemeService.ThemeChanged += HandleThemeChanged;
    }

    private async Task HandleLogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    private async Task SetThemePreferenceAsync(string preference)
    {
        await ThemeService.SetPreferenceAsync(preference);
    }

    private void HandleThemeChanged(ThemeState themeState)
    {
        _themeState = themeState;
        InvokeAsync(StateHasChanged);
    }

    private string GetThemeButtonClass(string preference) =>
        IsThemePreferenceSelected(preference) ? "theme-switcher__button--active" : string.Empty;

    private string GetAriaPressed(string preference) =>
        IsThemePreferenceSelected(preference)
            ? "true"
            : "false";

    private bool IsThemePreferenceSelected(string preference) =>
        string.Equals(_themeState.Preference, preference, StringComparison.OrdinalIgnoreCase);

    private string GetRailLinkClass(string href) =>
        IsActiveRoute(href)
            ? "app-rail__link app-rail__link--active"
            : "app-rail__link";

    private string GetFrameTitle()
    {
        var relativePath = GetRelativePath();
        return relativePath switch
        {
            "dashboard" => "Household dashboard",
            "accounts" => "Account ledger",
            "import" => "Import workbench",
            "budgets" => "Budget review",
            "forecast" => "Forecast plane",
            _ => "Household finance workspace",
        };
    }

    private bool IsPublicRoute()
    {
        var relativePath = GetRelativePath();
        return string.Equals(relativePath, "login", StringComparison.OrdinalIgnoreCase)
            || string.Equals(relativePath, "register", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsActiveRoute(string href)
    {
        var relativePath = GetRelativePath();
        var normalizedHref = href.Trim('/');

        if (string.IsNullOrWhiteSpace(normalizedHref))
        {
            return string.IsNullOrWhiteSpace(relativePath);
        }

        return string.Equals(relativePath, normalizedHref, StringComparison.OrdinalIgnoreCase)
            || relativePath.StartsWith($"{normalizedHref}/", StringComparison.OrdinalIgnoreCase);
    }

    private string GetRelativePath() => Navigation.ToBaseRelativePath(Navigation.Uri).TrimEnd('/');

    public void Dispose()
    {
        ThemeService.ThemeChanged -= HandleThemeChanged;
    }

    private sealed record NavigationItem(string Href, string Label);

    private sealed record NavigationSection(string Label, IReadOnlyList<NavigationItem> Items);
}
