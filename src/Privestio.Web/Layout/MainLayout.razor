@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject IThemeService ThemeService
@inject NavigationManager Navigation
@implements IDisposable

<div class="app-shell">
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <header class="app-header">
        <div class="app-header__inner">
            <div class="app-header__top">
                <div class="brand-block">
                    <FluentAnchor Href="/" Appearance="Appearance.Hypertext" Class="brand-link">
                        <span class="brand-mark">P</span>
                        <span>
                            <strong>Privestio</strong>
                            <span class="brand-tagline">Personal finance with clear signal</span>
                        </span>
                    </FluentAnchor>
                </div>

                <div class="app-header__controls">
                    <div class="status-cluster">
                        <OnlineIndicator />
                        <InstallPrompt />
                    </div>

                    <div class="theme-switcher" role="group" aria-label="Theme preference">
                        <button type="button" class="theme-switcher__button @GetThemeButtonClass("system")"
                                aria-pressed="@GetAriaPressed("system")" @onclick='() => SetThemePreferenceAsync("system")'>
                            Auto
                        </button>
                        <button type="button" class="theme-switcher__button @GetThemeButtonClass("light")"
                                aria-pressed="@GetAriaPressed("light")" @onclick='() => SetThemePreferenceAsync("light")'>
                            Light
                        </button>
                        <button type="button" class="theme-switcher__button @GetThemeButtonClass("dark")"
                                aria-pressed="@GetAriaPressed("dark")" @onclick='() => SetThemePreferenceAsync("dark")'>
                            Dark
                        </button>
                    </div>

                    @if (AuthService.IsAuthenticated)
                    {
                        <button type="button" class="app-button app-button--secondary header-cta"
                                @onclick="HandleLogoutAsync">
                            Sign out
                        </button>
                    }
                    else
                    {
                        <a href="/login" class="app-button app-button--primary header-cta">Sign in</a>
                    }
                </div>
            </div>

            <nav class="primary-nav" aria-label="Primary navigation">
                <FluentAnchor Href="/" Class="nav-pill">Overview</FluentAnchor>
                @if (AuthService.IsAuthenticated)
                {
                    <FluentAnchor Href="/dashboard" Class="nav-pill">Dashboard</FluentAnchor>
                    <FluentAnchor Href="/accounts" Class="nav-pill">Accounts</FluentAnchor>
                    <FluentAnchor Href="/securities" Class="nav-pill">Security Pricing Sources</FluentAnchor>
                    <FluentAnchor Href="/securities/review" Class="nav-pill">Security Review</FluentAnchor>
                    <FluentAnchor Href="/budgets" Class="nav-pill">Budgets</FluentAnchor>
                    <FluentAnchor Href="/sinking-funds" Class="nav-pill">Savings</FluentAnchor>
                    <FluentAnchor Href="/recurring-transactions" Class="nav-pill">Recurring</FluentAnchor>
                    <FluentAnchor Href="/spending" Class="nav-pill">Spending</FluentAnchor>
                    <FluentAnchor Href="/cash-flow" Class="nav-pill">Cash Flow</FluentAnchor>
                    <FluentAnchor Href="/debt" Class="nav-pill">Debt</FluentAnchor>
                    <FluentAnchor Href="/forecast" Class="nav-pill">Forecast</FluentAnchor>
                    <FluentAnchor Href="/forecast-scenarios" Class="nav-pill">Scenarios</FluentAnchor>
                    <FluentAnchor Href="/contribution-room" Class="nav-pill">Contribution Room</FluentAnchor>
                    <FluentAnchor Href="/reconciliation" Class="nav-pill">Reconciliation</FluentAnchor>
                    <FluentAnchor Href="/sync/conflicts" Class="nav-pill">Sync Conflicts</FluentAnchor>
                    <FluentAnchor Href="/notifications" Class="nav-pill">Alerts</FluentAnchor>
                    <FluentAnchor Href="/import" Class="nav-pill">Import</FluentAnchor>
                    <FluentAnchor Href="/import/mappings" Class="nav-pill">Import Plugin Mappings</FluentAnchor>
                    <FluentAnchor Href="/plugins" Class="nav-pill">Plugin Catalog</FluentAnchor>
                    <FluentAnchor Href="/rules" Class="nav-pill">Rules</FluentAnchor>
                }
            </nav>
        </div>
    </header>

    <div class="app-backdrop" aria-hidden="true">
        <div class="app-backdrop__orb app-backdrop__orb--left"></div>
        <div class="app-backdrop__orb app-backdrop__orb--right"></div>
    </div>

    <main id="main-content" class="app-main" role="main">
        <ErrorBoundary>
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent>
                <FluentCard Class="surface-card page-shell">
                    <FluentMessageBar Intent="@MessageIntent.Error">
                        An unexpected error occurred. Please refresh the page and try again.
                    </FluentMessageBar>
                </FluentCard>
            </ErrorContent>
        </ErrorBoundary>
    </main>

    <footer class="app-footer">
        <p>Privestio keeps budgets, imports, and account snapshots in one consistent workspace.</p>
    </footer>
</div>

@code {
    private ThemeState _themeState = ThemeState.Default;

    protected override async Task OnInitializedAsync()
    {
        await ThemeService.InitializeAsync();
        _themeState = ThemeService.State;
        ThemeService.ThemeChanged += HandleThemeChanged;
    }

    private async Task HandleLogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    private async Task SetThemePreferenceAsync(string preference)
    {
        await ThemeService.SetPreferenceAsync(preference);
    }

    private void HandleThemeChanged(ThemeState themeState)
    {
        _themeState = themeState;
        InvokeAsync(StateHasChanged);
    }

    private string GetThemeButtonClass(string preference) =>
        IsThemePreferenceSelected(preference) ? "theme-switcher__button--active" : string.Empty;

    private string GetAriaPressed(string preference) =>
        IsThemePreferenceSelected(preference)
            ? "true"
            : "false";

    private bool IsThemePreferenceSelected(string preference) =>
        string.Equals(_themeState.Preference, preference, StringComparison.OrdinalIgnoreCase);

    public void Dispose()
    {
        ThemeService.ThemeChanged -= HandleThemeChanged;
    }
}
